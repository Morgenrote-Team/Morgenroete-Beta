entity = {
	name = "mr_stethoscope_entity"
	pdxmesh = "mr_stethoscope_mesh"

	attribute = { name = "body_bs_fat"                              blend_shape = "mr_stethoscope_bs_fat" }
	attribute = { name = "body_bs_gaunt"                            blend_shape = "mr_stethoscope_bs_gaunt" }
	
    game_data = { ## PLACEHOLDER / NO REAL CHANGE HERE
        portrait_entity_user_data = {
            portrait_accessory = {
                pattern_mask   = "gfx/models/portraits/attachments/male_headgear/extra_headgear/mr_stethoscope/mr_stethoscope_masks.dds"
                variation      = "mr_headgear_pith_helmet"
            }
        }
    }

}



