		texture_normal = "building_mr_airport_decal_normal.dds"
		texture_specular = "building_mr_airport_decal_properties.dds"
		shader = "decal_local"
		shader_file = "gfx/FX/pdxmesh_decal.shader"
		subpass = "LocalDecals"
	}
}

entity = {
	name = "building_mr_airport_entity"
