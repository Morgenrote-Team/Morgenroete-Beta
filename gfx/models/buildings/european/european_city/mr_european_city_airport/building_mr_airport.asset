pdxmesh = {
	name = "building_mr_airport_mesh"
	file = "building_mr_airport.mesh"

	meshsettings = {
		name = "mr_building_airportShape"
		index = 0
		texture_diffuse = "building_mr_airport_diffuse.dds"
		texture_normal = "building_mr_airport_normal.dds"
		texture_specular = "building_mr_airport_properties.dds"
		shader = "standard_alpha_to_coverage"
