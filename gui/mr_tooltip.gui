@tooltip_max_width = 650

types MR_TooltipRankingTypes
{
	type MR_TooltipRankingType = container {
		using = tooltip_properties

		state = {
			name = _show
			block "ranking_on_finish" {
				on_finish = "[GetScriptedGui('mr_chemistry_ranking_sgui').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]" #Resets the Ranking
			}
		}

		container = {
			flowcontainer = {
				direction = vertical

				block "tooltip_margins" {
					margin = { 18 15 }
				}

				flowcontainer = {
					ignoreinvisible = yes
					parentanchor = top|hcenter
					widgetanchor = top|hcenter
					margin_bottom = 10
					block "buttons_visible" {
						visible = no
					}
					sort_button = {
						using = fontsize_small
						align = center|nobaseline
						size = { 102 30 }
						block "button_1_content" {
							visible = no
						}
					}
					sort_button = {
						using = fontsize_small
						align = center|nobaseline
						size = { 102 30 }
						block "button_2_content" {
							visible = no
						}
					}
					sort_button = {
