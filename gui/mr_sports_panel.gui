        blockoverride "occupation_data_header_text" {
            text = mr_sports_coach_data_header
        }
        blockoverride "occupation_data_content" {
            margin_top = 5
            margin_left = 0
            margin_right = 0

            hbox = {
                layoutpolicy_horizontal = expanding
                margin_left = 15
                margin_right = 15

                expand = {}

                mr_shared_data_text = {
                    align = center
                    raw_text = "[Country.GetCustom('vikelas_fifa_president_type')]"
                    tooltip = MR_FIFA_PRESIDENT_TOOLTIP
