                    # Join FIFA
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_join_fifa_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_JOIN_FIFA_BUTTON"
                            tooltip = "MR_JOIN_FIFA_BUTTON_TT"
