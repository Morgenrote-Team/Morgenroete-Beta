                            datacontext = "[GetScriptedGui('mr_alpine_club_propose_expedition_button_sgui')]"
                            blockoverride "button_content" {
                                text = "MR_ALPINE_CLUB_PROPOSE_EXPEDITION_BUTTON"
                                tooltip = "MR_ALPINE_CLUB_PROPOSE_EXPEDITION_BUTTON_TT"
                            }
                        }

                        # Alpine Club - Join Expedition
                        mr_shared_project_button = {
                            datacontext = "[GetScriptedGui('mr_alpine_club_join_expedition_button_sgui')]"
                            blockoverride "button_content" {
                                text = "MR_ALPINE_CLUB_JOIN_EXPEDITION_BUTTON"
                                tooltip = "MR_ALPINE_CLUB_JOIN_EXPEDITION_BUTTON_TT"
                            }
                        }

                        # Alpine Club President
                        mr_shared_project_button = {
                            datacontext = "[GetScriptedGui('mr_alpine_club_president_button_sgui')]"
                            blockoverride "button_content" {
                                text = "MR_ALPINE_CLUB_PRESIDENT_BUTTON"
                                tooltip = "MR_ALPINE_CLUB_PRESIDENT_BUTTON_TT"
                            }
                        }

                        expand = {}
                    }
                }
                blockoverride "stop_context" {
                    datacontext = "[GetScriptedGui('mr_stop_mountaineer_project_button_sgui')]"
                }
            }
        }
    }

    type mr_sports_coach = mr_shared_occupation {
        blockoverride "occupation_character_context" {
