            hbox = {
                layoutpolicy_horizontal = expanding
                margin_left = 15
                margin_right = 15

                expand = {}

                mr_shared_data_text = {
                    align = center
                    raw_text = "[Country.GetCustom('vikelas_national_sport_type')]"
                }
            }
        }
        blockoverride "visit_button_visibility" {
            visible = no
        }
        blockoverride "big_box_content" {
            mr_shared_interactions_simple = {
                blockoverride "content" {
                    # Adapt National Sport
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_adapt_national_sport_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_ADAPT_NATIONAL_SPORT_BUTTON"
