@panel_button_width = 290
@panel_text_width = 250

types mr_main_sports_panel_types {

    type mr_sports_panel = fullscreen_block_window {
        name = "mr_sports_panel"
        datacontext = "[GetMetaPlayer.GetPlayedOrObservedCountry]"

        background = {
            using = illu_alpha
            fittype = center
            texture = "gfx/interface/illustrations/tech_tree/illustration_tech_society.dds"
            using = default_content_fade
        }

        visible = "[GetVariableSystem.HasValue('com_open_window', 'mr_sidebar_button_sports_sgui')]"

        blockoverride "animation_state_block" {
            state = {
                name = _show
                # Close open panel before showing this one
                on_start = "[InformationPanelBar.ClosePanel]"
                on_start = "[MapListPanelManager.CloseCurrentPanel]"
                # Fullscreen panels hide topbar
                on_finish = "[GetVariableSystem.Set('com_fullscreen', 'com_fullscreen')]"
                start_sound = {
                    soundeffect = "event:/SFX/UI/SideBar/markets"
                }
                start_sound = {
                    soundeffect = "snapshot:/Dynamic/mute_world_80"
                }
                start_sound = {
                    soundeffect = "snapshot:/Dynamic/mute_vfx_war_100"
                }
            }

            state = {
                name = _hide
                on_start = "[GetVariableSystem.Clear('com_fullscreen')]"
                on_finish = "[GetVariableSystem.Clear('mr_sports_tab')]"
                start_sound = {
                    soundeffect = "event:/SFX/UI/SideBar/markets_stop"
                }
            }
        }

        blockoverride "window_header_name" {
            text = SPORTS_OVERVIEW_VIEW_NAME
            default_format = "#bold"
        }

        blockoverride "back_button_fullscreen" {
            back_button_large = {
                position = { 11 15 }
                parentanchor = top|left
                onclick = "[GetVariableSystem.Clear('com_open_window')]"
                onclick = "[GetVariableSystem.Clear('com_alert_action')]"
                onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
                input_action = "back"
            }
        }

        close_button_large = {
            name = "tutorial_highlight_close_button"
            parentanchor = top|right
            onclick = "[GetVariableSystem.Clear('com_open_window')]"
            onclick = "[GetVariableSystem.Clear('com_alert_action')]"
            onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
            shortcut = "close_window"
            position = { -56 115 }
        }

        blockoverride "close_button_position" {
            visible = no
        }

        blockoverride "fixed_top" {
            tab_buttons_fullscreen = {
                name = "mr_tutorial_highlight_sports_tab_bar"
                # Sports
                blockoverride "first_button" {
                    text = "mr_sports_tab_main"
                }
                blockoverride "first_button_background" {
                    background = {
                        margin = { 0 -2 }
                        using = fade_bottom_entry_fancy_header_colored
                        using = Color_Red
                        alpha = 0.5
                    }
                }
                blockoverride "first_button_click" {
                    onclick = "[GetVariableSystem.Set('mr_sports_tab', 'main')]"
                }
                blockoverride "first_button_visibility" {
                    visible = "[Or(
									GetVariableSystem.HasValue('mr_sports_tab', 'main'),
									Not(GetVariableSystem.Exists('mr_sports_tab'))
								)]"
                }
                blockoverride "first_button_visibility_checked" {
                    visible = "[And(
									Not(GetVariableSystem.HasValue('mr_sports_tab', 'main')),
									GetVariableSystem.Exists('mr_sports_tab')
								)]"
                }
                blockoverride "first_button_selected" {
                    text = "mr_sports_tab_main"
                }
                blockoverride "first_button_background_selected" {
                    background = {
                        using = fade_bottom_entry_fancy_header_colored
                        using = Color_Red
                        alpha = 0.5
                    }
                }

                # Aeronautics
                blockoverride "second_button" {
                    name = "mr_tutorial_highlight_sports_tab_aeronautics"
                    text = "mr_sports_tab_aeronautics"
                }
                blockoverride "second_button_background" {
                    background = {
                        margin = { 0 -2 }
                        using = fade_bottom_entry_fancy_header_colored
                        using = Color_Red
                        alpha = 0.5
                    }
                }
                blockoverride "second_button_click" {
                    onclick = "[GetVariableSystem.Set('mr_sports_tab', 'aeronautics')]"
                }
                blockoverride "second_button_visibility" {
                    visible = "[GetVariableSystem.HasValue('mr_sports_tab', 'aeronautics')]"
                }
                blockoverride "second_button_visibility_checked" {
                    visible = "[Not(GetVariableSystem.HasValue('mr_sports_tab', 'aeronautics'))]"
                }
                blockoverride "second_button_selected" {
                    text = "mr_sports_tab_aeronautics"
                }
                blockoverride "second_button_background_selected" {
                    background = {
                        using = fade_bottom_entry_fancy_header_colored
                        using = Color_Red
                        alpha = 0.5
                    }
                }
            }
        }

        blockoverride "scrollarea_content" {
            vbox = {
                layoutpolicy_vertical = expanding
                layoutpolicy_horizontal = expanding

                mr_shared_tab_fullscreen = {
                    blockoverride "view_visibility" {
                        visible = "[Or(GetVariableSystem.HasValue('mr_sports_tab', 'main'), Not(GetVariableSystem.Exists('mr_sports_tab')))]"
                    }
                    blockoverride "view_content" {
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_sports_olympics = {}
                            expand = {}
                            mr_sports_mountaineer = {}
                        }
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_sports_coach = {}
                            expand = {}
                            mr_sports_car_racing = {}
                        }
                    }
                }

                mr_shared_tab_fullscreen = {
                    blockoverride "view_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_sports_tab', 'aeronautics')]"
                    }
                    blockoverride "view_content" {
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_sports_balloonist = {}
                            expand = {}
                            mr_sports_pilot = {}
                        }
                    }
                }
            }
        }
    }

    type mr_sports_balloonist = mr_shared_occupation {
        name = "mr_tutorial_highlight_balloonist"
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('curtiss_balloonist_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/curtiss_balloonist_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_curtiss_balloonist_role_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "BALLOONIST_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('sports_has_balloonist_gui_type')]"
        }
        blockoverride "occupation_achievements_icon_visibility" {
            visible = no
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('curtiss_balloonist_experience_var').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "MR_BALLOONIST_EXPERIENECE_TT"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_curtiss_balloonist_experience_text_type')]"
        }
        blockoverride "occupation_data_header_text" {
            text = mr_sports_balloonist_data_header
        }
        blockoverride "occupation_data_content" {
            margin_top = 5
            margin_left = 0
            margin_right = 0

            hbox = {
                margin_left = 15
                margin_right = 15
                margin_bottom = 20

                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding

                # Left Side
                hbox = {
                    spacing = 5
                    layoutpolicy_horizontal = expanding
                    layoutpolicy_vertical = expanding

                    # Flag
                    vbox = {
                        spacing = 5
                        layoutpolicy_vertical = expanding

                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[Country.GetFlagTextIcon]"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[Country.GetFlagTextIcon]"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[Country.GetFlagTextIcon]"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }

                        expand = {}
                    }

                    # Type
                    vbox = {
                        spacing = 5
                        layoutpolicy_vertical = expanding

                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_records_altitude"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_records_distance"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_records_time"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }

                        expand = {}
                    }

                    expand = {}
                }

                expand = {}

                # Right Side
                hbox = {
                    spacing = 5
                    layoutpolicy_vertical = expanding

                    # Record
                    vbox = {
                        spacing = 5
                        layoutpolicy_vertical = expanding

                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[Country.MakeScope.Var('curtiss_balloon_altitude_record_var').GetValue|V0]"
                            align = right
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[Country.MakeScope.Var('curtiss_balloon_distance_record_var').GetValue|V0]"
                            align = right
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[Country.MakeScope.Var('curtiss_balloon_time_record_var').GetValue|V0]"
                            align = right
                            block "font_size" {
                                using = fontsize_large
                            }
                        }

                        expand = {}
                    }

                    # Units
                    vbox = {
                        spacing = 5
                        layoutpolicy_vertical = expanding

                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_unit_meters"
                            block "font_size" {
                                using = fontsize_small
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_unit_kilometers"
                            block "font_size" {
                                using = fontsize_small
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_unit_hours"
                            block "font_size" {
                                using = fontsize_small
                            }
                        }

                        expand = {}
                    }

                    expand = {}
                }
            }

            default_header_clean_faded = {
                blockoverride "size" {
                    size = { @panel_text_width 40 }
                }
                blockoverride "text" {
                    text = "mr_sports_balloonist_data_header_intl"
                }
            }

            hbox = {
                margin_left = 15
                margin_right = 15

                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding

                # Left Side
                hbox = {
                    spacing = 5
                    layoutpolicy_horizontal = expanding
                    layoutpolicy_vertical = expanding

                    # Flag
                    vbox = {
                        spacing = 5
                        layoutpolicy_vertical = expanding

                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[GetGlobalVariable('curtiss_balloon_altitude_record_holder_global_var').GetCountry.GetFlagTextIcon]"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[GetGlobalVariable('curtiss_balloon_distance_record_holder_global_var').GetCountry.GetFlagTextIcon]"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[GetGlobalVariable('curtiss_balloon_time_record_holder_global_var').GetCountry.GetFlagTextIcon]"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }

                        expand = {}
                    }

                    # Type
                    vbox = {
                        spacing = 5
                        layoutpolicy_vertical = expanding

                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_records_altitude"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_records_distance"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_records_time"
                            block "font_size" {
                                using = fontsize_large
                            }
                        }

                        expand = {}
                    }

                    expand = {}
                }

                expand = {}

                # Right Side
                hbox = {
                    spacing = 5
                    layoutpolicy_vertical = expanding

                    # Record
                    vbox = {
                        spacing = 5
                        layoutpolicy_vertical = expanding

                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[GetGlobalVariable('curtiss_balloon_altitude_record_global_var').GetValue|V0]"
                            align = right
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[GetGlobalVariable('curtiss_balloon_distance_record_global_var').GetValue|V0]"
                            align = right
                            block "font_size" {
                                using = fontsize_large
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            raw_text = "[GetGlobalVariable('curtiss_balloon_time_record_global_var').GetValue|V0]"
                            align = right
                            block "font_size" {
                                using = fontsize_large
                            }
                        }

                        expand = {}
                    }

                    # Units
                    vbox = {
                        spacing = 5
                        layoutpolicy_vertical = expanding

                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_unit_meters"
                            block "font_size" {
                                using = fontsize_small
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_unit_kilometers"
                            block "font_size" {
                                using = fontsize_small
                            }
                        }
                        mr_shared_data_text = {
                            minimumsize = { -1 30 }
                            text = "mr_sports_balloonist_unit_hours"
                            block "font_size" {
                                using = fontsize_small
                            }
                        }

                        expand = {}
                    }

                    expand = {}
                }
            }
        }
        blockoverride "visit_button_visibility" {
            visible = no
        }
        blockoverride "big_box_content" {
            mr_shared_interactions_simple = {
                blockoverride "content" {
                    # Recruit Balloonist
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_sponsor_balloonist_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_RECRUIT_BALLOONIST_BUTTON"
                            tooltip = "MR_RECRUIT_BALLOONIST_BUTTON_TT"
                        }
                    }

                    # Fire Balloonist
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_fire_balloonist_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_FIRE_BALLOONIST_BUTTON"
                            tooltip = "MR_FIRE_BALLOONIST_BUTTON_TT"
                        }
                    }

                    # Gordon Bennett Cup
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_gordon_bennett_cup_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_GORDON_BENNETT_CUP_BUTTON"
                            tooltip = "MR_GORDON_BENNETT_CUP_BUTTON_TT"
                        }
                    }

                    # No more Flight Information
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_ballooning_no_more_flight_information_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_NO_MORE_BALLOON_FLIGHT_EVENTS_BUTTON"
                            tooltip = "MR_NO_MORE_BALLOON_FLIGHT_EVENTS_BUTTON_TT"
                        }
                    }

                    # Show Flight Information
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_ballooning_flight_information_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_SHOW_BALLOON_FLIGHT_EVENTS_BUTTON"
                            tooltip = "MR_SHOW_BALLOON_FLIGHT_EVENTS_BUTTON_TT"
                        }
                    }

                    # No more Death Events
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_ballooning_no_more_death_information_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_NO_MORE_BALLOONIST_DEATH_EVENTS_BUTTON"
                            tooltip = "MR_NO_MORE_BALLOONIST_DEATH_EVENTS_BUTTON_TT"
                        }
                    }

                    # Show Death Events
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_ballooning_death_information_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_SHOW_BALLOONIST_DEATH_EVENTS_BUTTON"
                            tooltip = "MR_SHOW_BALLOONIST_DEATH_EVENTS_BUTTON_TT"
                        }
                    }

                    expand = {}
                }
                blockoverride "stop_project_visibility" {
                    visible = no
                }
            }
        }
    }

    type mr_sports_pilot = mr_shared_occupation {
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('curtiss_pilot_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/curtiss_pilot_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_curtiss_pilot_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "PILOT_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('curtiss_has_pilot_gui_type')]"
        }
        blockoverride "occupation_achievements_icon_visibility" {
            visible = no
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('curtiss_pilot_experience').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_curtiss_pilot_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_curtiss_pilot_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_schneider_tophy_victories_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                    }
                    blockoverride "text_1" {
                        raw_text = "PILOT_SCHNEIDER_TROPHY_VICTORIES_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = yes
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_schneider_trophy_victories_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
                        raw_text = "[Country.MakeScope.GetVariable('curtiss_schneider_trophy_victories_var').GetValue|*V0]"
                    }
                }
            }
        }
        blockoverride "occupation_data_header_text" {
            text = mr_sports_pilot_data_header
        }
        blockoverride "occupation_data_content" {
            margin_top = 5

            # Information about the Pilot and Schneider Trophy
            mr_shared_data_text = {
                text = "MR_PILOT_INFORMATION"
            }
        }
        blockoverride "big_box_content" {
            mr_shared_interactions_simple = {
                blockoverride "content" {
                    # Air Combat Mission
                    mr_shared_activity_button = {
                        datacontext = "[GetScriptedGui('mr_curtiss_air_combat_mission_button_sgui')]"
                        blockoverride "button_content" {
                            text = "mr_sports_pilot_combat_button_text"
                            tooltip = "MR_AIR_COMBAR_MISSION_BUTTON_TT"
                        }
                        blockoverride "button_highlight_visible" {
                            visible = "[GetScriptedGui('mr_curtiss_air_combat_mission_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                        }
                        blockoverride "button_icon" {
                            texture = "gfx/interface/icons/GUI_icons/GUI_curtiss_air_combat_button.dds"
                        }
                    }

                    # Aircraft Parade
                    mr_shared_activity_button = {
                        datacontext = "[GetScriptedGui('mr_curtiss_aircraft_parade_button_sgui')]"
                        blockoverride "button_content" {
                            text = "mr_sports_pilot_parade_button_text"
                            tooltip = "MR_AIRCRAFT_PARADE_BUTTON_TT"
                        }
                        blockoverride "button_highlight_visible" {
                            visible = "[GetScriptedGui('mr_curtiss_aircraft_parade_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                        }
                        blockoverride "button_icon" {
                            texture = "gfx/interface/icons/GUI_icons/GUI_curtiss_aircraft_parade_button.dds"
                        }
                    }

                    # Schneider Trophy
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_curtiss_hold_schneider_trophy_race_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_HOLD_SCHNEIDER_TROPHY_RACE_BUTTON"
                            tooltip = "MR_HOLD_SCHNEIDER_TROPHY_RACE_BUTTON_TT"
                        }
                    }

                    # Found Pilot School
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_curtiss_found_pilot_school_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_CURTISS_FOUND_PILOT_SCHOOL_BUTTON"
                            tooltip = "MR_CURTISS_FOUND_PILOT_SCHOOL_BUTTON_TT"
                        }
                    }

                    expand = {}
                }
                blockoverride "stop_context" {
                    datacontext = "[GetScriptedGui('mr_stop_pilot_project_button_sgui')]"
                }
            }
        }
    }

    type mr_sports_olympics = mr_shared_occupation {
        name = "mr_tutorial_highlight_olympics"
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('GUI_vikelas_athlete_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/GUI_icons/GUI_olympic_games_with_background.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_vikelas_olympic_games_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "OLYMPIC_GAMES_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('sports_has_athlete_gui_type')]"
        }
        blockoverride "occupation_achievements_icon_visibility" {
            visible = no
        }
        blockoverride "occupation_experience_value_bar_visibility" {
            visible = no
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_olympic_medals_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                    }
                    blockoverride "text_1" {
                        raw_text = "OLYMPIC_GOLD_MEDALS_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = yes
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_olympic_medals_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
