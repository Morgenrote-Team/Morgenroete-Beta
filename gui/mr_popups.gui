                                            size = { 60 70 }
                                            elide = right
                                            align = center|nobaseline
                                            using = fontsize_medium
                                        }

                                        #Divider
                                        vertical_divider = {
                                            blockoverride "size" {
                                                size = { 3 70 }
                                            }
                                        }

                                        building_progressbars = {
                                            parentanchor = center
                                            blockoverride "progressbar_size" {
                                                size = { 110 20 }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            button = {
                #Start Project Button
                parentanchor = hcenter
                using = default_button_primary_big_action
                size = { 300 45 }
                raw_text = "MR_START_BUILDINGS_PROJECT"
                using = fontsize_large

                block "start_button_datacontext" {
                    datacontext = "[GetScriptedGui('mr_biologist_improve_agriculture_window_start_button_sgui')]"
                }
                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                tooltip = "MR_START_BUILDINGS_PROJECT_TT"
            }

            button = {
                #Accept Chosen Buildings List Button
                parentanchor = hcenter
                using = default_button_primary_big_action
                size = { 300 45 }
                raw_text = "MR_SAVE_NEW_BUILDINGS_LIST"
                using = fontsize_large

                block "accept_prioritization_button_datacontext" {
                    datacontext = "[GetScriptedGui('mr_biologist_improve_agriculture_window_change_chosen_buildings_button_sgui')]"
                }
                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                tooltip = "MR_SAVE_NEW_BUILDINGS_LIST_TT"
            }
        }

        #Close button
        button_icon_round = {
            parentanchor = top|right
            size = { 42 42 }
            position = { -5 13 }

            block "close_button_onclick" {
                onclick = "[GetScriptedGui('mr_biologist_improve_agriculture_window_close_button_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            }
            tooltip = "MR_CLOSE_WINDOW_TT"
            shortcut = "close_window"

            blockoverride "icon" {
                texture = "gfx/interface/buttons/button_icons/close.dds"
            }
            blockoverride "icon_size" {
                size = { 100% 100% }
            }
        }
    }

    type state_choser_popup = window {

        layer = popups
        using = clickthrough_blocker
        filter_mouse = all
        movable = yes
        allow_outside = yes
        parentanchor = center

        size = { 900 605 }

        enabled = "[GetMetaPlayer.GetPlayedOrObservedCountry.IsValid]"
        visible = yes
        block "visible" {
            visible = "[And( GetScriptedGui('mr_state_prioritizing_topographic_project_window_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End), And( IsInGame, And( Not( IsPauseMenuShown ), Not( IsGameOverScreenShown ))))]"
        }

        widget = {
            size = { 100% 100% }

            background = {
                texture = "gfx/interface/backgrounds/popup_bg.dds"
                spriteType = Corneredstretched
                spriteborder = { 90 90 }
                texture_density = 2

                modify_texture = {
                    texture = "gfx/interface/backgrounds/default_bg_shading.dds"
                    spriteType = Corneredstretched
                    spriteborder = { 0 0 }
                    blend_mode = overlay
                }
                modify_texture = {
                    using = texture_velvet
                }
            }
        }

        ### HEADER
        widget = {
            size = { 100% 82 }

            popup_top_header = {}

            textbox = {
                block "first_line_position" {
                    position = { 0 24 }
                }
                size = { 75% 40 }
                raw_text = "MR_STATE_CHOSER_HEADER"
                elide = right
                fontsize_min = 14
                parentanchor = hcenter
                align = hcenter|nobaseline
                using = header_font
                using = header_font_size
                default_format = "#header"
            }

            block "second_line" {}
        }

        ### FRAME
        popup_bg_frame = {}

        ### Actual stuff
        flowcontainer = {
            direction = vertical
            parentanchor = center
            minimumsize = { 850 505 }

            widget = {
                size = { 850 55 }
            }

            flowcontainer = {
                margin = { 10 0 }

                default_header_clean_faded = {
                    size = { 425 40 }
                    position = { 14 306 }
                    blockoverride "text" {
                    }
                    textbox = {
                        text = "VALID_STATES_HEADER_TEXT"
                        parentanchor = center
                        autoresize = yes
                        max_width = 350
                        elide = right
                        using = fontsize_large
                    }
                }
                default_header_clean_faded = {
                    size = { 425 40 }
                    position = { 14 306 }
                    blockoverride "text" {
                    }
                    textbox = {
                        text = "CHOSEN_STATES_HEADER_TEXT"
                        parentanchor = center
                        autoresize = yes
                        max_width = 350
                        elide = right
                        using = fontsize_large
                    }
                }
            }

            flowcontainer = {
                margin = { 10 0 }
                spacing = 2

                sort_button = {
                    size = { 140 30 }
                    text = "NAME"
                    enabled = no
                    align = center|nobaseline
                }

                sort_button = {
                    size = { 68 30 }
                    text = "MR_INCORPORATION_STATUS"
                    tooltip = "MR_INCORPORATION_STATUS_TT"
                    block "sort_by_incorporation_status" {
                        datacontext = "[GetScriptedGui('mr_sort_topographic_state_by_status_button_sgui')]"
                        onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                    }
                    align = center|nobaseline
                }

                sort_button = {
                    size = { 71 30 }
                    block "sort_by_third_button_name_and_tooltip" {
                        text = "MR_INFRASTRUCTURE_BALANCE"
                        tooltip = "MR_INFRASTRUCTURE_BALANCE_TT"
                    }
                    using = fontsize_xsmall
                    block "sort_by_third_button" {
                        datacontext = "[GetScriptedGui('mr_sort_topographic_state_by_infrastructure_button_sgui')]"
                    }
                    onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                    align = center|nobaseline
                }

                sort_button = {
                    size = { 110 30 }
                    block "sort_by_fourth_button_name" {
                        text = "MR_JOBSEEKERS"
                    }
                    block "sort_by_fourth_button_effect" {
                        enabled = no
                    }
                    align = center|nobaseline
                }

                widget = {
                    size = { 36 10 }
                }

                sort_button = {
                    size = { 150 30 }
                    text = "NAME"
                    enabled = no
                    align = center|nobaseline
                }

                sort_button = {
                    size = { 68 30 }
                    text = "MR_INCORPORATION_STATUS"
                    enabled = no
                    align = center|nobaseline
                }

                sort_button = {
                    size = { 71 30 }
                    block "sort_by_third_button_name" {
                        text = "MR_INFRASTRUCTURE_BALANCE_NO_CONCEPT"
                    }
                    using = fontsize_xsmall
                    enabled = no
                    align = center|nobaseline
                }

                sort_button = {
                    size = { 100 30 }
                    block "sort_by_fourth_button_name" {
                        text = "MR_JOBSEEKERS_NO_CONCEPT"
                    }
                    enabled = no
                    align = center|nobaseline
                }

            }

            flowcontainer = {
                minimumsize = { 850 390 }
                margin = { 10 2 }
                spacing = 10

                #Left Side
                scrollbox = {
                    size = { 410 380 }

                    scrollbarpolicy_horizontal = always_off
                    scrollbarpolicy_vertical = as_needed

                    scrollbar_vertical = {
                        using = Scrollbar_Vertical
                    }

                    blockoverride "scrollbox_content" {
                        vbox = {
                            spacing = 5
                            block "datamodel_states" {
                                datamodel = "[Country.MakeScope.GetList('states_for_topographic_improvement_variable_list')]"
                            }

                            item = {
                                widget = {
                                    size = { 380 50 }
                                    background = {
                                        using = entry_bg_simple
                                    }
                                    datacontext = "[Scope.GetState]"

                                    flowcontainer = {
                                        spacing = 5
                                        margin = { 10 0 }

                                        #Name
                                        textbox = {
                                            raw_text = "[State.GetName]"
                                            size = { 150 50 }
                                            elide = right
                                            align = nobaseline
                                            using = fontsize_medium
                                        }
                                        #Unincorporated Status
                                        widget = {
                                            size = { 25 50 }

                                            icon = {
                                                parentanchor = center
                                                visible = "[And(State.IsUnincorporated, Not(State.IsIncorporating))]"
                                                size = { 25 25 }
                                                texture = "gfx/interface/icons/state_status_icons/unincorporated_state.dds"
                                            }
                                        }

                                        #Divider
                                        vertical_divider = {
                                            blockoverride "size" {
                                                size = { 3 50 }
                                            }
                                        }

                                        #Third Row
                                        textbox = {
                                            block "third_column_text" {
                                                raw_text = "[State.GetInfrastructureBalance|0+=]"
                                            }
                                            size = { 60 50 }
                                            elide = right
                                            align = center|nobaseline
                                            using = fontsize_large
                                        }

                                        #Divider
                                        vertical_divider = {
                                            blockoverride "size" {
                                                size = { 3 50 }
                                            }
                                        }

                                        #Fourth Row
                                        textbox = {
                                            block "fourth_column_text" {
                                                raw_text = "[State.GetNumJobseekers|Dv]"
                                            }
                                            size = { 70 50 }
                                            elide = right
                                            align = center|nobaseline
                                            using = fontsize_large
                                        }

                                        button_icon_move_right = {
                                            parentanchor = vcenter
                                            size = { 30 50 }

                                            block "general_list_to_prioritized_button_datacontext" {
                                                datacontext = "[GetScriptedGui('mr_transfer_from_general_list_to_prioritized_list_topographic_project_button_sgui')]"
                                            }
                                            onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).AddScope('chosen_state', Scope.GetState.MakeScope ).End)]"

                                            #tooltip = "TRANSFER_FORMATION_MOVE_UNITS_TOOLTIP"
                                            using = tooltip_above

                                            blockoverride "icon_size" {
                                                size = { 30 75% }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                #Right Side
                scrollbox = {
                    size = { 410 380 }

                    scrollbarpolicy_horizontal = always_off
                    scrollbarpolicy_vertical = as_needed

                    scrollbar_vertical = {
                        using = Scrollbar_Vertical
                    }

                    blockoverride "scrollbox_content" {
                        vbox = {
                            spacing = 5
                            block "datamodel_prioritized_states" {
                                datamodel = "[Country.MakeScope.GetList('prioritized_states_for_topographic_improvement_variable_list')]"
                            }

                            item = {
                                widget = {
                                    size = { 380 50 }
                                    background = {
                                        using = entry_bg_simple
                                    }
                                    datacontext = "[Scope.GetState]"

                                    flowcontainer = {
                                        spacing = 5

                                        button_icon_move_left = {
                                            parentanchor = vcenter
                                            size = { 30 50 }

                                            block "prioritized_list_to_general_button_datacontext" {
                                                datacontext = "[GetScriptedGui('mr_transfer_from_prioritized_list_to_general_list_topographic_project_button_sgui')]"
                                            }
                                            onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).AddScope('chosen_state', Scope.GetState.MakeScope ).End)]"

                                            blockoverride "icon_size" {
                                                size = { 30 75% }
                                            }
                                        }

                                        #Name
                                        textbox = {
                                            raw_text = "[Add_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)1')]. [State.GetName]"
                                            size = { 150 50 }
                                            elide = right
                                            align = nobaseline
                                            using = fontsize_medium
                                        }
                                        #Unincorporated Status
                                        widget = {
                                            size = { 25 50 }

                                            icon = {
                                                parentanchor = center
                                                visible = "[And(State.IsUnincorporated, Not(State.IsIncorporating))]"
                                                size = { 25 25 }
                                                texture = "gfx/interface/icons/state_status_icons/unincorporated_state.dds"
                                            }
                                        }

                                        #Divider
                                        vertical_divider = {
                                            blockoverride "size" {
                                                size = { 3 50 }
                                            }
                                        }

                                        #Third Row
                                        textbox = {
                                            block "third_column_text" {
                                                raw_text = "[State.GetInfrastructureBalance|0+=]"
                                            }
                                            size = { 60 50 }
                                            elide = right
                                            align = center|nobaseline
                                            using = fontsize_large
                                        }

                                        #Divider
                                        vertical_divider = {
                                            blockoverride "size" {
                                                size = { 3 50 }
                                            }
                                        }

                                        #Job Seekers
                                        textbox = {
                                            block "fourth_column_text" {
                                                raw_text = "[State.GetNumJobseekers|Dv]"
                                            }
                                            size = { 70 50 }
                                            elide = right
                                            align = center|nobaseline
                                            using = fontsize_large
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            button = {
                #Start Project Button
                parentanchor = hcenter
                using = default_button_primary_big_action
                size = { 300 45 }
                raw_text = "MR_START_STATES_PROJECT"
                using = fontsize_large

                block "start_button_datacontext" {
                    datacontext = "[GetScriptedGui('mr_state_prioritizing_topographic_project_window_start_button_sgui')]"
                }
                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                tooltip = "MR_START_STATES_PROJECT_TT"
            }

            button = {
                #Accept Prioritization Button
                parentanchor = hcenter
                using = default_button_primary_big_action
                size = { 300 45 }
                raw_text = "MR_ACCEPT_PRIORITIZED_STATES"
                using = fontsize_large

                block "accept_prioritization_button_datacontext" {
                    datacontext = "[GetScriptedGui('mr_state_prioritizing_topographic_project_window_change_priority_button_sgui')]"
                }
                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                tooltip = "MR_ACCEPT_PRIORITIZED_STATES_TT"
            }
        }

        #Close button
        button_icon_round = {
            parentanchor = top|right
            size = { 42 42 }
            position = { -5 13 }

            block "close_button_onclick" {
                onclick = "[GetScriptedGui('mr_state_prioritizing_topographic_project_window_close_button_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            }
            tooltip = "MR_CLOSE_WINDOW_TT"
            shortcut = "close_window"

            blockoverride "icon" {
                texture = "gfx/interface/buttons/button_icons/close.dds"
            }
            blockoverride "icon_size" {
                size = { 100% 100% }
            }
        }
    }

    type missing_cmf_popup = window {

        layer = popups
        using = clickthrough_blocker
        filter_mouse = all
        movable = yes
        allow_outside = yes
        parentanchor = center

        size = { 700 400 }

        enabled = "[GetMetaPlayer.GetPlayedOrObservedCountry.IsValid]"
        visible = yes
        block "visible" {
            visible = "[And( GetScriptedGui('mr_missing_cmf_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End), And( IsInGame, And( Not( IsPauseMenuShown ), Not( IsGameOverScreenShown ))))]"
        }

        widget = {
            size = { 100% 100% }

            background = {
                texture = "gfx/interface/backgrounds/popup_bg.dds"
                spriteType = Corneredstretched
                spriteborder = { 90 90 }
                texture_density = 2

                modify_texture = {
                    texture = "gfx/interface/backgrounds/default_bg_shading.dds"
                    spriteType = Corneredstretched
                    spriteborder = { 0 0 }
                    blend_mode = overlay
                }
                modify_texture = {
                    using = texture_velvet
                }
            }
        }

        ### HEADER
        widget = {
            size = { 100% 82 }

            popup_top_header = {}

            textbox = {
                block "first_line_position" {
                    position = { 0 24 }
                }
                size = { 75% 40 }
                raw_text = "MR_MISSING_CMF_HEADER"
                elide = right
                fontsize_min = 14
                parentanchor = hcenter
                align = hcenter|nobaseline
                using = header_font
                using = header_font_size
                default_format = "#header"
            }

            block "second_line" {}
        }

        ### FRAME
        popup_bg_frame = {}

        ### Actual stuff
        textbox = {
            block "textbox" {
                raw_text = "MR_MISSING_CMF_HEADER_LOC"
            }
            position = { 30 90 }
            size = { 640 280 }
			parentanchor = top
            align = top|left
            elide = right
            multiline = yes
            using = fontsize_large
        }

        #Close button
        button_icon_round = {
            parentanchor = top|right
            size = { 42 42 }
            position = { -5 13 }

            enabled = no
            tooltip = "MR_CLOSE_WINDOW_INACESSIBLE_CMF_TT"

            blockoverride "icon" {
                texture = "gfx/interface/buttons/button_icons/close.dds"
            }
            blockoverride "icon_size" {
                size = { 100% 100% }
            }
        }
    }
}
