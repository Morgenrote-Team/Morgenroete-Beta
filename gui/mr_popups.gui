# By Lord R

#################

widget = {
    visible = "[GetMetaPlayer.GetPlayedOrObservedCountry.IsValid]"
    datacontext = "[GetMetaPlayer.GetPlayedOrObservedCountry]"
    name = "mr_popups"

    size = { 100% 100% }

    #CMF Notification
    missing_cmf_popup = {}

    #Construction improvement project
    mr_building_chooser_multiple_popup = {
        blockoverride "gui_header" {
            raw_text = "MR_TESLA_BUILDING_CHOOSER_CONSTRUCTION_MULTIPLE_HEADER"
        }
        blockoverride "visible" {
            visible = "[And( GetScriptedGui('mr_improve_construction_sector_window_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End), And( IsInGame, And( Not( IsPauseMenuShown ), Not( IsGameOverScreenShown ))))]"
        }
        blockoverride "sort_by_size_datamodel" {
            datacontext = "[GetScriptedGui('mr_sort_construction_sector_building_by_size_button_sgui')]"
        }
        blockoverride "sort_by_productivity_datamodel" {
            datacontext = "[GetScriptedGui('mr_sort_construction_sector_building_by_productivity_button_sgui')]"
        }
        blockoverride "sort_by_employment_percentage_datamodel" {
            datacontext = "[GetScriptedGui('mr_sort_construction_sector_building_by_employment_percentage_button_sgui')]"
        }
        blockoverride "datamodel_buildings" {
            datamodel = "[Country.MakeScope.GetList('tesla_improve_construction_sector_building_buildings_variable_list')]"
        }
        blockoverride "general_list_to_prioritized_button_datacontext" {
            datacontext = "[GetScriptedGui('mr_engineer_improve_construction_transfer_from_general_list_to_prioritized_list_button_sgui')]"
        }
        blockoverride "datamodel_prioritized_buildings" {
            datamodel = "[Country.MakeScope.GetList('tesla_improve_construction_buildings_chosen_variable_list')]"
        }
        blockoverride "prioritized_list_to_general_button_datacontext" {
            datacontext = "[GetScriptedGui('mr_engineer_improve_construction_transfer_from_prioritized_list_to_general_list_button_sgui')]"
        }
        blockoverride "start_button_datacontext" {
            datacontext = "[GetScriptedGui('mr_engineer_improve_construction_window_start_button_sgui')]"
        }
        blockoverride "accept_prioritization_button_datacontext" {
            datacontext = "[GetScriptedGui('mr_engineer_improve_construction_window_change_chosen_buildings_button_sgui')]"
        }
        blockoverride "close_button_onclick" {
            onclick = "[GetScriptedGui('mr_engineer_improve_construction_window_close_button_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
        }
    }

