types mr_popup_types {
	type panum_character_treatment_per_trait_box = hbox {
		block "visible" {
            visible = "[GetScriptedGui('mr_character_has_sickly_trait_for_treatment_sgui').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
        }
        layoutpolicy_horizontal = expanding

        icon = {
            size = { 24 32 }

            block "trait_icon" {
                texture = "gfx/interface/icons/character_trait_icons/sickly.dds"
                tooltip = "MR_SICKLY_SPECIAL_TOOLTIP"
            }
        }

        #Probability of Success
        textbox = {
            max_update_rate = 100
            block "success_chance" {
                raw_text = "MR_SICKLY_TREATMENT_SUCCESS_LOC"
            }
            size = { 118 32 }
            elide = right
            align = nobaseline
            using = fontsize_medium
            margin = { 10 0 }
        }

        button_icon_round = {
            size = { 30 30 }

            block "datacontext" {
                datacontext = "[GetScriptedGui('mr_physician_sickly_treatment_button_sgui')]"
                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).AddScope('chosen_character', Scope.GetCharacter.MakeScope ).End)]"
            }
            block "tooltip" {
                tooltip = "MR_PHYSICIAN_SICKLY_TREATMENT_BUTTON_TT"
            }
            blockoverride "icon" {
                block "button_icon" {
                    texture = "gfx/interface/icons/GUI_icons/GUI_panum_treatment_standard_button.dds"
                }
            }
            blockoverride "icon_size" {
                size = { 70% 70% }
            }
        }

        expand = {}
	}

    type mr_send_to_asylum_chooser_popup = window {
        name = "mr_send_to_asylum_chooser_popup"
        layer = popups
        using = clickthrough_blocker
        filter_mouse = all
        movable = yes
        allow_outside = yes
        parentanchor = center

        size = { 780 380 }

        enabled = "[GetMetaPlayer.GetPlayedOrObservedCountry.IsValid]"
        visible = "[And( GetScriptedGui('mr_send_character_to_asylum_window_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End), And( IsInGame, And( Not( IsPauseMenuShown ), Not( IsGameOverScreenShown ))))]"

        widget = {
            size = { 100% 100% }

            background = {
                texture = "gfx/interface/backgrounds/popup_bg.dds"
                spriteType = Corneredstretched
                spriteborder = { 90 90 }
                texture_density = 2

                modify_texture = {
                    texture = "gfx/interface/backgrounds/default_bg_shading.dds"
                    spriteType = Corneredstretched
                    spriteborder = { 0 0 }
                    blend_mode = overlay
                }
                modify_texture = {
                    using = texture_velvet
                }
            }
        }

		### HEADER
		widget = {
			size = { 100% 82 }

			popup_top_header = {}

			textbox = {
				block "first_line_position" {
					position = { 0 24 }
				}
				size = { 75% 40 }
				block "window_header_name" {
					raw_text = "MR_ASYLUM_CHOOSER_HEADER"
				}
				elide = right
				fontsize_min = 14
				parentanchor = hcenter
				align = hcenter|nobaseline
				using = header_font
				using = header_font_size
				default_format = "#header"
			}

			block "second_line" {}
		}

		### FRAME
		popup_bg_frame = {}

        ### Actual stuff
		scrollbox = {
			size = { 730 280 }
			position = { 0 32 }
			parentanchor = center

			scrollbarpolicy_horizontal = as_needed
			scrollbarpolicy_vertical = always_off

			scrollbar_horizontal = {
				using = Scrollbar_Horizontal
			}

            blockoverride "scrollbox_content" {
                hbox = {
                    spacing = 20
                    datamodel = "[Country.MakeScope.GetList('panum_characters_to_asylum_variable_list')]"

                    item = {
                        widget = {
                            size = { 220 250 }
                            using = entry_bg_fancy
                            datacontext = "[Scope.GetCharacter]"

                            #General Information
                            widget = {
                                parentanchor = hcenter
                                size = { 220 35 }
                                scissor = yes

                                background = {
                                    using = default_header_bg
                                    using = frame_small_mask_top
                                }

                                character_role_icon = {
                                    parentanchor = left|vcenter
                                    position = { 10 0 }
                                    size = { 25 25 }
                                }

                                #Name
                                textbox = {
                                    raw_text = "#b [Character.GetFullName]#!"
                                    size = { 80% 100% }
                                    position = { 30 0 }
                                    elide = right
                                    align = nobaseline
                                    using = fontsize_medium
                                    margin = { 10 0 }
                                    parentanchor = vcenter
                                }
                            }

                            # Character Portrait
                            character_portrait_medium_torso = {
                                parentanchor = top|hcenter
                                position = { 0 25 }

                                blockoverride "show_hat" {}
                            }

                            #Send to Asylum
                            button = {
                                parentanchor = bottom|hcenter
                                position = { 0 -7 }
                                using = default_button_primary_big_action
                                size = { 200 40 }
                                raw_text = "MR_SEND_CHARACTER_TO_ASYLUM_POPUP_BUTTON"
                                using = fontsize_medium

                                datacontext = "[GetScriptedGui('mr_send_character_to_asylum_in_popup_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).AddScope('chosen_character', Scope.GetCharacter.MakeScope ).End)]"
                                tooltip = "MR_SEND_CHARACTER_TO_ASYLUM_POPUP_BUTTON_TT"
                            }
                        }
                    }
                }
            }
        }

        #Close button
		button_icon_round = {
            parentanchor = top|right
            size = { 42 42 }
            position = { -5 13 }

            onclick = "[GetScriptedGui('mr_send_character_to_asylum_window_close_button_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            tooltip = "MR_CLOSE_WINDOW_TT"
            shortcut = "close_window"

            blockoverride "icon" {
                texture = "gfx/interface/buttons/button_icons/close.dds"
            }
            blockoverride "icon_size" {
                size = { 100% 100% }
            }
		}
    }

    type mr_hire_academic_popup = window {
        name = "mr_hire_academic_popup"
        layer = popups
        using = clickthrough_blocker
        filter_mouse = all
        movable = yes
        allow_outside = yes
        parentanchor = center

        size = { 790 555 }
        enabled = "[GetMetaPlayer.GetPlayedOrObservedCountry.IsValid]"
        block "popup_visible" {
            visible = "[And( GetScriptedGui('mr_academics_hire_chemist_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End), And( IsInGame, And( Not( IsPauseMenuShown ), Not( IsGameOverScreenShown ))))]"
        }

        widget = {
            size = { 100% 100% }

            background = {
                texture = "gfx/interface/backgrounds/popup_bg.dds"
                spriteType = Corneredstretched
                spriteborder = { 90 90 }
                texture_density = 2

                modify_texture = {
                    texture = "gfx/interface/backgrounds/default_bg_shading.dds"
                    spriteType = Corneredstretched
                    spriteborder = { 0 0 }
                    blend_mode = overlay
                }
                modify_texture = {
                    using = texture_velvet
                }
            }
        }

		### HEADER
		widget = {
			size = { 100% 82 }

			popup_top_header = {}

			textbox = {
				block "first_line_position" {
					position = { 0 24 }
				}
				size = { 75% 40 }
				block "window_header_name" {
					text = "MR_CHOOSE_ACADEMIC_HEADER"
				}
				elide = right
				fontsize_min = 14
				parentanchor = hcenter
				align = hcenter|nobaseline
				using = header_font
				using = header_font_size
				default_format = "#header"
			}

			block "second_line" {}
		}

		### FRAME
		popup_bg_frame = {}

        ### Actual stuff
        hbox = {
            spacing = 10
            position = { 25 82 }
            maximumsize = { 750 455 }

            widget = {
                block "current_character_datacontext" {
                    datacontext = "[GetPlayer.MakeScope.Var('mendelejew_chemist_var')]"
                }
                visible = "[Scope.IsSet]"

			    size = { 240 445 }

                background = {
                    using = Background_Area
                }

                #Current Character
                widget = {
                    parentanchor = center
                    size = { 220 415 }
                    using = entry_bg_fancy
                    datacontext = "[Scope.GetCharacter]"

                    #General Information
                    widget = {
                        parentanchor = hcenter
                        size = { 220 35 }
                        scissor = yes

                        background = {
                            using = default_header_bg
                            using = frame_small_mask_top
                        }

                        character_role_icon = {
                            parentanchor = left|vcenter
                            position = { 190 -2 }
                            size = { 30 30 }
                        }

                        #Name
                        textbox = {
                            block "character_name" {
                                text = "MR_CHEMIST_NAME_LOC"
                            }
                            size = { 83% 100% }
                            position = { 8 0 }
                            elide = right
                            align = nobaseline
                            using = fontsize_medium
                            margin = { 10 0 }
                            parentanchor = vcenter
                        }
                    }

                    # Character Portrait
                    character_portrait_medium_torso = {
                        parentanchor = top|hcenter
                        position = { 0 25 }

                        blockoverride "show_hat" {}
                    }

                    #Rating of Character
                    widget = {
                        position = { 140 45 }
                        size = { 40 40 }
                        block "character_rating_tooltip" {
                            tooltip = "mendelejew_official_chemist_rating_tt_loc"
                        }

                        icon = {
                            size = { 100% 100% }
                            texture = "gfx/interface/backgrounds/round_button_bg.dds"
                            parentanchor = center
                        }

                        textbox = {
                            block "character_rating_text" {
                                text = "MR_CHEMIST_RATING_LOC"
                            }
                            size = { 100% 100% }
                            position = { 0 0 }
                            elide = right
                            align = center
                            using = fontsize_xxl
                            parentanchor = center
                        }
                    }

                    green_progressbar_horizontal = {
                        name =  "mr_tutorial_highlight_experience_bar"
                        parentanchor = top|hcenter
                        position = { 0 202 }
                        size = { 190 30 }
                        block "occupation_experience_value_bar_visibility" {
                            visible = yes
                        }
                        blockoverride "values" {
                            block "occupation_experience_range" {
                                min = 0
                                max = 300
                            }
                            block "occupation_experience_value" {
                                value = "[Scope.Var('mendelejew_chemist_experience_var').GetValue]"
                            }
                            block "occupation_experience_tooltip" {
                                tooltip = "GUI_mendelejew_chemist_character_experience_tt"
                            }
                        }
                        textbox = {
                            block "occupation_experience_bar_text" {
                                text = "GUI_mendelejew_chemist_character_experience_text_loc"
                            }
                            position = { 0 0 }
                            parentanchor = center
                            autoresize = yes
                            using = fontsize_xl
                        }
                    }

                    # Displays the Traits of the character
                    widget = {
                        size = { 190 42 }
                        parentanchor = top|hcenter
                        position = { 0 241 }

                        overlappingitembox = {
                            minimumsize = { 180 42 }
                            maximumsize = { 180 42 }

                            datamodel = "[Scope.GetCharacter.AccessTraits]"

                            item = {
                                icon = {
                                    size = { 30 42 }
                                    texture = "[CharacterTrait.GetTexture]"
                                    using = tooltip_above

                                    tooltipwidget = {
                                        FancyTooltip_CharacterTrait = {}
                                    }
                                }
                            }
                        }
                    }

                    textbox = {
                        text = "MR_HIRE_ACADEMIC_HOME_COUNTRY"
                        position = { 17 292 }
                        size = { 200 26 }
                        elide = right
                        parentanchor = top|left
                        using = fontsize_xl
                    }

                    textbox = {
                        block "current_academic_loc" {
                            text = "MR_THIS_IS_THE_CURRENT_CHEMIST"
                        }
                        position = { 17 322 }
                        size = { 195 26 }
                        elide = right
                        parentanchor = top|left
                        using = fontsize_xl
                    }

                    #Fire
                    button = {
                        parentanchor = bottom|hcenter
                        position = { 0 -20 }
                        using = default_button_primary_big_action
                        size = { 200 40 }
                        block "fire_character_text" {
                            text = "MR_ACADEMICS_FIRE_THIS_CHEMIST_BUTTON"
                        }
                        using = fontsize_medium

                        block "fire_character_button_datacontext" {
                            datacontext = "[GetScriptedGui('mr_academics_fire_this_chemist_button_sgui')]"
                        }
                        onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                        block "fire_character_tooltip" {
                            tooltip = "MR_ACADEMICS_FIRE_THIS_CHEMIST_BUTTON_TT"
                        }
                    }
                }
            }

            scrollbox = {
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding
                maximumsize = { 745 445 }

                scrollbarpolicy_horizontal = as_needed
                scrollbarpolicy_vertical = always_off

                scrollbar_horizontal = {
                    using = Scrollbar_Horizontal
                }

                blockoverride "scrollbox_content" {
                    hbox = {
                        spacing = 20
                        block "list_datamodel" {
                            datamodel = "[Country.MakeScope.GetList('mr_academics_hire_chemist_variable_list')]"
                        }

                        item = {
                            widget = {
                                size = { 220 415 }
                                using = entry_bg_fancy
                                datacontext = "[Scope.GetCharacter]"

                                #General Information
                                widget = {
                                    parentanchor = hcenter
                                    size = { 220 35 }
                                    scissor = yes

                                    background = {
                                        using = default_header_bg
                                        using = frame_small_mask_top
                                    }

                                    character_role_icon = {
                                        parentanchor = left|vcenter
                                        position = { 190 -2 }
                                        size = { 30 30 }
                                    }

                                    #Name
                                    textbox = {
                                        block "character_name" {
                                            text = "MR_CHEMIST_NAME_LOC"
                                        }
                                        size = { 83% 100% }
                                        position = { 8 0 }
                                        elide = right
                                        align = nobaseline
                                        using = fontsize_medium
                                        margin = { 10 0 }
                                        parentanchor = vcenter
                                    }
                                }

                                # Character Portrait
                                character_portrait_medium_torso = {
                                    parentanchor = top|hcenter
                                    position = { 0 25 }

                                    blockoverride "show_hat" {}
                                }

                                #Rating of Character
                                widget = {
                                    position = { 140 45 }
                                    size = { 40 40 }

                                    block "character_rating_tooltip" {
                                        tooltip = "mendelejew_official_chemist_rating_tt_loc"
                                    }

                                    icon = {
                                        size = { 100% 100% }
                                        texture = "gfx/interface/backgrounds/round_button_bg.dds"
                                        parentanchor = center
                                    }

                                    textbox = {
                                        block "character_rating_text" {
                                            text = "MR_CHEMIST_RATING_LOC"
                                        }
                                        size = { 100% 100% }
                                        position = { 0 0 }
                                        elide = right
                                        align = center
                                        using = fontsize_xxl
                                        parentanchor = center
                                    }
                                }

                                green_progressbar_horizontal = {
                                    name =  "mr_tutorial_highlight_experience_bar"
                                    parentanchor = top|hcenter
                                    position = { 0 202 }
                                    size = { 190 30 }
                                    block "occupation_experience_value_bar_visibility" {
                                        visible = yes
                                    }
                                    blockoverride "values" {
                                        block "occupation_experience_range" {
                                            min = 0
                                            max = 300
                                        }
                                        block "occupation_experience_value" {
                                            value = "[Scope.Var('mendelejew_chemist_experience_var').GetValue]"
                                        }
                                        block "occupation_experience_tooltip" {
                                            tooltip = "GUI_mendelejew_chemist_character_experience_tt"
                                        }
                                    }
                                    textbox = {
                                        block "occupation_experience_bar_text" {
                                            text = "GUI_mendelejew_chemist_character_experience_text_loc"
                                        }
                                        position = { 0 0 }
                                        parentanchor = center
                                        autoresize = yes
                                        using = fontsize_xl
                                    }
                                }

                                # Displays the Traits of the character
                                widget = {
                                    size = { 190 42 }
                                    parentanchor = top|hcenter
                                    position = { 0 241 }

                                    overlappingitembox = {
                                        minimumsize = { 180 42 }
                                        maximumsize = { 180 42 }

                                        datamodel = "[Scope.GetCharacter.AccessTraits]"

                                        item = {
                                            icon = {
                                                size = { 30 42 }
                                                texture = "[CharacterTrait.GetTexture]"
                                                using = tooltip_above

                                                tooltipwidget = {
                                                    FancyTooltip_CharacterTrait = {}
                                                }
                                            }
                                        }
                                    }
                                }

                                textbox = {
                                    text = "MR_HIRE_ACADEMIC_HOME_COUNTRY"
                                    position = { 17 292 }
                                    size = { 200 26 }
                                    elide = right
                                    parentanchor = top|left
                                    using = fontsize_xl
                                }

                                textbox = {
                                    block "hire_character_cost_text" {
                                        text = "MR_HIRE_CHEMIST_COST"
                                        tooltip = "MR_HIRE_CHEMIST_COST_TT"
                                    }
                                    position = { 17 322 }
                                    size = { 200 26 }
                                    elide = right
                                    parentanchor = top|left
                                    using = fontsize_xl
                                    using = tooltip_above
                                }

                                #Invite
                                button = {
                                    parentanchor = bottom|hcenter
                                    position = { 0 -20 }
                                    using = default_button_primary_big_action
                                    size = { 200 40 }
                                    block "hire_character_button_text" {
                                        text = "MR_ACADEMICS_HIRE_THIS_CHARACTER_BUTTON"
                                    }
                                    using = fontsize_medium

                                    block "hire_character_button_datacontext" {
                                        datacontext = "[GetScriptedGui('mr_academics_hire_this_chemist_button_sgui')]"
                                    }
                                    onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).AddScope('chosen_character', Scope.GetCharacter.MakeScope ).End)]"
                                    block "hire_character_button_tooltip" {
                                        tooltip = "MR_ACADEMICS_HIRE_THIS_CHARACTER_BUTTON_TT"
                                    }
                                }
                            }
                        }
                    }
                }
            }

            expand = {}
        }

        #Close button
		button_icon_round = {
            parentanchor = top|right
            size = { 42 42 }
            position = { -5 13 }

            block "close_window_on_click" {
                onclick = "[GetScriptedGui('mr_academics_hire_chemist_close_button_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            }
            tooltip = "MR_CLOSE_WINDOW_TT"
            shortcut = "close_window"

            blockoverride "icon" {
                texture = "gfx/interface/buttons/button_icons/close.dds"
            }
            blockoverride "icon_size" {
                size = { 100% 100% }
            }
		}
    }

    type building_choser_popup = window {
        block "name" {
            name = "mr_improve_forestry_building_choser"
        }
        layer = popups
        using = clickthrough_blocker
        filter_mouse = all
        movable = yes
        allow_outside = yes
        parentanchor = center

        size = { 780 500 }

        enabled = "[GetMetaPlayer.GetPlayedOrObservedCountry.IsValid]"
        block "visible" {
            visible = "[And( GetScriptedGui('mr_improve_forestry_window_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End), And( IsInGame, And( Not( IsPauseMenuShown ), Not( IsGameOverScreenShown ))))]"
        }

        widget = {
            size = { 100% 100% }

            background = {
                texture = "gfx/interface/backgrounds/popup_bg.dds"
                spriteType = Corneredstretched
                spriteborder = { 90 90 }
