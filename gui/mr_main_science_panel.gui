						mr_academic_project_button = {
							text = "mr_science_chemist_fertilizers_button_text"
							datacontext = "[GetScriptedGui('mr_chemist_fertilizer_button')]"
							tooltip = "MR_CHEMIST_FERTILIZER_BUTTON"
						}

						# Improve Explosives
						mr_academic_project_button = {
							text = "mr_science_chemist_explosives_button_text"
							datacontext = "[GetScriptedGui('mr_chemist_explosives_button')]"
							tooltip = "MR_CHEMIST_EXPLOSIVES_BUTTON"
						}

						# Synthetic Oil
						mr_academic_project_button = {
							text = "MR_CHEMIST_SYNTHETIC_OIL_BUTTON"
							datacontext = "[GetScriptedGui('mr_chemist_synthetic_oil_button')]"
							tooltip = "MR_CHEMIST_SYNTHETIC_OIL_BUTTON_TT"
						}

