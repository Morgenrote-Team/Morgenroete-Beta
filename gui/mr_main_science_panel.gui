						visible = "[GetVariableSystem.HasValue('mr_astronomer_ranking', 'moons')]"
					}
					blockoverride "ranking_3_datamodel" {
						datamodel = "[GetGlobalList('mr_moons_ranking_global_list')]"
					}
					blockoverride "ranking_variable_used_3" {
						raw_text = "[Country.MakeScope.GetVariable('verrier_num_discovered_moons_var').GetValue|V0]"
					}
					blockoverride "text_4" {
						raw_text = "ASTRONOMY_RANKING_HEADER"
					}
					blockoverride "ranking_4_visible" {
						visible = "[GetVariableSystem.HasValue('mr_astronomer_ranking', 'astronomical_objects')]"
					}
					blockoverride "ranking_4_datamodel" {
						datamodel = "[GetGlobalList('mr_astronomical_objects_ranking_global_list')]"
					}
					blockoverride "ranking_variable_used_4" {
						raw_text = "[Country.MakeScope.GetVariable('verrier_astronomical_objects').GetValue|V0]"
					}
				}
			}
		}
		blockoverride "academic_data_header_text" {
			text = mr_science_astronomer_data_header
		}
		blockoverride "academic_data_content" {
			mr_academic_data_text = {
				#Total Number of Planets
				text = "NUMBER_PLANETS_VAR"
				tooltip = "NUMBER_PLANETS_VAR_TT"
			}
			mr_academic_data_text = {
				#Total Number of Moons
				text = "NUMBER_MOONS_VAR"
				tooltip = "NUMBER_MOONS_VAR_TT"
			}
			mr_academic_data_text = {
				#Great Comets
				text = "COMETS_VAR"
				tooltip = "COMETS_VAR_TT"
			}
			mr_academic_data_text = {
				#Total Number of Meteorites
				text = "NUMBER_METEORITES_VAR"
				tooltip = "NUMBER_METEORITES_VAR_TT"
			}
			flowcontainer = {
				direction = horizontal
				maximumsize = { 255 310 }
				spacing = 8

				mr_academic_data_text = {
					#Astronomical Objects of Total Astronomical Objects
					text = "TOTAL_ASTRONOMICAL_OBJECTS_VAR"
					tooltip = "TOTAL_ASTRONOMICAL_OBJECTS_VAR_TT"
				}
				mr_academic_data_text = {
					#yearly estimated number of Astronomical Object
					text = "MR_YEARLY_ASTRONOMICAL_OBJECTS"
					tooltip = "MR_YEARLY_ASTRONOMICAL_OBJECTS_TT"
				}
				expand = {}
			}
			mr_academic_data_text = {
				#Lunar Fotos
				text = "MOON_PHOTO_VAR"
				tooltip = "MOON_PHOTO_VAR_TT"
			}
		}
		blockoverride "visit_button" {
			text = "VISIT_OBSERVATORY_BUTTON"
			onclick = "[GetVariableSystem.Set( 'mr_window_tab', 'academy_planetarium' )]"
			tooltip = "VISIT_OBSERVATORY_BUTTON_TT"
		}
		blockoverride "big_box_content" {
			margin = { 25 25 }
			vbox = {
				layoutpolicy_vertical = expanding
				spacing = 7
				margin_right = 10
				minimumsize = { 270 0 }

				mr_academic_project_button = {
					text = "mr_science_general_stop_project"
					datacontext = "[GetScriptedGui('mr_stop_engineering_project_button')]" #TODO
					tooltip = "MR_STOP_ENGINEERING_PROJECT_BUTTON_TT" #TODO
				}

				# Search for Satellites
				mr_academic_project_button = {
					text = "mr_science_astronomer_discover_satellites_button"
					datacontext = "[GetScriptedGui('mr_astronomer_discover_satellites_button')]"
					tooltip = "MR_ASTRONOMER_DISCOVER_SATELLITES_BUTTON_TT"
				}

				# Moon Photos
				mr_academic_project_button = {
					text = "mr_science_astronomer_moon_map_button"
					datacontext = "[GetScriptedGui('mr_astronomer_moon_map_button')]"
					tooltip = "MR_ASTRONOMER_MOON_MAP_BUTTON_TT"
				}

				expand = {}
			}

			hbox = {
				background = {
					using = entry_bg_simple
				}
				layoutpolicy_vertical = expanding
				layoutpolicy_horizontal = expanding

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding

					textbox = {
						maximumsize = { 800 -1 }
						margin = { 20 20 }
						autoresize = yes
						multiline = yes
						text = "mr_science_astronomer_congress_desc"
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding

						#Congress on Asteroids
						mr_academic_project_button = {
							blockoverride "size" {
								size = { 300 50 }
							}
							text = "MR_ASTEROID_CONGRESS_BUTTON"
							datacontext = "[GetScriptedGui('mr_asteroid_congress_button')]"
							tooltip = "MR_ASTEROID_CONGRESS_BUTTON_TT"
						}

						#Carte de Ciel
						mr_academic_project_button = {
							blockoverride "size" {
								size = { 300 50 }
							}
							text = "MR_CARTE_DE_CIEL_CONGRESS_BUTTON"
							datacontext = "[GetScriptedGui('mr_carte_congress_button')]"
							tooltip = "MR_CARTE_DE_CIEL_CONGRESS_BUTTON_TT"
						}

						#Great Debate
						mr_academic_project_button = {
							blockoverride "size" {
								size = { 300 50 }
							}
							text = "MR_GREAT_DEBATE_CONGRESS_BUTTON"
							datacontext = "[GetScriptedGui('mr_great_debate_congress_button')]"
							tooltip = "MR_GREAT_DEBATE_CONGRESS_BUTTON_TT"
						}
					}
				}
			}
		}
	}

	type mr_academic_engineer_tab = hbox {
		block "tab_visibility" {
			visible = no
		}
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding
		margin = { 20 20 }

		vbox = {
			layoutpolicy_vertical = expanding
			spacing = 7
			minimumsize = { 270 0 }

			# Stop engineering project
			mr_academic_project_button = {
				text = "mr_science_general_stop_project"
				datacontext = "[GetScriptedGui('mr_stop_engineering_project_button')]"
				tooltip = "MR_STOP_ENGINEERING_PROJECT_BUTTON_TT"
			}

			block "tab_buttons" {
			}

			expand = {}
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			background = {
				using = entry_bg_simple
			}

			vbox = {
				block "tab_button_context" {}
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				textbox = {
					maximumsize = { 800 -1 }
					margin = { 20 20 }
					autoresize = yes
					multiline = yes
					block "tab_desc" {
						raw_text = "tab_desc"
						default_format = "#r"
					}
				}

				hbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding

					button = {
						using = default_button_primary_big_action
						size = { 300 50 }
						block "tab_button_specialize" {
							raw_text = "tab_button_specialize"
							default_format = "#r"
						}
						onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
						enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
						visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
					}
				}
			}
		}

	}

	type mr_science_view = vbox {
		size = { 100% 100% }
		spacing = 20
		margin = { 20 10 }

		block "view_visibility" {
			visible = no
		}

		block "view_content" {

		}
	}

	type mr_academic_full = hbox {
		size = { 100% 410 }
		spacing = 20
		margin = { 20 20 }
		layoutpolicy_horizontal = expanding
		block "academic" {
			#datacontext = "[Country.Var('gaudi_engineer_var')]"
		}

		background = {
			using = entry_bg
		}

		widget = {
			size = { 300 450 }

			mr_academic_character = {}

			default_header_clean_faded = {
				position = { 14 306 }
				size = { 250 40 }
				blockoverride "text" {}
				textbox = {
					block "character_name" {
						text = "ARCHAEOLOGY_HEADER_TEXT"
					}
					parentanchor = center
					position = { 5 -2 }
					autoresize = yes
					max_width = 190
					elide = right
					using = fontsize_large
				}
			}

			widget = {
				parentanchor = left
				size = { 65 65 }
				position = { 10 10 }
				icon = {
					size = { 100% 100% }
					block "role_icon" {
						# texture = ""
					}
					block "role_tooltip" {}
				}
			}

			textbox = {
				block "role_name" {
					text = "ARCHAEOLOGY_HEADER_TEXT"
				}
				position = { 82 23 }
				parentanchor = left
				autoresize = yes
				max_width = 196
				elide = right
				block "fontsize_role" {
					using = fontsize_mega
				}
			}

			block "experience_bar" {
				visible = yes
				green_progressbar_horizontal = {
					parentanchor = bottom|left
					position = { 15 -60 }
					size = { 250 35 }
					block "experience_bar_visibility" {
						visible = yes
					}
					blockoverride "values" {
						min = 0
						max = 300
						block "values" {
							value = "[FixedPointToFloat(GetPlayer.MakeScope.Var('dubois_academy_progress').GetValue)]"
						}
						block "experience_tooltip" {}
					}
					textbox = {
						block "experience_bar_text" {
							text = "MR_EXPERIENCE"
						}
						position = { 0 0 }
						parentanchor = center
						autoresize = yes
						using = fontsize_xl
					}
				}
			}


			widget = { #Displays the Traits of the character
				size = { 250 40 }
				parentanchor = bottom|left
				position = { 15 -10 }

				overlappingitembox = {
					minimumsize = { 250 42 }
					maximumsize = { 250 42 }

					block "character_traits"
					{
						datamodel = "[Scope.GetCharacter.AccessTraits]"
					}

					item = {
						icon = {
							size = { 30 42 }
							texture = "[CharacterTrait.GetTexture]"
							using = tooltip_above

							tooltipwidget = {
								FancyTooltip_CharacterTrait = {}
							}
						}
					}
				}
			}

			widget = { #This Icon displays the achievements of the Scientist
				#The Correct Localizations are chosen in the GUI_customizable_localization.txt and
				#used in the mr_GUI_l_english.yml file to display the correct Achievements.
				size = { 35 35 }
				parentanchor = bottom|left
				position = { 10 -107 }
				block "achievements_icon_visibility" {
					visible = yes
				}

				icon = {
					size = { 100% 100% }
					texture = "gfx/interface/backgrounds/round_button_bg.dds"
					block "enabled" {}
				}
				icon = {
					size = { 100% 100% }
					texture = "gfx/interface/icons/GUI_icons/GUI_scientist_achievements_button.dds"
					block "enabled" {}
					block "scientist_achievement_tooltip" {}
				}
			}
		}

		widget = {
			size = { 290 450 }

			#Center Box
			widget = {
				size = { 290 380 }
				background = {
					using = simple_frame
				}

				widget = {
					block "academic_ranking_visible" {
						visible = no
					}
					size = { 30 30 }
					parentanchor = top|right
					position = { 5 -5 }

					icon = {
						size = { 100% 100% }
						texture = "gfx/interface/backgrounds/round_button_bg.dds"
						block "enabled" {}
					}
					icon = {
						size = { 100% 100% }
						texture = "gfx/interface/buttons/button_icons/list.dds"
						block "enabled" {}
						block "academic_ranking" {}
					}
				}

				flowcontainer = {
					direction = vertical
					ignoreinvisible = yes
					spacing = 8
					margin = { 2 0 }

					default_header_clean_faded = {
						blockoverride "size" {
							size = { 286 40 }
						}
						blockoverride "text" {
							block "academic_data_header_text" {
								raw_text = "academic_data_header_text"
								default_format = "#r"
							}
						}
					}

					flowcontainer = {
						margin = { 23 8 }
						spacing = 8
						direction = vertical
						block "academic_data_content" {}
					}
				}
			}

			button = {
				parentanchor = bottom
				using = default_button_primary_big_action
				size = { 290 50 }
				block "visit_button" {
					raw_text = "visit_button"
					default_format = "#r"
				}
				using = fontsize_large
			}
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			block "big_box_background" {
				background = {
					using = simple_frame
				}
			}
			block "big_box_content" {
			}
		}
	}

	type mr_academic_character = widget {
		size = { 250 300 }

		# Character Portrait
		mr_character_portrait_base = {
			position = { 30 45 }
			block "character_visible" {
				visible = "[Scope.IsSet]"
			}
		}
		mr_no_character = {
			position = { 30 65 }
			block "no_character_visible" {
				visible = "[Not(Scope.IsSet)]"
			}
		}
	}

	type mr_academic_project_button = button {
		using = default_button_primary_big_action
		block "size" {
			size = { 250 45 }
		}
		onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
		enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
		visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
	}

	type mr_academic_data_text = textbox {
		parentanchor = top|left
		maximumsize = { 255 310 }
		autoresize = yes
		multiline = yes
		using = fontsize_xl
	}

}