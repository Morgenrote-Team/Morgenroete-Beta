    type mr_academic_paleontologist = mr_shared_occupation {
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('dubois_paleontologist_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/dubois_paleontologist_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_dubois_paleontologist_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "PALEONTOLOGY_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('academics_has_paleontologist_gui_type')]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = MR_PALEONTOLOGIST_ACHIEVEMENTS_TT
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('dubois_paleontologist_experience_var').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_dubois_paleontologist_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_dubois_paleontologist_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_paleontology_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_paleontologist_ranking', 'dinosaur_skeletons')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_paleontologist_ranking', 'dinosaur_skeletons') )]"
                        text = "MR_DINOSAUR_SKELETONS"
                        tooltip = "MR_RANKING_BY_DINOSAUR_SKELETONS"

                        onclick = "[GetVariableSystem.Set('mr_paleontologist_ranking', 'dinosaur_skeletons')]"
                    }
                    blockoverride "button_2_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_paleontologist_ranking', 'fossils') )]"
                        text = "MR_FOSSILS"
                        tooltip = "MR_RANKING_BY_FOSSILS"

                        onclick = "[GetVariableSystem.Set('mr_paleontologist_ranking', 'fossils')]"
                    }
                    blockoverride "button_3_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_paleontologist_ranking', 'dinosaur_bones') )]"
                        text = "MR_DINOSAUR_BONES"
                        tooltip = "MR_RANKING_BY_DINOSAUR_BONES"

                        onclick = "[GetVariableSystem.Set('mr_paleontologist_ranking', 'dinosaur_bones')]"
                    }
                    blockoverride "button_4_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_paleontologist_ranking', 'paleontologist_ranking') )]"
                        text = "MR_PALEONTOLOGIST_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_PALEONTOLOGIST"

                        onclick = "[GetVariableSystem.Set('mr_paleontologist_ranking', 'paleontologist_ranking')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "PALEONTOLOGIST_DINOSAUR_SKELETON_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_paleontologist_ranking', 'dinosaur_skeletons')]"
                    }
