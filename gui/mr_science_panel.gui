    type mr_academic_promote = mr_shared_basic_box {
        name = "mr_tutorial_highlight_academic_promote"
        blockoverride "general_header_text" {
            text = mr_academic_promote_header
        }
        blockoverride "content" {
            spacing = 20

            vbox = {
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding
                spacing = 30
                margin = { 15 0 }

                vbox = {
                    layoutpolicy_horizontal = expanding
                    margin = { 20 0 }
                    margin_bottom = 20
                    spacing = 20
