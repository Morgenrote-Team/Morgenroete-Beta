    type mr_academic_astronomer = mr_shared_occupation {
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('verrier_astronomer_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/verrier_astronomer_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_verrier_astronomer_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "ASTRONOMY_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('academics_has_astronomer_gui_type')]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = "MR_ASTRONOMER_ACHIEVEMENTS_TT"
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('verrier_astronomer_experience_var').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_verrier_astronomer_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_verrier_astronomer_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_astronomy_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_astronomer_ranking', 'astronomical_prestige')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_astronomer_ranking', 'astronomical_prestige') )]"
                        text = "MR_ASTRONOMICAL_PRESTIGE"
                        tooltip = "MR_RANKING_BY_ASTRONOMICAL_PRESTIGE"

                        onclick = "[GetVariableSystem.Set('mr_astronomer_ranking', 'astronomical_prestige')]"
                    }
                    blockoverride "button_2_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_astronomer_ranking', 'planets') )]"
                        text = "MR_PLANETS"
                        tooltip = "MR_RANKING_BY_PLANETS"

                        onclick = "[GetVariableSystem.Set('mr_astronomer_ranking', 'planets')]"
                    }
                    blockoverride "button_3_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_astronomer_ranking', 'moons') )]"
                        text = "MR_MOONS"
                        tooltip = "MR_RANKING_BY_MOONS"

                        onclick = "[GetVariableSystem.Set('mr_astronomer_ranking', 'moons')]"
                    }
                    blockoverride "button_4_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_astronomer_ranking', 'astronomical_objects') )]"
                        text = "MR_ASTRONOMICAL_OBJECTS"
                        tooltip = "MR_RANKING_BY_ASTRONOMICAL_OBJECTS"

                        onclick = "[GetVariableSystem.Set('mr_astronomer_ranking', 'astronomical_objects')]"
                    }
                    blockoverride "button_5_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_astronomer_ranking', 'astronomer_ranking') )]"
                        text = "MR_ASTRONOMER_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_ASTRONOMER"

                        onclick = "[GetVariableSystem.Set('mr_astronomer_ranking', 'astronomer_ranking')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "ASTRONOMY_ASTRONOMICAL_PRESTIGE_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_astronomer_ranking', 'astronomical_prestige')]"
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_astronomical_prestige_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
                        raw_text = "[Country.MakeScope.GetVariable('verrier_astronomical_prestige_var').GetValue|V0]"
                    }
                    blockoverride "text_2" {
                        raw_text = "ASTRONOMY_PLANETS_RANKING_HEADER"
                    }
                    blockoverride "ranking_2_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_astronomer_ranking', 'planets')]"
                    }
                    blockoverride "ranking_2_datamodel" {
                        datamodel = "[GetGlobalList('mr_planets_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_2" {
                        raw_text = "[Country.MakeScope.GetVariable('verrier_num_discovered_planets_var').GetValue|V0]"
                    }
                    blockoverride "text_3" {
                        raw_text = "ASTRONOMY_MOONS_RANKING_HEADER"
                    }
                    blockoverride "ranking_3_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_astronomer_ranking', 'moons')]"
                    }
                    blockoverride "ranking_3_datamodel" {
                        datamodel = "[GetGlobalList('mr_moons_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_3" {
                        raw_text = "[Country.MakeScope.GetVariable('verrier_num_discovered_moons_var').GetValue|V0]"
                    }
                    blockoverride "text_4" {
                        raw_text = "ASTRONOMY_RANKING_HEADER"
                    }
                    blockoverride "ranking_4_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_astronomer_ranking', 'astronomical_objects')]"
                    }
                    blockoverride "ranking_4_datamodel" {
                        datamodel = "[GetGlobalList('mr_astronomical_objects_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_4" {
                        raw_text = "[Country.MakeScope.GetVariable('verrier_astronomical_objects').GetValue|V0]"
                    }
                    blockoverride "text_5" {
                        raw_text = "ASTRONOMER_ASTRONOMER_RANKING_HEADER"
                    }
                    blockoverride "ranking_5_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_astronomer_ranking', 'astronomer_ranking')]"
                    }
                    blockoverride "ranking_5_datamodel" {
                        datamodel = "[GetGlobalList('mr_astronomer_ranking_global_list')]"
                    }
                    blockoverride "ranking_5_datacontext"{
                        datacontext = "[Scope.GetCharacter]"
                    }
                    blockoverride "ranking_5_text_column_2"{
                        raw_text = "#tooltip:[GetRawTextTooltipTag('verrier_official_astronomer_rating_tt_loc')] [Character.GetCustom('verrier_astronomer_rating_new_astronomer_icon_type')] #! [Character.GetFullName]"
                    }
                    blockoverride "ranking_variable_used_5" {
                        raw_text = "[Character.MakeScope.GetVariable('verrier_astronomer_experience_var').GetValue|V0]"
                    }
                }
            }
        }
        blockoverride "occupation_data_header_text" {
            text = mr_science_astronomer_data_header
        }
        blockoverride "occupation_data_content" {
            mr_shared_data_text = {
                #Total Number of Planets
                text = "NUMBER_PLANETS_VAR"
                tooltip = "NUMBER_PLANETS_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xl
                }
            }
            mr_shared_data_text = {
                #Total Number of Moons
                text = "NUMBER_MOONS_VAR"
                tooltip = "NUMBER_MOONS_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xl
                }
            }
            mr_shared_data_text = {
                #Great Comets
                text = "COMETS_VAR"
                tooltip = "COMETS_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xl
                }
            }
            mr_shared_data_text = {
                #Total Number of Meteorites
                text = "NUMBER_METEORITES_VAR"
                tooltip = "NUMBER_METEORITES_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xl
                }
            }
            flowcontainer = {
                direction = horizontal
                minimumsize = { @[panel_text_width - 30] -1 }
                spacing = 8

                mr_shared_data_text = {
                    #Astronomical Objects of Total Astronomical Objects
                    text = "TOTAL_ASTRONOMICAL_OBJECTS_VAR"
                    tooltip = "TOTAL_ASTRONOMICAL_OBJECTS_VAR_TT"
                    blockoverride "font_size" {
                        using = fontsize_xl
                    }
                }
                mr_shared_data_text = {
                    #yearly estimated number of Astronomical Object
                    text = "MR_YEARLY_ASTRONOMICAL_OBJECTS"
                    tooltip = "MR_YEARLY_ASTRONOMICAL_OBJECTS_TT"
                    blockoverride "font_size" {
                        using = fontsize_xl
                    }
                }

                expand = {}
            }
            mr_shared_data_text = {
                #Lunar Fotos
                text = "MOON_PHOTO_VAR"
                tooltip = "MOON_PHOTO_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xl
                }
            }
            mr_shared_data_text = {
                #Lunar Fotos
                text = "MR_ASTRONOMY_MERIDIAN_LOC"
                tooltip = "MR_ASTRONOMY_MERIDIAN_TT"
                blockoverride "font_size" {
                    using = fontsize_large
                }
            }
        }
        blockoverride "extra_button" {
            # Start Automation
            mr_shared_project_button = {
                datacontext = "[GetScriptedGui('mr_astronomy_automation_gui')]"
                blockoverride "size" {
                    size = { 100% 100% }
                }
                blockoverride "button_content" {
                    text = "mr_science_general_project_automation"
                    tooltip = "MR_AUTOMATE_ASTRONOMER_TT"
                    using = fontsize_large
                }
            }
            # Stop Automation
            mr_shared_project_button = {
                datacontext = "[GetScriptedGui('mr_stop_astronomy_automation_gui')]"
                blockoverride "size" {
                    size = { 100% 100% }
                }
                blockoverride "button_content" {
                    text = "mr_science_general_project_automation_stop"
                    tooltip = "MR_STOP_AUTOMATE_ASTRONOMER_TT"
                    using = fontsize_large
                }
                blockoverride "button_highlight_visible" {
                    visible = yes
                }
            }
        }
        blockoverride "visit_button" {
            text = "VISIT_OBSERVATORY_BUTTON"
            onclick = "[GetVariableSystem.Set('com_open_window', 'mr_academic_planetarium')]"
            tooltip = "VISIT_OBSERVATORY_BUTTON_TT"
        }
        blockoverride "big_box_content" {
            mr_shared_interactions_simple = {
                visible = "[Not(GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"
                blockoverride "content" {

                    # Searching the Skies
