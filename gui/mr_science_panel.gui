							datacontext = "[GetScriptedGui('mr_examine_cave_button')]"
							tooltip = "MR_EXAMINE_CAVE_BUTTON_BUTTON_TT"
						}

						# Fossil Identification
						mr_academic_project_button = {
							text = "MR_FOSSIL_IDENTIFICATION_BUTTON"
							datacontext = "[GetScriptedGui('mr_fossil_identification_active_sgui')]"
							tooltip = "MR_FOSSIL_IDENTIFICATION_BUTTON_TT"
						}

						expand = {}
					}
				}

				hbox = {
					margin_top = 20
					margin_left = 20
					mr_academic_project_button = {
						blockoverride "size" {
							size = { 310 50 }
						}
						text = "mr_science_general_stop_project"
						datacontext = "[GetScriptedGui('mr_stop_engineering_project_button')]" #TODO
						tooltip = "MR_STOP_ENGINEERING_PROJECT_BUTTON_TT" #TODO
					}
				}
			}

			hbox = {
				background = {
					using = entry_bg_simple
				}
				layoutpolicy_vertical = expanding
				layoutpolicy_horizontal = expanding

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding

					vbox = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
						textbox = {
							maximumsize = { 800 -1 }
							margin = { 20 20 }
							autoresize = yes
							multiline = yes
							text = "mr_science_anthropologist_congress_desc"
						}
						expand = {}
					}

					hbox = {
						maximumsize = { -1 60 }
						margin = { 20 20 }
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding

						# Origin Congress
						mr_academic_project_button = {
							blockoverride "size" {
								size = { 300 50 }
							}
							text = "MR_ORIGIN_CONGRESS_BUTTON"
							datacontext = "[GetScriptedGui('mr_origin_congress_button')]"
							tooltip = "MR_ORIGIN_CONGRESS_BUTTON_TT"
						}
					}
				}
			}
		}
	}

	type mr_science_view = vbox {
