	type mr_academic_full = hbox {
		size = { 100% 410 }
		spacing = 20
		margin = { 20 20 }
		layoutpolicy_horizontal = expanding
		block "academic" {
			#datacontext = "[Country.Var('gaudi_engineer_var')]"
		}

		background = {
			using = entry_bg
		}

		widget = {
			size = { 300 450 }

			mr_academic_character = {}

			default_header_clean_faded = {
				position = { 14 306 }
				size = { 250 40 }
				blockoverride "text" {}
				textbox = {
					block "character_name" {
						text = "ARCHAEOLOGY_HEADER_TEXT"
					}
					parentanchor = center
					position = { 5 -2 }
					autoresize = yes
					max_width = 190
					elide = right
					using = fontsize_large
				}
			}

			widget = {
				parentanchor = left
				size = { 55 55 }
				position = { -30 -30 }
				icon = {
					size = { 100% 100% }
					block "role_icon" {
						# texture = ""
					}
					block "role_tooltip" {}
				}
			}

			textbox = {
				block "role_name" {
					raw_text = "role_name"
					default_format = "#r"
				}
				position = { -10 23 }
				parentanchor = left
				autoresize = yes
				maximumsize = { 300 -1 }
				minimumsize = { 300 -1 }
				align = center
				elide = right
				block "fontsize_role" {
					using = fontsize_mega
				}
			}

			block "experience_bar" {
				visible = yes
				green_progressbar_horizontal = {
					parentanchor = bottom|left
					position = { 15 -60 }
					size = { 250 35 }
					block "experience_bar_visibility" {
						visible = yes
					}
					blockoverride "values" {
						min = 0
						max = 300
						block "values" {
							value = "[FixedPointToFloat(Country.MakeScope.Var('dubois_academy_progress').GetValue)]"
						}
						block "experience_tooltip" {}
					}
					textbox = {
						block "experience_bar_text" {
							text = "MR_EXPERIENCE"
						}
						position = { 0 0 }
						parentanchor = center
						autoresize = yes
						using = fontsize_xl
					}
				}
			}

			# Displays the Traits of the character
			widget = {
				size = { 250 40 }
				parentanchor = bottom|left
				position = { 15 -10 }

				overlappingitembox = {
					minimumsize = { 250 42 }
					maximumsize = { 250 42 }

					block "character_traits"
					{
						datamodel = "[Scope.GetCharacter.AccessTraits]"
					}

					item = {
						icon = {
							size = { 30 42 }
							texture = "[CharacterTrait.GetTexture]"
							using = tooltip_above

							tooltipwidget = {
								FancyTooltip_CharacterTrait = {}
							}
						}
					}
				}
			}

			# This Icon displays the achievements of the Scientist
			# The Correct Localizations are chosen in the GUI_customizable_localization.txt and
			# used in the mr_GUI_l_english.yml file to display the correct Achievements.
			widget = {
				size = { 35 35 }
				parentanchor = bottom|left
				position = { 10 -107 }
				block "achievements_icon_visibility" {
					visible = yes
				}

				icon = {
					size = { 100% 100% }
					texture = "gfx/interface/backgrounds/round_button_bg.dds"
					block "enabled" {}
				}
				icon = {
					size = { 100% 100% }
					texture = "gfx/interface/icons/GUI_icons/GUI_scientist_achievements_button.dds"
					block "enabled" {}
					block "scientist_achievement_tooltip" {}
				}
			}
		}

		widget = {
			size = { 290 450 }

			#Center Box
			widget = {
				size = { 290 380 }
				background = {
					using = simple_frame
				}

				widget = {
					block "academic_ranking_visible" {
						visible = no
					}
					size = { 30 30 }
					parentanchor = top|right
					position = { 5 -5 }

					icon = {
						size = { 100% 100% }
						texture = "gfx/interface/backgrounds/round_button_bg.dds"
						block "enabled" {}
					}
					icon = {
						size = { 100% 100% }
						texture = "gfx/interface/buttons/button_icons/list.dds"
						block "enabled" {}
						block "academic_ranking" {}
					}
				}

				flowcontainer = {
					direction = vertical
					ignoreinvisible = yes
					spacing = 8
					margin = { 2 0 }

					default_header_clean_faded = {
						blockoverride "size" {
							size = { 286 40 }
						}
						blockoverride "text" {
							block "academic_data_header_text" {
								raw_text = "academic_data_header_text"
								default_format = "#r"
							}
						}
					}

					flowcontainer = {
						margin = { 23 8 }
						spacing = 8
						direction = vertical
						block "academic_data_content" {}
					}
				}
			}

			button = {
				parentanchor = bottom
				using = default_button_primary_big_action
				size = { 290 50 }
				block "visit_button" {
					raw_text = "visit_button"
					default_format = "#r"
				}
				using = fontsize_large
			}
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			block "big_box_content" {}
		}
	}

	type mr_academic_character = widget {
		size = { 250 300 }

		# Character Portrait
		mr_character_portrait_base = {
			blockoverride "character" {
				datacontext = "[Scope.GetCharacter]"
			}
			position = { 30 45 }
			block "character_visible" {
				visible = "[Scope.IsSet]"
			}
		}
		mr_no_character = {
			position = { 30 65 }
			block "no_character_visible" {
				visible = "[Not(Scope.IsSet)]"
			}
		}
	}

	type mr_academic_project_button = button {
		using = default_button_primary_big_action
		block "size" {
			size = { 250 45 }
		}
		onclick = "[ScriptedGui.Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
		enabled = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).End)]"
		visible = "[ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
	}

	type mr_academic_round_project_button = button_icon_round {
		block "size" {
			size = { 50 50 }
		}
		blockoverride "icon_size" {
			size = { 65% 65% }
		}
		onclick = "[ScriptedGui.Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
		enabled = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).End)]"
		visible = "[ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
	}

	type mr_academic_data_text = textbox {
		parentanchor = top|left
		maximumsize = { 255 310 }
		autoresize = yes
		multiline = yes
		block "font_size" {
			using = fontsize_xl
		}
	}

}