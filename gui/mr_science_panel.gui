                                texture = "gfx/interface/icons/GUI_icons/GUI_lepsius_examine_cave_button.dds"
                                visible = "[GetScriptedGui('mr_recall_anthropologist_button_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
