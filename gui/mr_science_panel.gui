@panel_button_width = 290
@panel_text_width = 250

types mr_main_science_panel_types {

    type mr_science_panel = fullscreen_block_window {
        name = "mr_science_panel"
        datacontext = "[GetMetaPlayer.GetPlayedOrObservedCountry]"

        background = {
            using = illu_alpha
            fittype = center
            texture = "gfx/interface/illustrations/tech_tree/illustration_tech_society.dds"
            using = default_content_fade
        }

        visible = "[GetVariableSystem.HasValue('com_open_window', 'mr_sidebar_button_science_sgui')]"

        blockoverride "animation_state_block" {
            state = {
                name = _show
                # Close open panel before showing this one
                on_start = "[InformationPanelBar.ClosePanel]"
                on_start = "[MapListPanelManager.CloseCurrentPanel]"
                # Fullscreen panels hide topbar
                on_finish = "[GetVariableSystem.Set('com_fullscreen', 'com_fullscreen')]"
                start_sound = {
                    soundeffect = "event:/SFX/UI/SideBar/markets"
                }
                start_sound = {
                    soundeffect = "snapshot:/Dynamic/mute_world_80"
                }
                start_sound = {
                    soundeffect = "snapshot:/Dynamic/mute_vfx_war_100"
                }
            }

            state = {
                name = _hide
                on_start = "[GetVariableSystem.Clear('com_fullscreen')]"
                on_finish = "[GetVariableSystem.Clear('mr_science_tab')]"
                start_sound = {
                    soundeffect = "event:/SFX/UI/SideBar/markets_stop"
                }
            }

            # Open Active Engineer Tab
            widget = {
                visible = "[And(
                				GetVariableSystem.HasValue('mr_science_tab', 'mathematics'),
                				GetScriptedGui('gaudi_civil_engineer_experience_bar_visibility_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)
                			)]"
                state = {
                    name = _show
                    on_finish = "[GetVariableSystem.Set('mr_science_engineer_tab', 'civil')]"
                }
            }
            widget = {
                visible = "[And(
                				GetVariableSystem.HasValue('mr_science_tab', 'mathematics'),
                				GetScriptedGui('gaudi_mechanical_engineer_experience_bar_visibility_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)
                			)]"
                state = {
                    name = _show
                    on_finish = "[GetVariableSystem.Set('mr_science_engineer_tab', 'mechanical')]"
                }
            }
            widget = {
                visible = "[And(
                				GetVariableSystem.HasValue('mr_science_tab', 'mathematics'),
                				GetScriptedGui('gaudi_military_engineer_experience_bar_visibility_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)
                			)]"
                state = {
                    name = _show
                    on_finish = "[GetVariableSystem.Set('mr_science_engineer_tab', 'military')]"
                }
            }
            widget = {
                visible = "[And(
                				GetVariableSystem.HasValue('mr_science_tab', 'mathematics'),
                				GetScriptedGui('gaudi_electrical_engineer_experience_bar_visibility_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)
                			)]"
                state = {
                    name = _show
                    on_finish = "[GetVariableSystem.Set('mr_science_engineer_tab', 'electrical')]"
                }
            }
            widget = {
                visible = "[And(
                				GetVariableSystem.HasValue('mr_science_tab', 'mathematics'),
                				GetScriptedGui('gaudi_aeronautical_engineer_experience_bar_visibility_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)
                			)]"
                state = {
                    name = _show
                    on_finish = "[GetVariableSystem.Set('mr_science_engineer_tab', 'aeronautical')]"
                }
            }
        }

        blockoverride "window_header_name" {
            text = ACADEMY_OF_SCIENCE_VIEW_NAME
            default_format = "#bold"
        }

        blockoverride "back_button_fullscreen" {
            back_button_large = {
                position = { 11 15 }
                parentanchor = top|left
                onclick = "[GetVariableSystem.Clear('com_open_window')]"
                onclick = "[GetVariableSystem.Clear('com_alert_action')]"
                onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
                input_action = "back"
            }
        }

        close_button_large = {
            name = "tutorial_highlight_close_button"
            parentanchor = top|right
            onclick = "[GetVariableSystem.Clear('com_open_window')]"
            onclick = "[GetVariableSystem.Clear('com_alert_action')]"
            onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
            shortcut = "close_window"
            position = { -56 115 }
        }

        blockoverride "close_button_position" {
            visible = no
        }

        blockoverride "fixed_top" {
            hbox = {
                layoutpolicy_horizontal = expanding
                margin_right = 20

                mr_tab_buttons_fullscreen = {
                    name = "mr_tutorial_highlight_scicence_tab_bar"
                    # General
                    blockoverride "first_button_name" {
                        name = "mr_tutorial_highlight_science_overview_tab_button"
                    }
                    blockoverride "first_button" {
                        text = "mr_science_tab_general"
                    }
                    blockoverride "first_button_click" {
                        onclick = "[GetVariableSystem.Set('mr_science_tab', 'general')]"
                    }
                    blockoverride "first_button_visibility" {
                        visible = "[Or(
									GetVariableSystem.HasValue('mr_science_tab', 'general'),
									Not(GetVariableSystem.Exists('mr_science_tab'))
								)]"
                    }
                    blockoverride "first_button_visibility_checked" {
                        visible = "[And(
									Not(GetVariableSystem.HasValue('mr_science_tab', 'general')),
									GetVariableSystem.Exists('mr_science_tab')
								)]"
                    }
                    blockoverride "first_button_selected" {
                        text = "mr_science_tab_general"
                    }

                    # Mathematical-Technical
                    blockoverride "second_button_name" {
                        name = "mr_mathematics_tab_button"
                    }
                    blockoverride "second_button" {
                        text = "mr_science_tab_mathematics"
                    }
                    blockoverride "second_button_background" {
                        background = {
                            margin = { 0 -2 }
                            using = fade_bottom_entry_fancy_header_colored
                            using = Color_Orange
                            alpha = 0.5
                        }
                    }
                    blockoverride "second_button_click" {
                        onclick = "[GetVariableSystem.Set('mr_science_tab', 'mathematics')]"
                    }
                    blockoverride "second_button_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_science_tab', 'mathematics')]"
                    }
                    blockoverride "second_button_visibility_checked" {
                        visible = "[Not(GetVariableSystem.HasValue('mr_science_tab', 'mathematics'))]"
                    }
                    blockoverride "second_button_selected" {
                        text = "mr_science_tab_mathematics"
                    }
                    blockoverride "second_button_background_selected" {
                        background = {
                            using = fade_bottom_entry_fancy_header_colored
                            using = Color_Orange
                            alpha = 0.5
                        }
                    }

                    # Natural History
                    blockoverride "third_button_name" {
                        name = "mr_tutorial_highlight_natural_history_tab_button"
                    }
                    blockoverride "third_button" {
                        text = "mr_science_tab_natural_history"
                    }
                    blockoverride "third_button_background" {
                        background = {
                            margin = { 0 -2 }
                            using = fade_bottom_entry_fancy_header_colored
                            using = Color_Green
                            alpha = 0.5
                        }
                    }
                    blockoverride "third_button_click" {
                        onclick = "[GetVariableSystem.Set('mr_science_tab', 'natural_history')]"
                    }
                    blockoverride "third_button_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_science_tab', 'natural_history')]"
                    }
                    blockoverride "third_button_visibility_checked" {
                        visible = "[Not(GetVariableSystem.HasValue('mr_science_tab', 'natural_history'))]"
                    }
                    blockoverride "third_button_selected" {
                        text = "mr_science_tab_natural_history"
                    }
                    blockoverride "third_button_background_selected" {
                        background = {
                            using = fade_bottom_entry_fancy_header_colored
                            using = Color_Green
                            alpha = 0.5
                        }
                    }

                    # Humanities-Anthropological
                    blockoverride "fourth_button_name" {
                        name = "mr_natural_humanities_tab_button"
                    }
                    blockoverride "fourth_button" {
                        text = "mr_science_tab_humanities"
                    }
                    blockoverride "fourth_button_background" {
                        background = {
                            margin = { 0 -2 }
                            using = fade_bottom_entry_fancy_header_colored
                            using = Color_Blue
                            alpha = 0.5
                        }
                    }
                    blockoverride "fourth_button_click" {
                        onclick = "[GetVariableSystem.Set('mr_science_tab', 'humanities')]"
                    }
                    blockoverride "fourth_button_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_science_tab', 'humanities')]"
                    }
                    blockoverride "fourth_button_visibility_checked" {
                        visible = "[Not(GetVariableSystem.HasValue('mr_science_tab', 'humanities'))]"
                    }
                    blockoverride "fourth_button_selected" {
                        text = "mr_science_tab_humanities"
                    }
                    blockoverride "fourth_button_background_selected" {
                        background = {
                            using = fade_bottom_entry_fancy_header_colored
                            using = Color_Blue
                            alpha = 0.5
                        }
                    }
                }

                widget = {
                    name = "mr_tutorial_highlight_view_switch_button"
                    size = { 35 35 }

                    button_icon_round = {
                        size = { 35 35 }
                        onclick = "[GetScriptedGui('mr_setting_academic_compact_sgui').Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
                        visible = "[GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                        tooltip = mr_science_setting_compact
                        blockoverride "icon" {
                            texture = "gfx/interface/buttons/button_icons/grid.dds"
                        }
                        blockoverride "icon_size" {
                            size = { 80% 80% }
                        }
                    }
                    button_icon_round = {
                        onclick = "[GetScriptedGui('mr_setting_academic_compact_sgui').Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
                        visible = "[Not(GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"
                        tooltip = mr_science_setting_compact
                        size = { 35 35 }
                        blockoverride "icon" {
                            texture = "gfx/interface/buttons/button_icons/list.dds"
                        }
                        blockoverride "icon_size" {
                            size = { 80% 80% }
                        }
                    }
                }
            }
        }

        blockoverride "scrollarea_content" {
            vbox = {
                layoutpolicy_vertical = expanding
                layoutpolicy_horizontal = expanding

                mr_shared_tab_fullscreen = {
                    blockoverride "view_visibility" {
                        visible = "[Or(GetVariableSystem.HasValue('mr_science_tab', 'general'), Not(GetVariableSystem.Exists('mr_science_tab')))]"
                    }
                    blockoverride "view_content" {
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_academic_promote = {}
                            expand = {}
                            mr_academic_scientific_focus = {}
                        }
                        mr_academic_expeditions = {}
                    }
                }

                mr_shared_tab_fullscreen = {
                    blockoverride "view_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_science_tab', 'mathematics')]"
                    }
                    blockoverride "view_content" {
                        mr_academic_engineer = {}
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_academic_chemist = {}
                            expand = {}
                            mr_academic_astronomer = {}
                        }
                    }
                }
                mr_shared_tab_fullscreen = {
                    blockoverride "view_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_science_tab', 'natural_history')]"
                    }
                    blockoverride "view_content" {
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_academic_geologist = {}
                            expand = {}
                            mr_academic_paleontologist = {}
                        }
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_academic_naturalist = {}
                            expand = {}
                            mr_academic_biologist = {}
                        }
                    }
                }
                mr_shared_tab_fullscreen = {
                    blockoverride "view_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_science_tab', 'humanities')]"
                    }
                    blockoverride "view_content" {
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_academic_physician = {}
                            expand = {}
                            mr_academic_archaeologist = {}
                        }
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_academic_anthropologist = {}
                            expand = {}
                            mr_academic_manaflow = {}
                        }
                    }
                }
            }
        }
    }

    type mr_academic_engineer = mr_shared_occupation {
        layoutpolicy_horizontal = expanding
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('tesla_engineer_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/gaudi_engineer_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_tesla_engineer_desc]"
        }
        blockoverride "occupation_role_name" {
            raw_text = "[Country.GetCustom('gaudi_engineer_role_name')]"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('academics_has_engineer_gui_type')]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = "MR_ENGINEER_ACHIEVEMENTS_TT"
        }
        blockoverride "experience_bar" {
            # Civil Engineer
            green_progressbar_horizontal = {
                parentanchor = bottom|left
                position = { 15 -51 }
                size = { 250 35 }
                datacontext = "[GetScriptedGui('gaudi_civil_engineer_experience_bar_visibility_sgui')]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                blockoverride "values" {
                    min = 0
                    max = 300
                    value = "[Country.MakeScope.Var('tesla_engineer_var').GetVariable('tesla_civil_engineer_experience_var').GetValue]"
                    tooltip = "[Country.GetCustom('GUI_gaudi_civil_engineer_experience_type')]"
                }
                textbox = {
                    text = "[Country.GetCustom('GUI_gaudi_civil_engineer_experience_text_type')]"
                    position = { 0 0 }
                    parentanchor = center
                    autoresize = yes
                    using = fontsize_xl
                }
            }
            # Mechanical Engineer
            green_progressbar_horizontal = {
                parentanchor = bottom|left
                position = { 15 -51 }
                size = { 250 35 }
                datacontext = "[GetScriptedGui('gaudi_mechanical_engineer_experience_bar_visibility_sgui')]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                blockoverride "values" {
                    min = 0
                    max = 300
                    value = "[Country.MakeScope.Var('tesla_engineer_var').GetVariable('tesla_mechanical_engineer_experience_var').GetValue]"
                    tooltip = "[Country.GetCustom('GUI_gaudi_mechanical_engineer_experience_type')]"
                }
                textbox = {
                    text = "[Country.GetCustom('GUI_gaudi_mechanical_engineer_experience_text_type')]"
                    position = { 0 0 }
                    parentanchor = center
                    autoresize = yes
                    using = fontsize_xl
                }
            }
            # Military Engineer
            green_progressbar_horizontal = {
                parentanchor = bottom|left
                position = { 15 -51 }
                size = { 250 35 }
                datacontext = "[GetScriptedGui('gaudi_military_engineer_experience_bar_visibility_sgui')]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                blockoverride "values" {
                    min = 0
                    max = 300
                    value = "[Country.MakeScope.Var('tesla_engineer_var').GetVariable('tesla_military_engineer_experience_var').GetValue]"
                    tooltip = "[Country.GetCustom('GUI_gaudi_military_engineer_experience_type')]"
                }
                textbox = {
                    text = "[Country.GetCustom('GUI_gaudi_military_engineer_experience_text_type')]"
                    position = { 0 0 }
                    parentanchor = center
                    autoresize = yes
                    using = fontsize_xl
                }
            }
            # Electrical Engineer
            green_progressbar_horizontal = {
                parentanchor = bottom|left
                position = { 15 -51 }
                size = { 250 35 }
                datacontext = "[GetScriptedGui('gaudi_electrical_engineer_experience_bar_visibility_sgui')]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                blockoverride "values" {
                    min = 0
                    max = 300
                    value = "[Country.MakeScope.Var('tesla_engineer_var').GetVariable('tesla_electrical_engineer_experience_var').GetValue]"
                    tooltip = "[Country.GetCustom('GUI_gaudi_electrical_engineer_experience_type')]"
                }
                textbox = {
                    text = "[Country.GetCustom('GUI_gaudi_electrical_engineer_experience_text_type')]"
                    position = { 0 0 }
                    parentanchor = center
                    autoresize = yes
                    using = fontsize_xl
                }
            }
            # Aeronautical Engineer
            green_progressbar_horizontal = {
                parentanchor = bottom|left
                position = { 15 -51 }
                size = { 250 35 }
                datacontext = "[GetScriptedGui('gaudi_aeronautical_engineer_experience_bar_visibility_sgui')]"
                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                blockoverride "values" {
                    min = 0
                    max = 300
                    value = "[Country.MakeScope.Var('tesla_engineer_var').GetVariable('tesla_aeronautical_engineer_experience_var').GetValue]"
                    tooltip = "[Country.GetCustom('GUI_gaudi_aeronautical_engineer_experience_type')]"
                }
                textbox = {
                    text = "[Country.GetCustom('GUI_gaudi_aeronautical_engineer_experience_text_type')]"
                    position = { 0 0 }
                    parentanchor = center
                    autoresize = yes
                    using = fontsize_xl
                }
            }
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_engineer_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_science_engineer_ranking', 'engineer_ranking')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = no
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_science_engineer_ranking', 'engineer_ranking') )]"
                        text = "MR_ENGINEER_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_ENGINEER"

                        onclick = "[GetVariableSystem.Set('mr_science_engineer_ranking', 'engineer_ranking')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "ENGINEER_ENGINEER_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_science_engineer_ranking', 'engineer_ranking')]"
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_engineer_ranking_global_list')]"
                    }
                    blockoverride "ranking_1_datacontext"{
                        datacontext = "[Scope.GetCharacter]"
                    }
                    blockoverride "ranking_1_text_column_2"{
                        raw_text = "#tooltip:[Character.GetTooltipTag],tesla_engineer_rating_tt_loc @mr_rating_fantastic! #! [Character.GetFullName]"
                    }
                    blockoverride "ranking_variable_used_1" {
                        raw_text = "[Character.GetCustom('tesla_experience_current_specialization_type')]"
                    }
                }
            }
        }
        blockoverride "occupation_data_header_text" {
            text = mr_science_engineer_data_header
        }
        blockoverride "occupation_data_content" {
            # Geomagnetic Research Data
            mr_shared_data_text = {
                text = "GEOMAGNETIC_RESEARCH_VAR"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
        }
        blockoverride "extra_button" {
            text = "mr_science_general_stop_project"
            datacontext = "[GetScriptedGui('mr_stop_engineering_project_button_sgui')]"
            onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
            tooltip = "MR_STOP_ENGINEERING_PROJECT_BUTTON_TT"
        }
        blockoverride "extra_extra_button" {
            # Start Automation
            mr_shared_project_button = {
                datacontext = "[GetScriptedGui('mr_engineering_automation_gui')]"
                blockoverride "size" {
                    size = { 100% 100% }
                }
                blockoverride "button_content" {
                    text = "mr_science_general_project_automation"
                    tooltip = "MR_AUTOMATE_ENGINEER_TT"
                    using = fontsize_large
                }
            }
            # Stop Automation
            mr_shared_project_button = {
                datacontext = "[GetScriptedGui('mr_stop_engineering_automation_gui')]"
                blockoverride "size" {
                    size = { 100% 100% }
                }
                blockoverride "button_content" {
                    text = "mr_science_general_project_automation_stop"
                    tooltip = "MR_STOP_AUTOMATE_ENGINEER_TT"
                    using = fontsize_large
                }
                blockoverride "button_highlight_visible" {
                    visible = yes
                }
            }
        }
        blockoverride "visit_button" {
            text = "VISIT_SCIENTIFIC_SOCIETY_BUTTON"
            datacontext = "[GetScriptedGui('mr_visit_scientific_society_sgui')]"
            onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
            tooltip = "VISIT_SCIENTIFIC_SOCIETY_BUTTON_TT"
        }
        blockoverride "big_box_content" {
            margin_left = 10
            margin_right = 10
            vbox = {
                margin_top = 20
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding

                tab_buttons = {
                    margin_bottom = -4
                    blockoverride "first_button" {
                        mr_academic_engineer_tab_icon = {
                            datacontext = "[GetScriptedGui('gaudi_civil_engineer_experience_bar_visibility_sgui')]"
                            blockoverride "icon" {
                                texture = "gfx/interface/icons/concept_icons/gaudi_engineer_civil_concept_icon.dds"
                            }
                        }
                        text = "tesla_civil_engineer"
                    }
                    blockoverride "first_button_tooltip" {
                        tooltip = "concept_tesla_civil_engineer_desc"
                    }
                    blockoverride "first_button_click" {
                        onclick = "[GetVariableSystem.Set('mr_science_engineer_tab', 'civil')]"
                    }
                    blockoverride "first_button_visibility" {
                        visible = "[Or(GetVariableSystem.HasValue('mr_science_engineer_tab', 'civil'), Not(GetVariableSystem.Exists('mr_science_engineer_tab')))]"
                    }
                    blockoverride "first_button_visibility_checked" {
                        visible = "[And(Not(GetVariableSystem.HasValue('mr_science_engineer_tab', 'civil')), GetVariableSystem.Exists('mr_science_engineer_tab'))]"
                    }
                    blockoverride "first_button_selected" {
                        mr_academic_engineer_tab_icon = {
                            datacontext = "[GetScriptedGui('gaudi_civil_engineer_experience_bar_visibility_sgui')]"
                            blockoverride "icon" {
                                texture = "gfx/interface/icons/concept_icons/gaudi_engineer_civil_concept_icon.dds"
                            }
                        }
                        text = "tesla_civil_engineer"
                    }

                    blockoverride "second_button" {
                        mr_academic_engineer_tab_icon = {
                            datacontext = "[GetScriptedGui('gaudi_mechanical_engineer_experience_bar_visibility_sgui')]"
                            blockoverride "icon" {
                                texture = "gfx/interface/icons/concept_icons/gaudi_engineer_mechanical_concept_icon.dds"
                            }
                        }
                        text = "tesla_mechanical_engineer"
                    }
                    blockoverride "second_button_tooltip" {
                        tooltip = "concept_tesla_mechanical_engineer_desc"
                    }
                    blockoverride "second_button_click" {
                        onclick = "[GetVariableSystem.Set('mr_science_engineer_tab', 'mechanical')]"
                    }
                    blockoverride "second_button_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_science_engineer_tab', 'mechanical')]"
                    }
                    blockoverride "second_button_visibility_checked" {
                        visible = "[Not(GetVariableSystem.HasValue('mr_science_engineer_tab', 'mechanical'))]"
                    }
                    blockoverride "second_button_selected" {
                        mr_academic_engineer_tab_icon = {
                            datacontext = "[GetScriptedGui('gaudi_mechanical_engineer_experience_bar_visibility_sgui')]"
                            blockoverride "icon" {
                                texture = "gfx/interface/icons/concept_icons/gaudi_engineer_mechanical_concept_icon.dds"
                            }
                        }
                        text = "tesla_mechanical_engineer"
                    }

                    blockoverride "third_button" {
                        mr_academic_engineer_tab_icon = {
                            datacontext = "[GetScriptedGui('gaudi_military_engineer_experience_bar_visibility_sgui')]"
                            blockoverride "icon" {
                                texture = "gfx/interface/icons/concept_icons/gaudi_engineer_military_concept_icon.dds"
