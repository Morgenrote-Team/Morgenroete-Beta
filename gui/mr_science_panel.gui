                                size = { 45 45 }
                                texture = "gfx/interface/buttons/round_button_small_wood.dds"
                                visible = "[GetScriptedGui('mr_fossil_identification_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"

                                tooltip = "MR_FOSSIL_IDENTIFICATION_ACTIVE_TT"
