                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_CRETACEOUS_SCENERY_BUTTON_STOP_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_dubois_paleontologist_prehistoric_scenery_cretaceous_stop_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }
                        }

                        # Jurassic Scenery
                        widget = {
                            size = { 50 50 }
                            visible = "[GetScriptedGui('mr_prehistoric_scenery_jurassic_button_visible_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"

                            #Button when it is not active
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_prehistoric_scenery_jurassic_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_JURASSIC_SCENERY_BUTTON_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_dubois_paleontologist_prehistoric_scenery_jurassic_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }

                            #highlight circle to indicate that it is currently active
                            icon = {
                                parentanchor = center
                                size = { 100% 100% }
                                using = highlighted_circle_selection_small
                                visible = "[GetScriptedGui('mr_prehistoric_scenery_jurassic_stop_button_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                            # Stop Jurassic Scenery
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_prehistoric_scenery_jurassic_stop_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_JURASSIC_SCENERY_BUTTON_STOP_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_dubois_paleontologist_prehistoric_scenery_jurassic_stop_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }
                        }

                        # Triassic Scenery
                        widget = {
                            size = { 50 50 }
                            visible = "[GetScriptedGui('mr_prehistoric_scenery_triassic_button_visible_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"

                            #Button when it is not active
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_prehistoric_scenery_triassic_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_TRIASSIC_SCENERY_BUTTON_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_dubois_paleontologist_prehistoric_scenery_triassic_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }

                            #highlight circle to indicate that it is currently active
                            icon = {
                                parentanchor = center
                                size = { 100% 100% }
                                using = highlighted_circle_selection_small
                                visible = "[GetScriptedGui('mr_prehistoric_scenery_triassic_stop_button_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                            # Stop Jurassic Scenery
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_prehistoric_scenery_triassic_stop_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_TRIASSIC_SCENERY_BUTTON_STOP_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_dubois_paleontologist_prehistoric_scenery_triassic_stop_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }
                        }
                    }

                    expand = {}

                    # First Paleontological Team
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_paleontology_first_team_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_PALEONTOLOGY_FIRST_TEAM_BUTTON"
                            tooltip = "MR_PALEONTOLOGY_FIRST_TEAM_BUTTON_TT"
                        }
                    }

                    # Second Paleontological Team
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_paleontology_second_team_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_PALEONTOLOGY_SECOND_TEAM_BUTTON"
                            tooltip = "MR_PALEONTOLOGY_SECOND_TEAM_BUTTON_TT"
                        }
                    }

                    # Transform Fossils into a Bone
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_transform_fossils_to_bones_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_TRANSFORM_FOSSILS_TO_BONES_BUTTON"
                            tooltip = "MR_TRANSFORM_FOSSILS_TO_BONES_BUTTON_TT"
                        }
                    }

                    # Paleontological Collection
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_paleontological_collection_button_sgui')]"
                        blockoverride "button_content" {
                            text = "mr_science_paleontologist_create_collection_button"
                            tooltip = "MR_PALEONTOLOGICAL_COLECTION_BUTTON_TT"
                        }
                    }

                    # Extinction Congress
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_extinction_congress_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_EXTINCTION_CONGRESS_BUTTON"
                            tooltip = "MR_EXTINCTION_CONGRESS_BUTTON_TT"
                        }
                    }
                }
                blockoverride "stop_context" {
                    datacontext = "[GetScriptedGui('mr_stop_paleontologist_project_button_sgui')]"
                }
            }
        }
    }

    type mr_academic_naturalist = mr_shared_occupation {
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('dubois_naturalist_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/dubois_naturalist_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_dubois_naturalist_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "NATURALIST_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('academics_has_naturalist_gui_type')]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = MR_NATURALIST_ACHIEVEMENTS_TT
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('dubois_naturalist_experience_var').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_dubois_naturalist_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_dubois_naturalist_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_naturalist_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_naturalist_ranking', 'specimens')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_naturalist_ranking', 'specimens') )]"
                        text = "MR_SPECIMENS"
                        tooltip = "MR_RANKING_BY_SPECIMENS"

                        onclick = "[GetVariableSystem.Set('mr_naturalist_ranking', 'specimens')]"
                    }
                    blockoverride "button_2_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_naturalist_ranking', 'zoo_animals') )]"
                        text = "MR_ZOO_ANIMALS"
                        tooltip = "MR_RANKING_BY_ZOO_ANIMALS"

                        onclick = "[GetVariableSystem.Set('mr_naturalist_ranking', 'zoo_animals')]"
                    }
                    blockoverride "button_3_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_naturalist_ranking', 'animal_documentations') )]"
                        text = "MR_ANIMAL_DOCUMENTATIONS"
                        tooltip = "MR_RANKING_BY_ANIMAL_DOCUMENTATIONS"

                        onclick = "[GetVariableSystem.Set('mr_naturalist_ranking', 'animal_documentations')]"
                    }
                    blockoverride "button_4_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_naturalist_ranking', 'naturalist_ranking') )]"
                        text = "MR_NATURALIST_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_NATURALIST"

                        onclick = "[GetVariableSystem.Set('mr_naturalist_ranking', 'naturalist_ranking')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "NATURALIST_SPECIMEN_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_naturalist_ranking', 'specimens')]"
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_specimen_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
                        raw_text = "[Country.MakeScope.GetVariable('dubois_specimen').GetValue|V*0]"
                    }
                    blockoverride "text_2" {
                        raw_text = "NATURALIST_ZOO_ANIMALS_RANKING_HEADER"
                    }
                    blockoverride "ranking_2_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_naturalist_ranking', 'zoo_animals')]"
                    }
                    blockoverride "ranking_2_datamodel" {
                        datamodel = "[GetGlobalList('mr_zoo_animal_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_2" {
                        raw_text = "[Country.MakeScope.GetVariable('dubois_zoo_animal_total').GetValue|V0]"
                    }
                    blockoverride "text_3" {
                        raw_text = "NATURALIST_ANIMAL_DOCUMENTATIONS_RANKING_HEADER"
                    }
                    blockoverride "ranking_3_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_naturalist_ranking', 'animal_documentations')]"
                    }
                    blockoverride "ranking_3_datamodel" {
                        datamodel = "[GetGlobalList('mr_animal_documentation_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_3" {
                        raw_text = "[Country.MakeScope.GetVariable('dubois_country_num_animal_documentation_var').GetValue|V0]"
                    }
                    blockoverride "text_4" {
                        raw_text = "NATURALIST_NATURALIST_RANKING_HEADER"
                    }
                    blockoverride "ranking_4_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_naturalist_ranking', 'naturalist_ranking')]"
                    }
                    blockoverride "ranking_4_datamodel" {
                        datamodel = "[GetGlobalList('mr_naturalist_ranking_global_list')]"
                    }
                    blockoverride "ranking_4_datacontext"{
                        datacontext = "[Scope.GetCharacter]"
                    }
                    blockoverride "ranking_4_text_column_2"{
                        raw_text = "#tooltip:[GetRawTextTooltipTag('dubois_official_naturalist_rating_tt_loc')] [Character.GetCustom('dubois_naturalist_rating_new_naturalist_icon_type')] #! [Character.GetFullName]"
                    }
                    blockoverride "ranking_variable_used_4" {
                        raw_text = "[Character.MakeScope.GetVariable('dubois_naturalist_experience_var').GetValue|V0]"
                    }
                }
            }
        }
        blockoverride "occupation_data_header_text" {
            text = mr_science_naturalist_data_header
        }
        blockoverride "occupation_data_content" {
            mr_shared_data_text = {
                ## "dubois_zoo_animal" Texticon followed by the variable "dubois_zoo_animal_total"
                # followed by Text "Zoo Animals"
                text = "ZOO_ANIMALS_VAR"
                tooltip = "ZOO_ANIMALS_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
            mr_shared_data_text = {
                ## "dubois_specimen" Texticon followed by the variable "dubois_specimen"
                # followed by Text "Specimen"
                text = "SPECIMEN_VAR"
                tooltip = "SPECIMEN_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
            mr_shared_data_text = {
                #Amount of documentaries
                text = "WILDLIFE_DOCUMENTARIES_VAR"
                tooltip = "WILDLIFE_DOCUMENTARIES_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
            mr_shared_data_text = {
                #Amount of Medicinal Plants
                text = "MR_MEDICINAL_PLANTS_VAR"
                tooltip = "MR_MEDICINAL_PLANTS_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
        }
        blockoverride "visit_button" {
            text = "VISIT_ZOO_BUTTON"
            datacontext = "[GetScriptedGui('mr_visit_zoo_sgui')]"
            onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
            tooltip = "VISIT_ZOO_BUTTON_TT"
        }
        blockoverride "big_box_content" {
            mr_shared_interactions = {
                visible = "[Not(GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"

                blockoverride "tabs" {
                    tab_buttons = {
                        maximumsize = { @[ panel_button_width + 20 ] 0 }
                        margin_bottom = -4
                        blockoverride "first_button" {
                            text = mr_science_naturalist_tab_fauna
                        }
                        blockoverride "first_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_science_naturalist_tab', 'fauna')]"
                        }
                        blockoverride "first_button_visibility" {
                            visible = "[Or(GetVariableSystem.HasValue('mr_science_naturalist_tab', 'fauna'), Not(GetVariableSystem.Exists('mr_science_naturalist_tab')))]"
                        }
                        blockoverride "first_button_visibility_checked" {
                            visible = "[And(Not(GetVariableSystem.HasValue('mr_science_naturalist_tab', 'fauna')), GetVariableSystem.Exists('mr_science_naturalist_tab'))]"
                        }
                        blockoverride "first_button_selected" {
                            text = mr_science_naturalist_tab_fauna
                        }

                        blockoverride "second_button" {
                            text = mr_science_naturalist_tab_flora
                        }
                        blockoverride "second_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_science_naturalist_tab', 'flora')]"
                        }
                        blockoverride "second_button_visibility" {
                            visible = "[GetVariableSystem.HasValue('mr_science_naturalist_tab', 'flora')]"
                        }
                        blockoverride "second_button_visibility_checked" {
                            visible = "[Not(GetVariableSystem.HasValue('mr_science_naturalist_tab', 'flora'))]"
                        }
                        blockoverride "second_button_selected" {
                            text = mr_science_naturalist_tab_flora
                        }
                    }
                }
                blockoverride "tab_content" {
                    vbox = {
                        visible = "[Or(GetVariableSystem.HasValue('mr_science_naturalist_tab', 'fauna'), Not(GetVariableSystem.Exists('mr_science_naturalist_tab')))]"
                        layoutpolicy_vertical = expanding
                        spacing = 7
                        minimumsize = { @panel_button_width 0 }

                        # Specimen Collection
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_naturalist_specimen_collection_button_sgui')]"
                            blockoverride "button_content" {
                                text = "MR_NATURALIST_SPECIMEN_COLLECTION_BUTTON_SGUI"
                                tooltip = "MR_NATURALIST_SPECIMEN_COLLECTION_BUTTON_SGUI_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = "[GetScriptedGui('mr_naturalist_specimen_collection_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_ito_specimen_collection_button.dds"
                            }
