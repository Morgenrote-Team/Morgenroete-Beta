    type mr_academic_anthropologist = mr_shared_occupation {
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('lepsius_anthropologist_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/lepsius_anthropologist_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_lepsius_anthropologist_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "ANTHRAPOLOGY_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('academics_has_anthropologist_gui_type')]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = MR_ANTHROPOLOGIST_ACHIEVEMENTS_TT
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('lepsius_anthropologist_experience_var').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_lepsius_anthropologist_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_lepsius_anthropologist_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_anthropology_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_anthropology_ranking', 'anthropological_rating')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_anthropology_ranking', 'anthropological_rating') )]"
                        text = "MR_ANTHROPOLOGICAL_RATING"
                        tooltip = "MR_RANKING_BY_ANTHROPOLOGICAL_RATING"

                        onclick = "[GetVariableSystem.Set('mr_anthropology_ranking', 'anthropological_rating')]"
                    }
                    blockoverride "button_2_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_anthropology_ranking', 'total_human_fossils') )]"
                        text = "MR_TOTAL_HUMAN_FOSSILS"
                        tooltip = "MR_RANKING_BY_TOTAL_HUMAN_FOSSILS"

                        onclick = "[GetVariableSystem.Set('mr_anthropology_ranking', 'total_human_fossils')]"
                    }
                    blockoverride "button_3_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_anthropology_ranking', 'anthropologist_ranking') )]"
                        text = "MR_ANTHROPOLOGIST_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_ANTHROPOLOGIST"

                        onclick = "[GetVariableSystem.Set('mr_anthropology_ranking', 'anthropologist_ranking')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "ANTHROPOLOGIST_ANTHROPOLOGICAL_RATING_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_anthropology_ranking', 'anthropological_rating')]"
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_anthropological_rating_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
                        raw_text = "[Country.MakeScope.GetVariable('lepsius_anthropological_rating').GetValue|V0]"
                    }
                    blockoverride "text_2" {
                        raw_text = "ANTHROPOLOGIST_TOTAL_HUMAN_FOSSILS_RANKING_HEADER"
                    }
                    blockoverride "ranking_2_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_anthropology_ranking', 'total_human_fossils')]"
                    }
                    blockoverride "ranking_2_datamodel" {
                        datamodel = "[GetGlobalList('mr_total_human_fossils_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_2" {
                        raw_text = "[Country.MakeScope.GetVariable('lepsius_total_human_fossil').GetValue|V0]"
                    }
                    blockoverride "text_3" {
                        raw_text = "ANTHROPOLOGIST_ANTHROPOLOGIST_RANKING_HEADER"
                    }
                    blockoverride "ranking_3_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_anthropology_ranking', 'anthropologist_ranking')]"
                    }
                    blockoverride "ranking_3_datamodel" {
                        datamodel = "[GetGlobalList('mr_anthropologist_ranking_global_list')]"
                    }
                    blockoverride "ranking_3_datacontext"{
                        datacontext = "[Scope.GetCharacter]"
                    }
                    blockoverride "ranking_3_text_column_2"{
                        raw_text = "[Character.GetFullName]"
                    }
                    blockoverride "ranking_variable_used_3" {
                        raw_text = "[Character.MakeScope.GetVariable('lepsius_anthropologist_experience_var').GetValue|V0]"
                    }
                }
            }
        }
        blockoverride "occupation_data_header_text" {
            text = mr_science_anthropologist_data_header
        }
        blockoverride "occupation_data_content" {
            flowcontainer = {
                direction = horizontal
                ignoreinvisible = yes
                spacing = 40

                flowcontainer = {
                    #Left Column
                    direction = vertical
                    ignoreinvisible = yes
                    spacing = 8


                    # Known Human Fossils
                    mr_shared_data_text = {
                        text = "TOTAL_HUMAN_FOSSILS_VAR"
                        tooltip = "TOTAL_HUMAN_FOSSILS_VAR_TT"
                        blockoverride "font_size" {
                            using = fontsize_xxl
                        }
                    }
                    # Cro-Magnon
                    mr_shared_data_text = {
                        text = "CROMAGNON_VAR"
                        tooltip = "CROMAGNON_VAR_TT"
                        blockoverride "font_size" {
                            using = fontsize_xxl
                        }
                    }
                    # Homo Heidelbergensis
                    mr_shared_data_text = {
                        text = "HEIDELBERGENSIS_VAR"
                        tooltip = "HEIDELBERGENSIS_VAR_TT"
                        blockoverride "font_size" {
                            using = fontsize_xxl
                        }
                    }
                    # Paranthropus
                    mr_shared_data_text = {
                        text = "PARANTHROPUS_VAR"
                        tooltip = "PARANTHROPUS_VAR_TT"
                        blockoverride "font_size" {
                            using = fontsize_xxl
                        }
                    }
                }
                flowcontainer = {
                    #Right column
                    direction = vertical
                    ignoreinvisible = yes
                    spacing = 8

                    # Unknown Human Fossils
                    mr_shared_data_text = {
                        text = "UNKNOWN_HUMAN_FOSSILS_VAR"
                        tooltip = "UNKNOWN_HUMAN_FOSSILS_VAR_TT"
                        blockoverride "font_size" {
                            using = fontsize_xxl
                        }
                    }
                    # Neanderthaler
                    mr_shared_data_text = {
                        text = "NEANDERTHALER_VAR"
                        tooltip = "NEANDERTHALER_VAR_TT"
                        blockoverride "font_size" {
                            using = fontsize_xxl
                        }
                    }
                    # Homo Erectus
                    mr_shared_data_text = {
                        text = "ERECTUS_VAR"
                        tooltip = "ERECTUS_VAR_TT"
                        blockoverride "font_size" {
                            using = fontsize_xxl
                        }
                    }
                    # Australopithecus
                    mr_shared_data_text = {
                        text = "AUSTRALOPITHECUS_VAR"
                        tooltip = "AUSTRALOPITHECUS_VAR_TT"
                        blockoverride "font_size" {
                            using = fontsize_xxl
                        }
                    }
                }
            }
        }
        blockoverride "visit_button" {
            text = "VISIT_ANTHROPOLOGICAL_COLLECTION_BUTTON"
            datacontext = "[GetScriptedGui('mr_visit_anthropological_collection_sgui')]"
            onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
            tooltip = "VISIT_ANTHROPOLOGICAL_COLLECTION_BUTTON_TT"
        }
        blockoverride "big_box_content" {
            mr_shared_interactions_simple = {
                visible = "[Not(GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"

                blockoverride "content" {
