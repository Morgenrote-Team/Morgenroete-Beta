                            datacontext = "[GetScriptedGui('mr_extend_zoo_famous_button_sgui')]"
                            blockoverride "button_content" {
                                text = "MR_EXTEND_ZOO_FAMOUS_BUTTON"
                                tooltip = "MR_EXTEND_ZOO_FAMOUS_BUTTON_TT"
                            }
