		blockoverride "center_box_content" {
			margin = { 20 0 }
			margin_bottom = 23
			spacing = 20
			minimumsize = { 400 -1 }
			maximumsize = { 400 -1 }
			background = {
				using = simple_frame
			}

			default_header_clean_faded = {
				maximumsize = { 400 -1 }
				blockoverride "text" {
					text = "PROGRESS_TO_NEXT_ACADEMIC"
				}
				blockoverride "text_size" {
					using = fontsize_mega
				}
				blockoverride "size" {
					size = { 400 50 }
				}
			}

			vbox = {
				layoutpolicy_vertical = expanding

				expand = {}

				textbox = {
					maximumsize = { 400 -1 }
					minimumsize = { 400 -1 }
					text = "CURRENT_ACADEMIC_SUPPORT"
					autoresize = yes
					multiline = yes
					using = fontsize_xl
					align = center
				}

				expand = {}

				green_progressbar_horizontal = {
					size = { 400 35 }
					blockoverride "values" {
						min = 0
						max = 360
