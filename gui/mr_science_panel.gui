            }
            mr_shared_interactions_simple = {
                visible = "[GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"

                blockoverride "content" {
                    margin_bottom = 20
                    hbox = {
                        spacing = 4

                        # Chemical Researcg
                        widget = {
                            size = { 50 50 }

                            #Button when it is not active
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_chemist_chemical_research_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_CHEMIST_CHEMICAL_RESEARCH_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_chemist_chemical_research_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }

                            # Three Icons for when it is active (normal color plus highlight circle)
                            #highlight circle to indicate that it is currently active
                            icon = {
                                parentanchor = center
                                size = { 100% 100% }
                                using = highlighted_circle_selection_small
                                visible = "[GetScriptedGui('mr_chemist_chemical_research_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                            #Button background
                            icon = {
                                parentanchor = center
                                size = { 45 45 }
                                texture = "gfx/interface/buttons/round_button_small_wood.dds"
                                visible = "[GetScriptedGui('mr_chemist_chemical_research_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"

                                tooltip = "MR_CHEMIST_CHEMICAL_RESEARCH_ACTIVE_TT"
                            }
                            #Button Icon
                            icon = {
                                parentanchor = center
                                size = { 34 34 }
                                texture = "gfx/interface/icons/GUI_icons/GUI_chemist_chemical_research_button.dds"
                                visible = "[GetScriptedGui('mr_chemist_chemical_research_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                        }

                        # Theorize Element
                        widget = {
                            size = { 50 50 }

                            #Button when it is not active
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_chemist_theory_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_CHEMIST_THEORY_BUTTON"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_chemist_theorizing_button.dds"
                                }
                                blockoverride "icon_size" {
