	type mr_academic_engineer_tab = hbox {
		block "tab_visibility" {
			visible = no
		}
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding
		margin = { 20 20 }

		vbox = {
			layoutpolicy_vertical = expanding
			spacing = 7
			minimumsize = { 270 0 }

			# Stop engineering project
			mr_academic_project_button = {
				text = "mr_science_general_stop_project"
				datacontext = "[GetScriptedGui('mr_stop_engineering_project_button')]"
				tooltip = "MR_STOP_ENGINEERING_PROJECT_BUTTON_TT"
			}

			block "tab_buttons" {
			}

			expand = {}
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			background = {
				using = entry_bg_simple
			}

			vbox = {
				block "tab_button_context" {}
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				textbox = {
					maximumsize = { 800 -1 }
					margin = { 20 20 }
					autoresize = yes
					multiline = yes
					block "tab_desc" {
						raw_text = "tab_desc"
						default_format = "#r"
					}
				}

				hbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding

					mr_academic_project_button = {
						blockoverride "size" {
							size = { 300 50 }
						}
						block "tab_button_specialize" {
							raw_text = "tab_button_specialize"
							default_format = "#r"
						}
						onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
						enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
						visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
					}
				}
			}
		}

	}

	type mr_academic_chemist = mr_academic_full {
		blockoverride "academic" {
			datacontext = "[Country.MakeScope.Var('mendelejew_chemist_var')]"
		}
		blockoverride "role_icon" {
			texture = "gfx/interface/icons/character_role_icons/mendelejew_chemist_role.dds"
		}
		blockoverride "role_tooltip" {
			tooltip = "[concept_mendelejew_chemist_desc]"
		}
		blockoverride "role_name" {
			text = "CHEMISTRY_HEADER_TEXT"
		}
		blockoverride "character_name" {
			text = "[Country.GetCustom('academics_has_chemist_gui_type')]"
		}
		blockoverride "scientist_achievement_tooltip" {
			tooltip = "MR_CHEMIST_ACHIEVEMENTS_TT"
		}
		blockoverride "values" {
			value = "[Scope.Var('mendelejew_chemist_experience').GetValue]"
		}
		blockoverride "experience_tooltip" {
			tooltip = "[Country.GetCustom('GUI_mendelejew_chemist_experience_type')]"
		}
		blockoverride "experience_bar_text" {
			text = "[Country.GetCustom('GUI_mendelejew_chemist_experience_text_type')]"
		}
		blockoverride "academic_ranking_visible" {
			visible = yes
		}
		blockoverride "academic_ranking" {
			tooltipwidget = {
				MR_TooltipRankingType = {
					blockoverride "ranking_on_finish" {
						on_finish = "[GetScriptedGui('mr_chemistry_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
						on_finish = "[GetVariableSystem.Set('mr_chemistry_ranking', 'chemical_score')]"
					}
					blockoverride "buttons_visible" {
						visible = yes
					}
					blockoverride "button_1_content" {
						enabled = "[Not( GetVariableSystem.HasValue('mr_chemistry_ranking', 'chemical_score') )]"
						text = "MR_CHEMICAL_SCORE"
						tooltip = "MR_RANKING_BY_CHEMICAL_SCORE"

						onclick = "[GetVariableSystem.Set('mr_chemistry_ranking', 'chemical_score')]"
					}
					blockoverride "button_2_content" {
						enabled = "[Not( GetVariableSystem.HasValue('mr_chemistry_ranking', 'theorized_elements') )]"
						text = "MR_THEORIZED_ELEMENTS"
						tooltip = "MR_RANKING_BY_THEORIZED_ELEMENTS"

						onclick = "[GetVariableSystem.Set('mr_chemistry_ranking', 'theorized_elements')]"
					}
					blockoverride "button_3_content" {
						enabled = "[Not( GetVariableSystem.HasValue('mr_chemistry_ranking', 'discovered_elements') )]"
						text = "MR_DISCOVERED_ELEMENTS"
						tooltip = "MR_RANKING_BY_DISCOVERED_ELEMENTS"

						onclick = "[GetVariableSystem.Set('mr_chemistry_ranking', 'discovered_elements')]"
					}
					blockoverride "button_4_content" {
						enabled = "[Not( GetVariableSystem.HasValue('mr_chemistry_ranking', 'isolated_elements') )]"
						text = "MR_ISOLATED_ELEMENTS"
						tooltip = "MR_RANKING_BY_ISOLATED_ELEMENTS"

						onclick = "[GetVariableSystem.Set('mr_chemistry_ranking', 'isolated_elements')]"
					}
					blockoverride "text_1" {
						raw_text = "CHEMIST_RANKING_HEADER"
					}
					blockoverride "ranking_1_visible" {
						visible = "[GetVariableSystem.HasValue('mr_chemistry_ranking', 'chemical_score')]"
					}
					blockoverride "ranking_1_datamodel" {
						datamodel = "[GetGlobalList('mr_chemical_ranking_global_list')]"
					}
					blockoverride "ranking_variable_used_1" {
						raw_text = "[Country.MakeScope.GetVariable('mendelejew_chemical_score_country_var').GetValue|V0]"
					}
					blockoverride "text_2" {
						raw_text = "ASTRONOMY_THEORIZED_ELEMENTS_RANKING_HEADER"
					}
					blockoverride "ranking_2_visible" {
						visible = "[GetVariableSystem.HasValue('mr_chemistry_ranking', 'theorized_elements')]"
					}
					blockoverride "ranking_2_datamodel" {
						datamodel = "[GetGlobalList('mr_theorized_element_ranking_global_list')]"
					}
					blockoverride "ranking_variable_used_2" {
						raw_text = "[Country.MakeScope.GetVariable('mendelejew_theorized_elements_country_number_var').GetValue|V0]"
					}
					blockoverride "text_3" {
						raw_text = "ASTRONOMY_DISCOVERED_ELEMENTS_RANKING_HEADER"
					}
					blockoverride "ranking_3_visible" {
						visible = "[GetVariableSystem.HasValue('mr_chemistry_ranking', 'discovered_elements')]"
					}
					blockoverride "ranking_3_datamodel" {
						datamodel = "[GetGlobalList('mr_discovered_element_ranking_global_list')]"
					}
					blockoverride "ranking_variable_used_3" {
						raw_text = "[Country.MakeScope.GetVariable('mendelejew_discovered_elements_country_number_var').GetValue|V0]"
					}
					blockoverride "text_4" {
						raw_text = "ASTRONOMY_ISOLATED_ELEMENTS_RANKING_HEADER"
					}
					blockoverride "ranking_4_visible" {
						visible = "[GetVariableSystem.HasValue('mr_chemistry_ranking', 'isolated_elements')]"
					}
					blockoverride "ranking_4_datamodel" {
						datamodel = "[GetGlobalList('mr_isolated_element_ranking_global_list')]"
					}
					blockoverride "ranking_variable_used_4" {
						raw_text = "[Country.MakeScope.GetVariable('mendelejew_isolated_elements_country_number_var').GetValue|V0]"
					}
				}
			}
		}
		blockoverride "academic_data_header_text" {
			text = mr_science_chemist_data_header
		}
		blockoverride "academic_data_content" {
			mr_academic_data_text = {
				#Theorized Elements of Total theorized Elements
				text = "TOTAL_THEORIZED_ELEMENTS_VAR"
				tooltip = "TOTAL_THEORIZED_ELEMENTS_VAR_TT"
			}
			mr_academic_data_text = {
				#Discovered Elements of Total discovered Elements
				text = "TOTAL_DISCOVERED_ELEMENTS_VAR"
				tooltip = "TOTAL_DISCOVERED_ELEMENTS_VAR_TT"
			}
			mr_academic_data_text = {
				#Isolated Elements of Total isolated Elements
				text = "TOTAL_ISOLATED_ELEMENTS_VAR"
				tooltip = "TOTAL_ISOLATED_ELEMENTS_VAR_TT"
			}
		}
		blockoverride "visit_button" {
			text = "[Country.GetCustom('mendelejew_periodic_table_name_choser_type')]"
			onclick = "[GetVariableSystem.Set('com_open_window', 'mr_academic_periodic_table')]"
			tooltip = "VISIT_PERIODIC_TABLE_BUTTON_TT"
		}
		blockoverride "big_box_content" {
			vbox = {
				margin_left = -20
				margin_right = 10
				layoutpolicy_vertical = expanding

				tab_buttons = {
					margin_left = 20
					maximumsize = { 320 0 }
					margin_bottom = -4
					blockoverride "first_button" {
						text = mr_science_chemist_tab_research
					}
					blockoverride "first_button_click" {
						onclick = "[GetVariableSystem.Set('mr_science_chemist_tab', 'research')]"
					}
					blockoverride "first_button_visibility" {
						visible = "[Or(GetVariableSystem.HasValue('mr_science_chemist_tab', 'research'), Not(GetVariableSystem.Exists('mr_science_chemist_tab')))]"
					}
					blockoverride "first_button_visibility_checked" {
						visible = "[And(Not(GetVariableSystem.HasValue('mr_science_chemist_tab', 'research')), GetVariableSystem.Exists('mr_science_chemist_tab'))]"
					}
					blockoverride "first_button_selected" {
						text = mr_science_chemist_tab_research
					}

					blockoverride "second_button" {
						text = mr_science_chemist_tab_synthetics
					}
					blockoverride "second_button_click" {
						onclick = "[GetVariableSystem.Set('mr_science_chemist_tab', 'synthetics')]"
					}
					blockoverride "second_button_visibility" {
						visible = "[GetVariableSystem.HasValue('mr_science_chemist_tab', 'synthetics')]"
					}
					blockoverride "second_button_visibility_checked" {
						visible = "[Not(GetVariableSystem.HasValue('mr_science_chemist_tab', 'synthetics'))]"
					}
					blockoverride "second_button_selected" {
						text = mr_science_chemist_tab_synthetics
					}
				}
				hbox = {
					layoutpolicy_vertical = expanding
					margin = { 20 20 }
					background = {
						using = simple_frame
					}
					vbox = {
						visible = "[Or(GetVariableSystem.HasValue('mr_science_chemist_tab', 'research'), Not(GetVariableSystem.Exists('mr_science_chemist_tab')))]"
						layoutpolicy_vertical = expanding
						spacing = 7
						minimumsize = { 270 0 }

						# Theorize Element
						mr_academic_project_button = {
							text = "mr_science_chemist_theory_button_text"
							datacontext = "[GetScriptedGui('mr_chemist_theory_button')]"
							tooltip = "MR_CHEMIST_THEORY_BUTTON"
						}

						# Discover Element
						mr_academic_project_button = {
							text = "mr_science_chemist_discover_button_text"
							datacontext = "[GetScriptedGui('mr_chemist_discovery_button')]"
							tooltip = "MR_CHEMIST_DISCOVERY_BUTTON"
						}

						# Isolate Element
						mr_academic_project_button = {
							text = "mr_science_chemist_isolation_button_text"
							datacontext = "[GetScriptedGui('mr_chemist_isolation_button')]"
							tooltip = "MR_CHEMIST_ISOLATION_BUTTON"
						}

						expand = {}
					}
					vbox = {
						visible = "[GetVariableSystem.HasValue('mr_science_chemist_tab', 'synthetics')]"
