                            datacontext = "[GetScriptedGui('mr_zoological_expedition_button_sgui')]"
                            blockoverride "button_content" {
                                text = "mr_science_naturalist_zoological_expedition_button"
                                tooltip = "MR_ZOOLOGICAL_EXPEDITION_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
