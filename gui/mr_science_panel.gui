                            datacontext = "[GetScriptedGui('mr_naturalist_improve_rubber_button_sgui')]"
                            blockoverride "button_content" {
                                text = "mr_science_naturalist_improve_rubber_button"
                                tooltip = "MR_NATURALIST_IMPROVE_RUBBER_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = "[GetScriptedGui('mr_improve_rubber_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_dubois_improve_rubber_plantation_button.dds"
                            }
                        }

                        # Botanical Garden
                        mr_shared_project_button = {
                            datacontext = "[GetScriptedGui('dubois_specimen_garden_button_sgui')]"
