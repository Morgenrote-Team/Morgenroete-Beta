    type mr_academic_engineer_tab = hbox {
        block "tab_visibility" {
            visible = no
        }
        layoutpolicy_horizontal = expanding
        layoutpolicy_vertical = expanding
        margin = { 0 18 }
        margin_right = 10

        vbox = {
            layoutpolicy_vertical = expanding
            spacing = 7
            minimumsize = { @[panel_button_width + 10] 0 }

            block "tab_buttons" {
            }

            expand = {}
        }

        hbox = {
            layoutpolicy_horizontal = expanding
            layoutpolicy_vertical = expanding
            background = {
                using = entry_bg_simple
            }

            vbox = {
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding

                textbox = {
                    layoutpolicy_horizontal = expanding
                    maximumsize = { 880 -1 }
                    margin = { 20 20 }
                    autoresize = yes
                    multiline = yes
                    block "tab_desc" {
                        raw_text = "tab_desc"
                        default_format = "#r"
                    }
                }

                expand = {}

                hbox = {
                    block "tab_button_specialize_context" {}
                    margin = { 20 20 }
                    layoutpolicy_horizontal = expanding

                    mr_shared_project_button = {
                        blockoverride "button_content" {
                            block "tab_button_specialize" {
                                raw_text = "tab_button_specialize"
                                default_format = "#r"
                            }
                            onclick = "[ScriptedGui.Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
                            enabled = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).End)]"
                            visible = "[ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                        }
                        blockoverride "size" {
                            size = { 320 50 }
                        }
                    }
                }
            }
        }

    }

    type mr_academic_engineer_tab_icon = widget {
        parentanchor = hcenter
        size = { 35 35 }
        widget = {
            visible = "[Not(ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"
            position = { 0 -21 }
            size = { 35 35 }
            background = {
                texture = "gfx/interface/backgrounds/round_button_bg.dds"
            }
            icon = {
                parentanchor = center
                block "icon" {
                    texture = "gfx/interface/icons/concept_icons/gaudi_engineer_civil_concept_icon.dds"
                }
                size = { 70% 70% }
            }
        }
        widget = {
            visible = "[ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
            position = { 0 -25 }
            size = { 35 35 }
            background = {
                texture = "gfx/interface/backgrounds/round_button_bg.dds"
            }
            background = {
                margin = { 1 1 }
                using = highlighted_circle_selection_big
            }

            icon = {
                parentanchor = center
                block "icon" {
                    texture = "gfx/interface/icons/concept_icons/gaudi_engineer_civil_concept_icon.dds"
                }
                size = { 70% 70% }
            }
        }
    }

    type mr_academic_expedition_button = widget {
        block "size" {
            size = { 238 300 }
        }
        block "context" {}
        #
        visible = "[ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
        layoutpolicy_vertical = expanding
        background = {
            using = frame_small
        }
        widget = {
            block "size" {
                size = { 238 300 }
            }

            background = {
                using = dark_area
                alpha = 0.5
                using = frame_small_mask
            }

            vbox = {
                name = content
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding

                vbox = {
                    layoutpolicy_horizontal = expanding
                    layoutpolicy_vertical = expanding
                    bottomtotop = yes

                    vbox = {
                        layoutpolicy_horizontal = expanding
                        layoutpolicy_vertical = expanding
                        margin_top = -42
                        vbox = {
                            name = header
                            layoutpolicy_horizontal = expanding
                            layoutpolicy_vertical = expanding

                            background = {
                                block "background" {
                                    #texture = "gfx/interface/icons/objectives/sandbox.dds"
                                }
                                fittype = centercrop
                                spriteType = Corneredstretched
                                using = frame_small_mask_top
                            }

                            state = {
                                name = enter
                                using = button_animation_duration
                                alpha = 0.5
                            }
                            state = {
                                name = leave
                                using = button_animation_duration
                                alpha = 1
                            }

                            expand = {}
                        }
                    }

                    default_header_clean = {
                        layoutpolicy_horizontal = expanding
                        blockoverride "text" {
                            block "expedition_header" {
                                raw_text = "expedition_header"
                                default_format = "#r"
                            }
                        }
                        blockoverride "header_mask" {
                            using = frame_small_mask_top
                        }
                        blockoverride "size" {
                            size = { 100% 42 }
                        }
                    }
                }

                hbox = {
                    layoutpolicy_horizontal = expanding
                    margin = { 2 0 }
                    icon = {
                        minimumsize = { -1 2 }
                        layoutpolicy_horizontal = expanding
                        texture = "gfx/interface/dividers/divider_clean.dds"
                        texture_density = 2
                        spriteType = CorneredTiled
                        spriteborder = { 0 0 }
                    }
                }

                vbox = {
                    layoutpolicy_horizontal = expanding

                    vbox = {
                        margin = { 10 0 }
                        margin_bottom = 10
                        layoutpolicy_horizontal = expanding
                        layoutpolicy_vertical = expanding

                        textbox = {
                            text = "mr_science_general_expedition_start"
                            margin_top = 2
                            align = center|nobaseline
                            autoresize = yes
                            multiline = yes
                            using = fontsize_xxl
                        }
                    }
                }
            }

            widget = {
                visible = "[Not(ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).End))]"
                parentanchor = top|left
                block "size" {
                    size = { 238 300 }
                }
                background = {
                    using = dark_area
                    alpha = 0.5
                    using = frame_small_mask
                }
            }

            widget = {
                block "active_visible" {
                    visible = no
                }
                parentanchor = top|left
                block "size" {
                    size = { 238 300 }
                }
                background = {
                    texture = "gfx/interface/buttons/glow_button_border.dds"
                    spriteType = CorneredStretched
                    framesize = { 150 150 }
                    spriteborder = { 60 60 }
                    frame = 3
                    using = frame_small_mask
                }

                textbox = {
                    block "size" {
                        size = { 238 300 }
                    }
                    align = center
                    using = fontsize_xl
                    text = "mr_science_general_expedition_active"
                }
            }
        }

        button = {
            block "expedition_tooltip" {}
            using = glow_button_border
            block "size" {
                size = { 238 300 }
            }
            using = frame_small_mask
            using = start_game_button_sound

            onclick = "[ScriptedGui.Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
            enabled = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).End)]"

            state = {
                name = _mouse_enter
                on_start = "[PdxGuiWidget.AccessChild('content').AccessChild('header').TriggerAnimation('enter')]"
            }

            state = {
                name = _mouse_leave
                on_start = "[PdxGuiWidget.AccessChild('content').AccessChild('header').InterruptThenTriggerAnimation('enter','leave')]"
            }
        }
    }

}