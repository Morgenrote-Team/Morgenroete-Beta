                        }
                        blockoverride "third_button_visibility_checked" {
                            visible = "[Not(GetVariableSystem.HasValue('mr_science_geologist_tab', 'organization'))]"
                        }
                        blockoverride "third_button_selected" {
                            text = mr_science_geologist_tab_organization
                        }
                    }
                }
                blockoverride "tab_content" {
                    vbox = {
                        visible = "[Or(GetVariableSystem.HasValue('mr_science_geologist_tab', 'research'), Not(GetVariableSystem.Exists('mr_science_geologist_tab')))]"
                        layoutpolicy_vertical = expanding
                        spacing = 7
                        minimumsize = { @panel_button_width 0 }
                        # Geological Research
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_geologist_geological_research_button_sgui')]"
                            blockoverride "button_content" {
                                text = "mr_science_geologist_research_button"
                                tooltip = "MR_GEOLOGIST_GEOLOGICAL_RESEARCH_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
