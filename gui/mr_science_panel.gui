    type mr_academic_physician = mr_shared_occupation {
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('panum_physician_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/panum_physician_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_panum_physician_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "PHYSICIAN_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('academics_has_physician_gui_type')]"
        }
        blockoverride "character_animation" {
            portrait_texture = "[Character.GetAnimatedPortrait('characters_portrait_environment', 'mr_camera_torso_physician', 'idle', GetPortraitRenderSize(PdxGuiWidget.Self))]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = "MR_PHYSICIAN_ACHIEVEMENTS_TT"
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('panum_physician_experience_var').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_panum_physician_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_panum_physician_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_medical_score_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_medicine_ranking', 'medical_score')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_medicine_ranking', 'medical_score') )]"
                        text = "MR_MEDICAL_SCORE"
                        tooltip = "MR_RANKING_BY_MEDICAL_SCORE"

                        onclick = "[GetVariableSystem.Set('mr_medicine_ranking', 'medical_score')]"
                    }
                    blockoverride "button_2_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_medicine_ranking', 'disease_descriptions') )]"
                        text = "MR_DISEASE_DESCRIPTIONS"
                        tooltip = "MR_RANKING_BY_DISEASE_DESCRIPTIONS"

                        onclick = "[GetVariableSystem.Set('mr_medicine_ranking', 'disease_descriptions')]"
                    }
                    blockoverride "button_3_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_medicine_ranking', 'disease_treatments') )]"
                        text = "MR_DISEASE_TREATMENTS"
                        tooltip = "MR_RANKING_BY_DISEASE_TREATMENTS"

                        onclick = "[GetVariableSystem.Set('mr_medicine_ranking', 'disease_treatments')]"
                    }
                    blockoverride "button_4_content" {
