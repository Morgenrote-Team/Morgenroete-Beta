						text = "MR_ACADEMY_PROGRESS_VALUES"
						size = { 400 35 }
						using = fontsize_xl
						align = center
					}
				}
			}
		}
		blockoverride "big_box_content" {
			textbox = {
				layoutpolicy_horizontal = expanding
				autoresize = yes
				multiline = yes
				text = mr_academic_promote_desc
			}
			expand = {}
		}
	}

