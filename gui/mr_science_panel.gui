types mr_main_science_panel_types {

	type mr_science_panel = fullscreen_block_window {
		name = "mr_science_panel"
		datacontext = "[GetMetaPlayer.GetPlayedOrObservedCountry]"

		visible = "[Or(GetVariableSystem.HasValue('com_open_window', 'mr_sidebar_button_science_sgui'), GetVariableSystem.HasValue('com_alert_action', Localize('mr_science_panel_alert')))]"

		blockoverride "animation_state_block" {
			state = {
				name = _show
				# Close open panel before showing this one
				on_start = "[InformationPanelBar.ClosePanel]"
				on_start = "[MapListPanelManager.CloseCurrentPanel]"
				# Fullscreen panels hide topbar
				on_finish = "[GetVariableSystem.Set('com_fullscreen', 'com_fullscreen')]"
				start_sound = {
					soundeffect = "event:/SFX/UI/SideBar/markets"
				}
				start_sound = {
					soundeffect = "snapshot:/Dynamic/mute_world_80"
				}
				start_sound = {
					soundeffect = "snapshot:/Dynamic/mute_vfx_war_100"
				}
			}

			state = {
				name = _hide
				start_sound = {
					soundeffect = "event:/SFX/UI/SideBar/markets_stop"
				}
			}
		}

		blockoverride "window_header_name" {
			text = ACADEMY_OF_SCIENCE_VIEW_NAME
			default_format = "#bold"
		}

		block "back_button_fullscreen" {
			back_button_large = {
				position = { 11 15 }
				parentanchor = top|left
				onclick = "[GetVariableSystem.Clear('com_open_window')]"
				onclick = "[GetVariableSystem.Clear('com_alert_action')]"
				onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
				input_action = "back"
			}

			close_button_large = {
				name = "tutorial_highlight_close_button"
				parentanchor = top|right
				onclick = "[GetVariableSystem.Clear('com_open_window')]"
				onclick = "[GetVariableSystem.Clear('com_alert_action')]"
				onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
				shortcut = "close_window"
				position = { -55 116 }
			}
		}

		blockoverride "close_button_position" {
			visible = no
		}

		blockoverride "fixed_top" {
			tab_buttons_fullscreen = {
				# General
				blockoverride "first_button" {
					text = "mr_science_tab_general"
				}
				blockoverride "first_button_click" {
					onclick = "[GetVariableSystem.Set('mr_science_tab', 'general')]"
				}
				blockoverride "first_button_visibility" {
					visible = "[Or(
									GetVariableSystem.HasValue('mr_science_tab', 'general'),
									Not(GetVariableSystem.Exists('mr_science_tab'))
								)]"
				}
				blockoverride "first_button_visibility_checked" {
					visible = "[And(
									Not(GetVariableSystem.HasValue('mr_science_tab', 'general')),
									GetVariableSystem.Exists('mr_science_tab')
								)]"
				}
				blockoverride "first_button_selected" {
					text = "mr_science_tab_general"
				}

				# Mathematical-Technical
				blockoverride "second_button" {
					text = "mr_science_tab_mathematics"
				}
				blockoverride "second_button_background" {
					background = {
						margin = { 0 -2 }
						using = fade_bottom_entry_fancy_header_colored
						using = Color_Red
						alpha = 0.5
					}
				}
				blockoverride "second_button_click" {
					onclick = "[GetVariableSystem.Set('mr_science_tab', 'mathematics')]"
				}
				blockoverride "second_button_visibility" {
					visible = "[GetVariableSystem.HasValue('mr_science_tab', 'mathematics')]"
				}
				blockoverride "second_button_visibility_checked" {
					visible = "[Not(GetVariableSystem.HasValue('mr_science_tab', 'mathematics'))]"
				}
				blockoverride "second_button_selected" {
					text = "mr_science_tab_mathematics"
				}
				blockoverride "second_button_background_selected" {
					background = {
						using = fade_bottom_entry_fancy_header_colored
						using = Color_Red
						alpha = 0.5
					}
				}

				# Natural History
				blockoverride "third_button" {
					text = "mr_science_tab_natural_history"
				}
				blockoverride "third_button_background" {
					background = {
						margin = { 0 -2 }
						using = fade_bottom_entry_fancy_header_colored
						using = Color_Blue
						alpha = 0.5
					}
				}
				blockoverride "third_button_click" {
					onclick = "[GetVariableSystem.Set('mr_science_tab', 'natural_history')]"
				}
				blockoverride "third_button_visibility" {
					visible = "[GetVariableSystem.HasValue('mr_science_tab', 'natural_history')]"
				}
				blockoverride "third_button_visibility_checked" {
					visible = "[Not(GetVariableSystem.HasValue('mr_science_tab', 'natural_history'))]"
				}
				blockoverride "third_button_selected" {
					text = "mr_science_tab_natural_history"
				}
				blockoverride "third_button_background_selected" {
					background = {
						using = fade_bottom_entry_fancy_header_colored
						using = Color_Blue
						alpha = 0.5
					}
				}

				# Humanities-Anthropological
				blockoverride "fourth_button" {
					text = "mr_science_tab_humanities"
				}
				blockoverride "fourth_button_background" {
					background = {
						margin = { 0 -2 }
						using = fade_bottom_entry_fancy_header_colored
						using = Color_Green
						alpha = 0.5
					}
				}
				blockoverride "fourth_button_click" {
					onclick = "[GetVariableSystem.Set('mr_science_tab', 'humanities')]"
				}
				blockoverride "fourth_button_visibility" {
					visible = "[GetVariableSystem.HasValue('mr_science_tab', 'humanities')]"
				}
				blockoverride "fourth_button_visibility_checked" {
					visible = "[Not(GetVariableSystem.HasValue('mr_science_tab', 'humanities'))]"
				}
				blockoverride "fourth_button_selected" {
					text = "mr_science_tab_humanities"
				}
				blockoverride "fourth_button_background_selected" {
					background = {
						using = fade_bottom_entry_fancy_header_colored
						using = Color_Green
						alpha = 0.5
					}
				}
			}
		}

		blockoverride "scrollarea_content" {
			vbox = {
				layoutpolicy_vertical = expanding
				layoutpolicy_horizontal = expanding

				mr_science_view = {
					blockoverride "view_visibility" {
						visible = "[Or(GetVariableSystem.HasValue('mr_science_tab', 'general'), Not(GetVariableSystem.Exists('mr_science_tab')))]"
					}
					blockoverride "view_content" {
						mr_academic_promote = {}
						mr_academic_scientific_focus = {}
						mr_academic_expeditions = {}
					}
				}

				mr_science_view = {
					blockoverride "view_visibility" {
						visible = "[GetVariableSystem.HasValue('mr_science_tab', 'mathematics')]"
					}
					blockoverride "view_content" {
						mr_academic_engineer = {}
						mr_academic_chemist = {}
						mr_academic_astronomer = {}
					}
				}
				mr_science_view = {
					blockoverride "view_visibility" {
						visible = "[GetVariableSystem.HasValue('mr_science_tab', 'natural_history')]"
					}
					blockoverride "view_content" {
						mr_academic_geologist = {}
						mr_academic_paleontologist = {}
						mr_academic_naturalist = {}
					}
				}
				mr_science_view = {
					blockoverride "view_visibility" {
						visible = "[GetVariableSystem.HasValue('mr_science_tab', 'humanities')]"
					}
					blockoverride "view_content" {
						mr_academic_physician = {}
						mr_academic_archaeologist = {}
						mr_academic_anthropologist = {}
					}
				}
			}
		}
	}

	type mr_academic_engineer = mr_academic_full {
		blockoverride "academic" {
			datacontext = "[Country.MakeScope.Var('gaudi_engineer_var')]"
		}
		blockoverride "role_icon" {
			texture = "gfx/interface/icons/character_role_icons/gaudi_engineer_role.dds"
		}
		blockoverride "role_tooltip" {
			tooltip = "[concept_gaudi_engineer_desc]"
		}
		blockoverride "role_name" {
			raw_text = "[Country.GetCustom('gaudi_engineer_role_name')]"
		}
		blockoverride "character_name" {
			text = "[Country.GetCustom('academics_has_engineer_gui_type')]"
		}
		blockoverride "scientist_achievement_tooltip" {
			tooltip = "MR_ENGINEER_ACHIEVEMENTS_TT"
		}
		blockoverride "experience_bar" {
			green_progressbar_horizontal = { #Civil Engineer
				parentanchor = bottom|left
				position = { 15 -60 }
				size = { 250 35 }
				datacontext = "[GetScriptedGui('gaudi_civil_engineer_experience_bar_visibility_sgui')]"
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
				blockoverride "values" {
					min = 0
					max = 300
					value = "[Country.MakeScope.Var('gaudi_engineer_var').GetVariable('gaudi_civil_engineer_experience').GetValue]"
					tooltip = "[Country.GetCustom('GUI_gaudi_civil_engineer_experience_type')]"
				}
				textbox = {
					text = "[Country.GetCustom('GUI_gaudi_civil_engineer_experience_text_type')]"
					position = { 0 0 }
					parentanchor = center
					autoresize = yes
					using = fontsize_xl
				}
			}
			green_progressbar_horizontal = { #Mechanical Engineer
				parentanchor = bottom|left
				position = { 15 -60 }
				size = { 250 35 }
				datacontext = "[GetScriptedGui('gaudi_mechanical_engineer_experience_bar_visibility_sgui')]"
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
				blockoverride "values" {
					min = 0
					max = 300
					value = "[Country.MakeScope.Var('gaudi_engineer_var').GetVariable('gaudi_mechanical_engineer_experience').GetValue]"
					tooltip = "[Country.GetCustom('GUI_gaudi_mechanical_engineer_experience_type')]"
				}
				textbox = {
					text = "[Country.GetCustom('GUI_gaudi_mechanical_engineer_experience_text_type')]"
					position = { 0 0 }
					parentanchor = center
					autoresize = yes
					using = fontsize_xl
				}
			}
			green_progressbar_horizontal = { #Military Engineer
				parentanchor = bottom|left
				position = { 15 -60 }
				size = { 250 35 }
				datacontext = "[GetScriptedGui('gaudi_military_engineer_experience_bar_visibility_sgui')]"
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
				blockoverride "values" {
					min = 0
					max = 300
					value = "[Country.MakeScope.Var('gaudi_engineer_var').GetVariable('gaudi_military_engineer_experience').GetValue]"
					tooltip = "[Country.GetCustom('GUI_gaudi_military_engineer_experience_type')]"
				}
				textbox = {
					text = "[Country.GetCustom('GUI_gaudi_military_engineer_experience_text_type')]"
					position = { 0 0 }
					parentanchor = center
					autoresize = yes
					using = fontsize_xl
				}
			}
			green_progressbar_horizontal = { #Electrical Engineer
				parentanchor = bottom|left
				position = { 15 -60 }
				size = { 250 35 }
				datacontext = "[GetScriptedGui('gaudi_electrical_engineer_experience_bar_visibility_sgui')]"
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
				blockoverride "values" {
					min = 0
					max = 300
					value = "[Country.MakeScope.Var('gaudi_engineer_var').GetVariable('gaudi_electrical_engineer_experience').GetValue]"
					tooltip = "[Country.GetCustom('GUI_gaudi_electrical_engineer_experience_type')]"
				}
				textbox = {
					text = "[Country.GetCustom('GUI_gaudi_electrical_engineer_experience_text_type')]"
					position = { 0 0 }
					parentanchor = center
					autoresize = yes
					using = fontsize_xl
				}
			}
			green_progressbar_horizontal = { #Aeronautical Engineer
				parentanchor = bottom|left
				position = { 15 -60 }
				size = { 250 35 }
				datacontext = "[GetScriptedGui('gaudi_aeronautical_engineer_experience_bar_visibility_sgui')]"
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
				blockoverride "values" {
					min = 0
					max = 300
					value = "[Country.MakeScope.Var('gaudi_engineer_var').GetVariable('gaudi_aeronautical_engineer_experience').GetValue]"
					tooltip = "[Country.GetCustom('GUI_gaudi_aeronautical_engineer_experience_type')]"
				}
				textbox = {
					text = "[Country.GetCustom('GUI_gaudi_aeronautical_engineer_experience_text_type')]"
					position = { 0 0 }
					parentanchor = center
					autoresize = yes
					using = fontsize_xl
				}
			}
		}
		blockoverride "academic_data_header_text" {
			text = mr_science_engineer_data_header
		}
		blockoverride "academic_data_content" {
			mr_academic_data_text = {
				# Geomagnetic Research Data
				text = "GEOMAGNETIC_RESEARCH_VAR"
			}
			mr_academic_data_text = {
				# Splendid Architecture Points
				text = "SPLENDID_ARCHITECTURE_VAR"
			}
		}
		blockoverride "visit_button" {
			text = "VISIT_SCIENTIFIC_SOCIETY_BUTTON"
			datacontext = "[GetScriptedGui('mr_visit_scientific_society')]"
			onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
			enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
			tooltip = "VISIT_SCIENTIFIC_SOCIETY_BUTTON_TT"
		}
		blockoverride "big_box_content" {
			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				tab_buttons = {
					margin_bottom = -4
					blockoverride "first_button" {
						text = "gaudi_civil_engineer"
					}
					blockoverride "first_button_tooltip" {
						tooltip = "concept_gaudi_civil_engineer_desc"
					}
					blockoverride "first_button_click" {
						onclick = "[GetVariableSystem.Set('mr_science_engineer_tab', 'civil')]"
					}
					blockoverride "first_button_visibility" {
						visible = "[Or(GetVariableSystem.HasValue('mr_science_engineer_tab', 'civil'), Not(GetVariableSystem.Exists('mr_science_engineer_tab')))]"
					}
					blockoverride "first_button_visibility_checked" {
						visible = "[And(Not(GetVariableSystem.HasValue('mr_science_engineer_tab', 'civil')), GetVariableSystem.Exists('mr_science_engineer_tab'))]"
					}
					blockoverride "first_button_selected" {
						text = "gaudi_civil_engineer"
					}
					blockoverride "first_button_icon" {
					}

					blockoverride "second_button" {
						text = "gaudi_mechanical_engineer"
					}
					blockoverride "second_button_tooltip" {
						tooltip = "concept_gaudi_mechanical_engineer_desc"
					}
					blockoverride "second_button_click" {
						onclick = "[GetVariableSystem.Set('mr_science_engineer_tab', 'mechanical')]"
					}
					blockoverride "second_button_visibility" {
						visible = "[GetVariableSystem.HasValue('mr_science_engineer_tab', 'mechanical')]"
					}
					blockoverride "second_button_visibility_checked" {
						visible = "[Not(GetVariableSystem.HasValue('mr_science_engineer_tab', 'mechanical'))]"
					}
					blockoverride "second_button_selected" {
						text = "gaudi_mechanical_engineer"
					}

					blockoverride "third_button" {
						text = "gaudi_military_engineer"
					}
					blockoverride "third_button_tooltip" {
						tooltip = "concept_gaudi_military_engineer_desc"
					}
					blockoverride "third_button_click" {
						onclick = "[GetVariableSystem.Set('mr_science_engineer_tab', 'military')]"
					}
					blockoverride "third_button_visibility" {
						visible = "[GetVariableSystem.HasValue('mr_science_engineer_tab', 'military')]"
					}
					blockoverride "third_button_visibility_checked" {
						visible = "[Not(GetVariableSystem.HasValue('mr_science_engineer_tab', 'military'))]"
					}
					blockoverride "third_button_selected" {
						text = "gaudi_military_engineer"
					}

					blockoverride "fourth_button" {
						text = "gaudi_electrical_engineer"
					}
					blockoverride "fourth_button_tooltip" {
						tooltip = "concept_gaudi_electrical_engineer_desc"
					}
					blockoverride "fourth_button_click" {
						onclick = "[GetVariableSystem.Set('mr_science_engineer_tab', 'electrical')]"
					}
					blockoverride "fourth_button_visibility" {
						visible = "[GetVariableSystem.HasValue('mr_science_engineer_tab', 'electrical')]"
					}
					blockoverride "fourth_button_visibility_checked" {
						visible = "[Not(GetVariableSystem.HasValue('mr_science_engineer_tab', 'electrical'))]"
					}
					blockoverride "fourth_button_selected" {
						text = "gaudi_electrical_engineer"
					}

					blockoverride "fifth_button" {
						text = "gaudi_aeronautical_engineer"
					}
					blockoverride "fifth_button_tooltip" {
						tooltip = "concept_gaudi_aeronautical_engineer_desc"
					}
					blockoverride "fifth_button_click" {
						onclick = "[GetVariableSystem.Set('mr_science_engineer_tab', 'aeronautical')]"
					}
					blockoverride "fifth_button_visibility" {
						visible = "[GetVariableSystem.HasValue('mr_science_engineer_tab', 'aeronautical')]"
					}
					blockoverride "fifth_button_visibility_checked" {
						visible = "[Not(GetVariableSystem.HasValue('mr_science_engineer_tab', 'aeronautical'))]"
					}
					blockoverride "fifth_button_selected" {
						text = "gaudi_aeronautical_engineer"
					}
				}
				hbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					background = {
						using = simple_frame
					}

					mr_academic_engineer_tab = {
						blockoverride "tab_visibility" {
							# Default Tab
							visible = "[Or(GetVariableSystem.HasValue('mr_science_engineer_tab', 'civil'), Not(GetVariableSystem.Exists('mr_science_engineer_tab')))]"
						}
						blockoverride "tab_buttons" {
							# Civil Engineer Research
							mr_academic_project_button = {
								text = MR_CIVIL_ENGINEER_RESEARCH_BUTTON
								datacontext = "[GetScriptedGui('mr_civil_engineer_research_button')]"
								tooltip = "MR_CIVIL_ENGINEER_RESEARCH_BUTTON_TT"
							}

							# Civil Engineer Infrastructure Project
							mr_academic_project_button = {
								text = MR_CIVIL_ENGINEER_INFRASTRUCTURE_BUTTON
								datacontext = "[GetScriptedGui('mr_civil_engineer_infrastructure_button')]"
								tooltip = "MR_CIVIL_ENGINEER_INFRASTRUCTURE_BUTTON_TT"
							}

							# Civil Engineer Railway Project
							mr_academic_project_button = {
								text = mr_civil_engineer_railway_button
								datacontext = "[GetScriptedGui('mr_civil_engineer_railway_button')]"
								tooltip = "MR_CIVIL_ENGINEER_RAILWAY_BUTTON_TT"
							}

							# Civil Engineer Irrigation Project
							mr_academic_project_button = {
								text = mr_civil_engineer_irrigation_button
								datacontext = "[GetScriptedGui('mr_civil_engineer_irrigation_button')]"
								tooltip = "MR_CIVIL_ENGINEER_IRRIGATION_BUTTON_TT"
							}

							# Civil Engineer Construction Project
							mr_academic_project_button = {
								text = MR_CIVIL_ENGINEER_CONSTRUCTION_BUTTON
								datacontext = "[GetScriptedGui('mr_civil_engineer_construction_button')]"
								tooltip = "MR_CIVIL_ENGINEER_CONSTRUCTION_BUTTON_TT"
							}

							# Civil Engineer Topographic Map Project
							mr_academic_project_button = {
								text = MR_CIVIL_ENGINEER_TOPOGRAPHIC_MAP_BUTTON
								datacontext = "[GetScriptedGui('mr_civil_engineer_topographic_map_button')]"
								tooltip = "MR_CIVIL_ENGINEER_TOPOGRAPHIC_MAP_BUTTON_TT"
							}
						}
						blockoverride "tab_button_context" {
							datacontext = "[GetScriptedGui('mr_civil_engineer_research_button')]"
						}
						blockoverride "tab_desc" {
							text = MR_CHANGE_TO_CIVIL_EGINEER_BUTTON_TT
						}
						blockoverride "tab_button_specialize" {
							datacontext = "[GetScriptedGui('mr_civil_engineer_research_button')]"
							text = mr_civil_engineer_button
							tooltip = "MR_CHANGE_TO_CIVIL_EGINEER_BUTTON_TT"
						}
					}

					mr_academic_engineer_tab = {
						blockoverride "tab_visibility" {
							visible = "[GetVariableSystem.HasValue('mr_science_engineer_tab', 'mechanical')]"
						}
						blockoverride "tab_buttons" {
							# Mechanical Engineer Research
							mr_academic_project_button = {
								text = MR_MECHANICAL_ENGINEER_RESEARCH_BUTTON
								datacontext = "[GetScriptedGui('mr_mechanical_engineer_research_button')]"
								tooltip = "MR_MECHANICAL_ENGINEER_RESEARCH_BUTTON_TT"
							}

							# Mechanical Engineer New Locomotives Project
							mr_academic_project_button = {
								text = MR_MECHANICAL_ENGINEER_LOCOMOTIVES_BUTTON
								datacontext = "[GetScriptedGui('mr_mechanical_engineer_locomotives_button')]"
								tooltip = "MR_MECHANICAL_ENGINEER_LOCOMOTIVES_BUTTON_TT"
							}

							# Mechanical Engineer Industries Project
							mr_academic_project_button = {
								text = MR_MECHANICAL_ENGINEER_INDUSTRIES_BUTTON
								datacontext = "[GetScriptedGui('mr_mechanical_engineer_industries_button')]"
								tooltip = "MR_MECHANICAL_ENGINEER_INDUSTRIES_BUTTON_TT"
							}

							# Mechanical Engineer Mechanical Computer Project
							mr_academic_project_button = {
								text = MR_MECHANICAL_ENGINEER_MECHANICAL_COMPUTER_BUTTON
								datacontext = "[GetScriptedGui('mr_mechanical_engineer_mechanical_computer_button')]"
								tooltip = "MR_MECHANICAL_ENGINEER_MECHANICAL_COMPUTER_BUTTON_TT"
							}
						}
						blockoverride "tab_button_context" {
							datacontext = "[GetScriptedGui('gaudi_change_to_mechanical_engineer_button')]"
						}
						blockoverride "tab_desc" {
							text = MR_CHANGE_TO_MECHANICAL_EGINEER_BUTTON_TT
						}
						blockoverride "tab_button_specialize" {
							text = mr_mechanical_engineer_button
							tooltip = "MR_CHANGE_TO_MECHANICAL_EGINEER_BUTTON_TT"
						}
					}

					mr_academic_engineer_tab = {
						blockoverride "tab_visibility" {
							visible = "[GetVariableSystem.HasValue('mr_science_engineer_tab', 'military')]"
						}
						blockoverride "tab_buttons" {
							# Military Engineer Military Research Project
							mr_academic_project_button = {
								text = MR_MILITARY_ENGINEER_RESEARCH_BUTTON
								datacontext = "[GetScriptedGui('mr_military_engineer_research_button')]"
								tooltip = "MR_MILITARY_ENGINEER_RESEARCH_BUTTON_TT"
							}

							# Military Engineer Naval Research Project
							mr_academic_project_button = {
								text = MR_MILITARY_ENGINEER_NAVAL_RESEARCH_BUTTON
								datacontext = "[GetScriptedGui('mr_military_engineer_naval_research_button')]"
								tooltip = "MR_MILITARY_ENGINEER_NAVAL_RESEARCH_BUTTON_TT"
							}

							# Military Engineer Advanced Defences Project
							mr_academic_project_button = {
								text = MR_MILITARY_ENGINEER_ADVANCED_DEFENCE_BUTTON
								datacontext = "[GetScriptedGui('mr_military_engineer_advanced_defence_button')]"
