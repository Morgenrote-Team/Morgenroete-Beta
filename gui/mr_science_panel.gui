    type mr_academic_geologist = mr_shared_occupation {
        name = "mr_shared_occupation_geologist"
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('agassiz_geologist_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/mr_geologist_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_agassiz_geologist_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "GEOLOGY_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('academics_has_geologist_gui_type')]"
        }
        blockoverride "character_animation" {
            portrait_texture = "[Character.GetAnimatedPortrait('characters_portrait_environment', 'mr_camera_torso_geologist', 'idle', GetPortraitRenderSize(PdxGuiWidget.Self))]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = "MR_GEOLOGIST_ACHIEVEMENTS"
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('agassiz_geologist_experience_var').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_agassiz_geologist_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_agassiz_geologist_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_geology_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_geology_ranking', 'geology_score')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_geology_ranking', 'geology_score') )]"
                        text = "MR_GEOLOGICAL_SCORE"
                        tooltip = "MR_RANKING_BY_GEOLOGICAL_SCORE"

                        onclick = "[GetVariableSystem.Set('mr_geology_ranking', 'geology_score')]"
                    }
                    blockoverride "button_2_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_geology_ranking', 'geological_knowledge') )]"
                        text = "MR_GEOLOGICAL_KNOWLEDGE"
                        tooltip = "MR_RANKING_BY_GEOLOGICAL_KNOWLEDGE"

                        onclick = "[GetVariableSystem.Set('mr_geology_ranking', 'geological_knowledge')]"
                    }
                    blockoverride "button_3_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_geology_ranking', 'oceanographic_knowledge') )]"
                        text = "MR_OCEANOGRAPHIC_KNOWLEDGE"
                        tooltip = "MR_RANKING_BY_OCEANOGRAPHIC_KNOWLEDGE"

                        onclick = "[GetVariableSystem.Set('mr_geology_ranking', 'oceanographic_knowledge')]"
                    }
                    blockoverride "button_4_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_geology_ranking', 'minerals') )]"
                        text = "MR_MINERALS"
                        tooltip = "MR_RANKING_BY_MINERALS"

                        onclick = "[GetVariableSystem.Set('mr_geology_ranking', 'minerals')]"
                    }
                    blockoverride "button_5_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_geology_ranking', 'rare_minerals') )]"
                        text = "MR_RARE_MINERALS"
                        tooltip = "MR_RANKING_BY_RARE_MINERALS"

                        onclick = "[GetVariableSystem.Set('mr_geology_ranking', 'rare_minerals')]"
                    }
                    blockoverride "button_6_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_geology_ranking', 'geologist_ranking') )]"
                        text = "MR_GEOLOGIST_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_GEOLOGIST"

                        onclick = "[GetVariableSystem.Set('mr_geology_ranking', 'geologist_ranking')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "GEOLOGICAL_SCORE_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_geology_ranking', 'geology_score')]"
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_geological_score_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
