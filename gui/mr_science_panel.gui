                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_geologist_age_earth_button.dds"
                            }
                        }

                        # The Highest Mountain
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_geologist_highest_mountain_button_sgui')]"
                            blockoverride "button_content" {
                                text = "MR_GEOLOGIST_HIGHEST_MOUNTAIN_BUTTON"
                                tooltip = "MR_GEOLOGIST_HIGHEST_MOUNTAIN_BUTTON_TT"
