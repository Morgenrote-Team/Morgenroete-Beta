                    }
                    blockoverride "text_2" {
                        raw_text = "GEOLOGY_GEOLOGICAL_KNOWLEDGE_RANKING_HEADER"
                    }
                    blockoverride "ranking_2_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_geology_ranking', 'geological_knowledge')]"
                    }
                    blockoverride "ranking_2_datamodel" {
                        datamodel = "[GetGlobalList('mr_geological_knowledge_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_2" {
                        raw_text = "[Country.MakeScope.GetVariable('agassiz_geological_knowledge_var').GetValue|V0]"
                    }
                    blockoverride "text_3" {
                        raw_text = "GEOLOGY_OCEANOGRAPHIC_KNOWLEDGE_RANKING_HEADER"
                    }
                    blockoverride "ranking_3_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_geology_ranking', 'oceanographic_knowledge')]"
                    }
                    blockoverride "ranking_3_datamodel" {
                        datamodel = "[GetGlobalList('mr_oceanographic_knowledge_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_3" {
                        raw_text = "[Country.MakeScope.GetVariable('rapanui_oceanographic_understanding').GetValue|V0]"
                    }
                    blockoverride "text_4" {
                        raw_text = "GEOLOGY_MINERALS_RANKING_HEADER"
                    }
                    blockoverride "ranking_4_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_geology_ranking', 'minerals')]"
                    }
                    blockoverride "ranking_4_datamodel" {
                        datamodel = "[GetGlobalList('mr_minerals_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_4" {
                        raw_text = "[Country.MakeScope.GetVariable('agassiz_generic_minerals_var').GetValue|V*0]"
                    }
                    blockoverride "text_5" {
                        raw_text = "GEOLOGY_RARE_MINERALS_RANKING_HEADER"
                    }
                    blockoverride "ranking_5_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_geology_ranking', 'rare_minerals')]"
                    }
                    blockoverride "ranking_5_datamodel" {
                        datamodel = "[GetGlobalList('mr_rare_minerals_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_5" {
