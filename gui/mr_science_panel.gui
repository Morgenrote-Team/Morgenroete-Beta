        blockoverride "big_box_content" {
            mr_shared_interactions = {
                visible = "[Not(GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"

                blockoverride "tabs" {
                    tab_buttons = {
                        maximumsize = { @[ panel_button_width + 20 ] 0 }
                        margin_bottom = -4
                        blockoverride "first_button" {
                            text = mr_science_archaeologist_tab_expedition
                        }
                        blockoverride "first_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_science_archaeologist_tab', 'expedition')]"
                        }
                        blockoverride "first_button_visibility" {
                            visible = "[Or(GetVariableSystem.HasValue('mr_science_archaeologist_tab', 'expedition'), Not(GetVariableSystem.Exists('mr_science_archaeologist_tab')))]"
                        }
                        blockoverride "first_button_visibility_checked" {
                            visible = "[And(Not(GetVariableSystem.HasValue('mr_science_archaeologist_tab', 'expedition')), GetVariableSystem.Exists('mr_science_archaeologist_tab'))]"
                        }
                        blockoverride "first_button_selected" {
                            text = mr_science_archaeologist_tab_expedition
                        }

                        blockoverride "second_button" {
                            text = mr_science_archaeologist_tab_organization
                        }
                        blockoverride "second_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_science_archaeologist_tab', 'organization')]"
                        }
                        blockoverride "second_button_visibility" {
                            visible = "[GetVariableSystem.HasValue('mr_science_archaeologist_tab', 'organization')]"
                        }
                        blockoverride "second_button_visibility_checked" {
                            visible = "[Not(GetVariableSystem.HasValue('mr_science_archaeologist_tab', 'organization'))]"
                        }
                        blockoverride "second_button_selected" {
                            text = mr_science_archaeologist_tab_organization
                        }
                    }
                }
                blockoverride "tab_content" {
                    vbox = {
                        visible = "[Or(GetVariableSystem.HasValue('mr_science_archaeologist_tab', 'expedition'), Not(GetVariableSystem.Exists('mr_science_archaeologist_tab')))]"
                        layoutpolicy_vertical = expanding
                        spacing = 7
                        minimumsize = { @panel_button_width 0 }

                        widget = {
                            size = { @[ panel_button_width - 20 ] 0 }
                        }

                        hbox = {
                            layoutpolicy_vertical = expanding
                            layoutpolicy_horizontal = expanding
                            spacing = 5

                            vbox = {
                                layoutpolicy_vertical = expanding
                                spacing = 5

                                # Upper Egypt
                                mr_shared_round_button = {
                                    datacontext = "[GetScriptedGui('mr_upper_egypt_expedition_button_sgui')]"
                                    tooltip = "MR_UPPER_EGYPT_EXPEDITION_TT"
