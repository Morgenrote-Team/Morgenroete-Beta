						}

						# Improve Synthetics
						mr_academic_project_button = {
							text = "mr_science_chemist_synthetics_button_text"
							datacontext = "[GetScriptedGui('mr_chemist_synthetics_button')]"
							tooltip = "MR_CHEMIST_SYNTHETICS_BUTTON"
						}

						# Synthetic Oil
						mr_academic_project_button = {
							text = "MR_CHEMIST_SYNTHETIC_OIL_BUTTON"
							datacontext = "[GetScriptedGui('mr_chemist_synthetic_oil_button')]"
