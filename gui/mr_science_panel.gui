            mr_shared_interactions_simple = {
                visible = "[GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"

                blockoverride "content" {
                    margin_bottom = 20
                    hbox = {
                        spacing = 4

                        # Searching the Skies
                        widget = {
                            size = { 50 50 }

                            #Button when it is not active
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_astronomer_searching_the_skies_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_ASTRONOMER_SEARCHING_THE_SKIES_BUTTON_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_astronomer_searching_the_skies_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }

                            # Three Icons for when it is active (normal color plus highlight circle)
                            #highlight circle to indicate that it is currently active
                            icon = {
                                parentanchor = center
                                size = { 100% 100% }
                                using = highlighted_circle_selection_small
                                visible = "[GetScriptedGui('mr_astronomer_searching_the_skies_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                        }

                        # Search for Satellites
                        widget = {
                            size = { 50 50 }

                            #Button when it is not active
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_astronomer_discover_satellites_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_ASTRONOMER_DISCOVER_SATELLITES_BUTTON_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_astronomer_satellites_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }

                            # Three Icons for when it is active (normal color plus highlight circle)
                            #highlight circle to indicate that it is currently active
                            icon = {
                                parentanchor = center
                                size = { 100% 100% }
                                using = highlighted_circle_selection_small
                                visible = "[GetScriptedGui('mr_astronomer_discover_satellites_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                            #Button background
                            icon = {
                                parentanchor = center
                                size = { 45 45 }
                                texture = "gfx/interface/buttons/round_button_small_wood.dds"
                                visible = "[GetScriptedGui('mr_astronomer_discover_satellites_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"

                                tooltip = "MR_ASTRONOMER_DISCOVER_SATELLITES_ACTIVE_TT"
                            }
                            #Button Icon
                            icon = {
                                parentanchor = center
                                size = { 34 34 }
                                texture = "gfx/interface/icons/GUI_icons/GUI_astronomer_satellites_button.dds"
                                visible = "[GetScriptedGui('mr_astronomer_discover_satellites_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                        }

                        # Moon Photos
                        widget = {
                            size = { 50 50 }

                            #Button when it is not active
                            button_icon_round = {
                                parentanchor = center
                                size = { 45 45 }

                                datacontext = "[GetScriptedGui('mr_astronomer_moon_map_button_sgui')]"
                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
                                tooltip = "MR_ASTRONOMER_MOON_MAP_BUTTON_TT"
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/GUI_icons/GUI_astronomer_moon_map_button.dds"
                                }
                                blockoverride "icon_size" {
                                    size = { 75% 75% }
                                }
                            }

                            # Three Icons for when it is active (normal color plus highlight circle)
                            #highlight circle to indicate that it is currently active
                            icon = {
                                parentanchor = center
                                size = { 100% 100% }
                                using = highlighted_circle_selection_small
                                visible = "[GetScriptedGui('mr_astronomer_moon_map_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                            #Button background
                            icon = {
                                parentanchor = center
                                size = { 45 45 }
                                texture = "gfx/interface/buttons/round_button_small_wood.dds"
                                visible = "[GetScriptedGui('mr_astronomer_moon_map_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"

                                tooltip = "MR_ASTRONOMER_MOON_MAP_ACTIVE_TT"
                            }
                            #Button Icon
                            icon = {
                                parentanchor = center
                                size = { 34 34 }
                                texture = "gfx/interface/icons/GUI_icons/GUI_astronomer_moon_map_button.dds"
                                visible = "[GetScriptedGui('mr_astronomer_moon_map_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                        }

                    }

                    expand = {}

                    # Congress on Asteroids
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_asteroid_congress_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_ASTEROID_CONGRESS_BUTTON"
                            tooltip = "MR_ASTEROID_CONGRESS_BUTTON_TT"
                        }
                    }

                    # Carte de Ciel
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_carte_congress_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_CARTE_DE_CIEL_CONGRESS_BUTTON"
                            tooltip = "MR_CARTE_DE_CIEL_CONGRESS_BUTTON_TT"
                        }
                    }

                    # Great Debate
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_great_debate_congress_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_GREAT_DEBATE_CONGRESS_BUTTON"
                            tooltip = "MR_GREAT_DEBATE_CONGRESS_BUTTON_TT"
                        }
                    }

                    # Standard Time
                    mr_shared_project_button = {
                        datacontext = "[GetScriptedGui('mr_standard_time_button_sgui')]"
                        blockoverride "button_content" {
                            text = "MR_STANDARD_TIME_BUTTON"
                            tooltip = "MR_STANDARD_TIME_BUTTON_TT"
                        }
