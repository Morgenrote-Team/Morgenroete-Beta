	type mr_academic_general = vbox {
		layoutpolicy_horizontal = expanding

		using = entry_bg_fancy

		default_header_clean = {
			blockoverride "header_mask" {
				using = frame_small_mask_top
			}
			blockoverride "size" {
				layoutpolicy_horizontal = growing
				size = { 0 50 }
			}

			blockoverride "textbox" {
				hbox = {
					margin = { 20 0 }

					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 40 }
						block "general_header_text" {
							raw_text = "general_header_text"
							default_format = "#r"
						}
						using = fontsize_large
						align = center
						elide = right
					}
				}
			}
		}

		hbox = {
			margin = { 20 20 }
			spacing = 20
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			hbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				margin = { 20 20 }
				background = {
					using = entry_bg_simple
				}

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding

					block "big_box_content" {}
				}
			}

			vbox = {
				layoutpolicy_vertical = expanding
				background = {
					using = simple_frame
				}

				block "center_box_content" {
					visible = no
				}
			}

			vbox = {
				layoutpolicy_vertical = expanding
				margin = { 20 20 }
				minimumsize = { 400 -1 }
				maximumsize = { 400 -1 }
				background = {
					using = simple_frame
				}

				block "small_box_content" {}
			}
		}
	}

