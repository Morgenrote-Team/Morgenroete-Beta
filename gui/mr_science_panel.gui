                    }
                    blockoverride "text_6" {
                        raw_text = "GEOLOGY_GEOLOGIST_RANKING_HEADER"
                    }
                    blockoverride "ranking_6_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_geology_ranking', 'geologist_ranking')]"
                    }
                    blockoverride "ranking_6_datamodel" {
                        datamodel = "[GetGlobalList('mr_geologist_ranking_global_list')]"
                    }
                    blockoverride "ranking_6_datacontext"{
                        datacontext = "[Scope.GetCharacter]"
                    }
                    blockoverride "ranking_6_text_column_2"{
                        raw_text = "#tooltip:[GetRawTextTooltipTag('agassiz_official_geologist_rating_tt_loc')] [Character.GetCustom('agassiz_geologist_rating_new_geologist_icon_type')] #! [Character.GetFullName]"
                    }
                    blockoverride "ranking_variable_used_6" {
                        raw_text = "[Character.MakeScope.GetVariable('agassiz_geologist_experience_var').GetValue|V0]"
                    }
                }
            }
        }
        blockoverride "occupation_data_header_text" {
            text = mr_science_geologist_data_header
        }
        blockoverride "occupation_data_content" {
            mr_shared_data_text = {
                #Age of the Earth
                text = "AGE_OF_EARTH_VAR"
                tooltip = "AGE_OF_EARTH_VAR_TT"
            }
            mr_shared_data_text = {
                #Geological Knowledge
                text = "TOTAL_GEOLOGICAL_KNOWLEDGE_VAR"
                tooltip = "TOTAL_GEOLOGICAL_KNOWLEDGE_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
            mr_shared_data_text = {
                #Oceanographic Knowledge
                text = "OCEANOGRAPHIC_UNDERSTANDING_VAR"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
            mr_shared_data_text = {
                #Number of Minerals
                text = "TOTAL_MINERALS_VAR"
                tooltip = "TOTAL_MINERALS_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
            mr_shared_data_text = {
                #Number of Rare Minerals
                text = "TOTAL_RARE_MINERALS_VAR"
                tooltip = "TOTAL_RARE_MINERALS_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
        }
        blockoverride "visit_button" {
            text = "VISIT_MINERAL_CABINET_BUTTON"
            datacontext = "[GetScriptedGui('mr_visit_mineral_cabinet_sgui')]"
            onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
            tooltip = "VISIT_MINERAL_CABINET_BUTTON_TT"
        }
        blockoverride "big_box_content" {
            mr_shared_interactions = {
                visible = "[Not(GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"

                blockoverride "tabs" {
                    tab_buttons = {
                        maximumsize = { @[ panel_button_width + 20 ] 0 }
                        margin_bottom = -4
                        blockoverride "first_button" {
                            text = mr_science_geologist_tab_research
                        }
                        blockoverride "first_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_science_geologist_tab', 'research')]"
                        }
                        blockoverride "first_button_visibility" {
                            visible = "[Or(GetVariableSystem.HasValue('mr_science_geologist_tab', 'research'), Not(GetVariableSystem.Exists('mr_science_geologist_tab')))]"
                        }
                        blockoverride "first_button_visibility_checked" {
                            visible = "[And(Not(GetVariableSystem.HasValue('mr_science_geologist_tab', 'research')), GetVariableSystem.Exists('mr_science_geologist_tab'))]"
                        }
                        blockoverride "first_button_selected" {
                            text = mr_science_geologist_tab_research
                        }

                        blockoverride "second_button" {
                            text = mr_science_geologist_tab_industry
                        }
                        blockoverride "second_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_science_geologist_tab', 'industry')]"
                        }
                        blockoverride "second_button_visibility" {
                            visible = "[GetVariableSystem.HasValue('mr_science_geologist_tab', 'industry')]"
                        }
                        blockoverride "second_button_visibility_checked" {
                            visible = "[Not(GetVariableSystem.HasValue('mr_science_geologist_tab', 'industry'))]"
                        }
                        blockoverride "second_button_selected" {
                            text = mr_science_geologist_tab_industry
                        }

