    type mr_academic_biologist = mr_shared_occupation {
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('theiler_biologist_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/theiler_biologist_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_theiler_biologist_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "BIOLOGIST_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('academics_has_biologist_gui_type')]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = "MR_BIOLOGIST_ACHIEVEMENTS_TT"
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('theiler_biologist_experience_var').GetValue]"
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_theiler_biologist_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_theiler_biologist_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_biologist_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_biologist_ranking', 'microorganisms')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_biologist_ranking', 'microorganisms') )]"
                        text = "MR_MICROORGANISMS"
                        tooltip = "MR_RANKING_BY_MICROORGANISMS"

                        onclick = "[GetVariableSystem.Set('mr_biologist_ranking', 'microorganisms')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "BIOLOGIST_MICROORGANISMS_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_biologist_ranking', 'microorganisms')]"
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_microorganisms_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
                        raw_text = "[Country.MakeScope.GetVariable('theiler_microorganisms_var').GetValue|V*0]"
                    }
                }
            }
        }
        blockoverride "occupation_data_header_text" {
            text = mr_science_biologist_data_header
        }
        blockoverride "occupation_data_content" {
            mr_shared_data_text = {
                # Microorganisms
                text = "THEILER_BIOLOGIST_MICROORGANISMS_VAR"
                tooltip = "THEILER_BIOLOGIST_MICROORGANISMS_VAR_TT"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
        }
        blockoverride "extra_button" {
            # Start Automation
            mr_shared_project_button = {
                datacontext = "[GetScriptedGui('mr_biologist_automation_gui')]"
                blockoverride "size" {
                    size = { 100% 100% }
                }
                blockoverride "button_content" {
                    text = "mr_science_general_project_automation"
                    tooltip = "MR_AUTOMATE_BIOLOGIST_TT"
                    using = fontsize_large
                }
            }
            # Stop Automation
            mr_shared_project_button = {
                datacontext = "[GetScriptedGui('mr_stop_biologist_automation_gui')]"
                blockoverride "size" {
                    size = { 100% 100% }
                }
                blockoverride "button_content" {
                    text = "mr_science_general_project_automation_stop"
                    tooltip = "MR_STOP_AUTOMATE_BIOLOGIST_TT"
                    using = fontsize_large
                }
                blockoverride "button_highlight_visible" {
                    visible = yes
                }
            }
        }
        blockoverride "visit_button" {
            text = "VISIT_MEDICINE_BUTTON"
            onclick = "[GetVariableSystem.Set('com_open_window', 'mr_academic_medicine')]"
            tooltip = "VISIT_MEDICINE_BUTTON_TT"
        }
        blockoverride "big_box_content" {
            mr_shared_interactions = {
                visible = "[Not(GetScriptedGui('mr_setting_academic_compact_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"

                blockoverride "tabs" {
                    tab_buttons = {
                        maximumsize = { @[ panel_button_width + 20 ] 0 }
                        margin_bottom = -4
                        blockoverride "first_button" {
                            text = mr_science_biologist_tab_microbiology
                        }
                        blockoverride "first_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_science_biologist_tab', 'microbiology')]"
                        }
                        blockoverride "first_button_visibility" {
                            visible = "[Or(GetVariableSystem.HasValue('mr_science_biologist_tab', 'microbiology'), Not(GetVariableSystem.Exists('mr_science_biologist_tab')))]"
                        }
                        blockoverride "first_button_visibility_checked" {
                            visible = "[And(Not(GetVariableSystem.HasValue('mr_science_biologist_tab', 'microbiology')), GetVariableSystem.Exists('mr_science_biologist_tab'))]"
                        }
                        blockoverride "first_button_selected" {
                            text = mr_science_biologist_tab_microbiology
                        }

                        blockoverride "second_button" {
                            text = mr_science_biologist_tab_biology
                        }
                        blockoverride "second_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_science_biologist_tab', 'biology')]"
                        }
                        blockoverride "second_button_visibility" {
                            visible = "[GetVariableSystem.HasValue('mr_science_biologist_tab', 'biology')]"
                        }
                        blockoverride "second_button_visibility_checked" {
                            visible = "[Not(GetVariableSystem.HasValue('mr_science_biologist_tab', 'biology'))]"
                        }
                        blockoverride "second_button_selected" {
                            text = mr_science_biologist_tab_biology
                        }
                    }
                }
