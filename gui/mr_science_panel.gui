                                texture = "gfx/interface/icons/GUI_icons/GUI_lepsius_identify_fossils_button.dds"
                                visible = "[GetScriptedGui('mr_fossil_identification_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
                            }
                        }
