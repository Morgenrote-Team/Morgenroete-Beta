    type mr_artist_painter = mr_shared_occupation {
        layoutpolicy_horizontal = expanding
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('klimt_painter_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/klimt_painter_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_klimt_painter_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "PAINTER_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('artists_has_painter_gui_type')]"
        }
        blockoverride "character_animation" {
            portrait_texture = "[Character.GetAnimatedPortrait('characters_portrait_environment', 'mr_camera_torso_painter', 'idle', GetPortraitRenderSize(PdxGuiWidget.Self))]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = "MR_PAINTER_ACHIEVEMENTS_TT"
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('klimt_painter_experience').GetValue]"
        }
        blockoverride "occupation_experience_range" {
            min = 0
            max = 500
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_klimt_painter_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_klimt_painter_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_painting_tradition_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_painter_ranking', 'painting_tradition')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_painter_ranking', 'painting_tradition') )]"
                        text = "MR_PAINTING_TRADITION_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_PAINTING_TRADITION"

                        onclick = "[GetVariableSystem.Set('mr_painter_ranking', 'painting_tradition')]"
                    }
                    blockoverride "button_2_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_painter_ranking', 'painter_ranking') )]"
                        text = "MR_PAINTER_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_PAINTER"

                        onclick = "[GetVariableSystem.Set('mr_painter_ranking', 'painter_ranking')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "PAINTER_PAINTING_TRADITION_RANKING_HEADER"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_painter_ranking', 'painting_tradition')]"
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_painting_tradition_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
                        raw_text = "[Country.MakeScope.GetVariable('klimt_painting_tradition_var').GetValue|*V0]"
                    }
                    blockoverride "text_2" {
                        raw_text = "PAINTER_PAINTER_RANKING_HEADER"
                    }
                    blockoverride "ranking_2_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_painter_ranking', 'painter_ranking')]"
                    }
                    blockoverride "ranking_2_datamodel" {
                        datamodel = "[GetGlobalList('mr_painter_ranking_global_list')]"
                    }
                    blockoverride "ranking_2_datacontext"{
                        datacontext = "[Scope.GetCharacter]"
                    }
                    blockoverride "ranking_2_text_column_2"{
                        raw_text = "#tooltip:[GetRawTextTooltipTag('klimt_official_painter_rating_tt_loc')] [Character.GetCustom('klimt_painter_rating_new_painter_icon_type')] #! [Character.GetFullName]"
                    }
                    blockoverride "ranking_variable_used_2" {
                        raw_text = "[Character.MakeScope.GetVariable('klimt_painter_experience').GetValue|V0]"
                    }
                }
            }
        }
        blockoverride "occupation_data_size" {
            size = { @panel_text_width 440 }
        }
        blockoverride "occupation_data_header_text" {
            text = mr_artist_painter_data_header
        }
        blockoverride "occupation_data_content" {
            hbox = {
                spacing = 8

                # Painting Tradition
                mr_shared_data_text = {
                    text = "PAINTING_TRADITION_VAR"
                    tooltip = "PAINTING_TRADITION_VAR_TT"
                    blockoverride "font_size" {
                        using = fontsize_xxl
                    }
                }

                # Yearly Painting Tradition
                mr_shared_data_text = {
                    text = "MR_YEARLY_PAINTING_TRADITION"
                    tooltip = "MR_YEARLY_PAINTING_TRADITION_TT"
                    blockoverride "font_size" {
                        using = fontsize_xxl
                    }
                }

                expand = {}
