                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_writer_reading_tour_button.dds"
                            }
                        }
                        # Write text for a National Anthem
                        mr_shared_project_button = {
                            datacontext = "[GetScriptedGui('mr_anthem_text_button_sgui')]"
                            blockoverride "button_content" {
                                text = "MR_ANTHEM_TEXT_BUTTON"
                                tooltip = "MR_ANTHEM_TEXT_BUTTON_TT"
                            }
                            blockoverride "size" {
                                size = { @[ panel_button_width - 20 ] 45 }
                            }
                        }

                        expand = {}
                    }
                }
                blockoverride "stop_context" {
                    datacontext = "[GetScriptedGui('mr_stop_writer_project_button_sgui')]"
                }
