                blockoverride "size" {
                    layoutpolicy_horizontal = growing
                }
                text = "MR_TOTAL_MASTERWORKS_COUNTRY"
                tooltip = "MR_TOTAL_MASTERWORKS_COUNTRY_TT"
            }
        }
        blockoverride "visit_button" {
