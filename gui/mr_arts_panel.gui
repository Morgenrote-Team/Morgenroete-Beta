                    value = "[FixedPointToFloat(Character.MakeScope.GetVariable('manzoni_writer_experience').GetValue)]"
                }
                blockoverride "artist_character_name" {
                    text = "[Character.GetCustom('manzoni_writer_rating_new_writer_icon_type')] [Character.GetLastName]"
                }
                blockoverride "artist_character_experience_tooltip" {
                    tooltip = "MR_TRAVELLING_COMPOSER_EXPERIENCE_TOOLTIP"
                }
                blockoverride "artist_character_experience_bar_text" {
                    text = "[Character.GetCustom('GUI_manzoni_local_writer_experience_text_type')]"
                }
                blockoverride "artist_character_interaction" {
                    datacontext = "[GetScriptedGui('mr_invite_writer_button_sgui')]"
                    onclick = "[ScriptedGui.Execute(GuiScope.SetRoot(Country.MakeScope).AddScope('chosen_writer', Scope.GetCharacter.MakeScope).End)]"
                    enabled = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).AddScope('chosen_writer', Scope.GetCharacter.MakeScope).End)]"
                    text = "MR_INVITE_WRITER_BUTTON"
                    tooltip = "MR_INVITE_WRITER_BUTTON_TT"
                }
