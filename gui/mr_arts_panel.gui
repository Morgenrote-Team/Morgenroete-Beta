                            datacontext = "[GetScriptedGui('mr_reading_tour_button_sgui')]"
                            blockoverride "button_content" {
                                text = "mr_artist_writer_reading_tour_button_text"
                                tooltip = "MR_READING_TOUR_BUTTON_TT"
                            }
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
