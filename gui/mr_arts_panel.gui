    type mr_artist_character_box = hbox {
        layoutpolicy_horizontal = expanding
        layoutpolicy_vertical = expanding

        background = {
            using = simple_frame
        }

        vbox = {
            layoutpolicy_horizontal = expanding
            layoutpolicy_vertical = expanding
            margin = { 15 15 }
            margin_top = 0

            default_header_clean_faded = {
                layoutpolicy_horizontal = expanding
                blockoverride "text" {
                    block "artist_characters_header" {
                        raw_text = "artist_characters_header"
                        default_format = "#r"
                    }
                }
            }

            fullscreen_scrollarea = {
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding

                scrollbarpolicy_horizontal = as_needed
                scrollbarpolicy_vertical = always_off

                background = {}

                scrollbar_horizontal = {
                    using = Scrollbar_Horizontal
                }

                blockoverride "scrollarea_content" {
                    hbox = {
                        margin_bottom = 15
                        layoutpolicy_horizontal = expanding
                        layoutpolicy_vertical = expanding
                        spacing = 18
                        block "artist_character_list" {
                            textbox = {
                                layoutpolicy_horizontal = expanding
                                layoutpolicy_vertical = expanding
                                raw_text = "artist_character_list"
                                default_format = "#r"
                                align = center
                                autoresize = yes
                                using = fontsize_mega
                            }
                            #datamodel = "[GetGlobalList('mr_travelling_composer_global_list')]"
                        }

                        item = {
                            vbox = {
                                spacing = 10
                                margin = { 10 10 }
                                minimumsize = { 220 340 }
                                datacontext = "[Scope.GetCharacter]"
                                using = entry_bg_fancy
                                block "artist_character_visible" {}

                                # Character Portrait
                                character_portrait_medium_torso = {
                                    blockoverride "show_hat" {}
                                }

                                # Name
                                default_header_clean_faded = {
                                    size = { 160 40 }
                                    blockoverride "text" {
                                        block "artist_character_name" {
                                            text = "[Character.GetLastName]"
                                        }
                                    }
                                }

                                # Experience
                                green_progressbar_horizontal = {
                                    size = { 160 25 }
                                    blockoverride "values" {
                                        block "artist_character_experience_range" {
                                            min = 0
                                            max = 500
                                        }
                                        block "artist_character_experience_value" {
                                            value = 0
                                        }
                                        block "artist_character_experience_tooltip" {}
                                    }
                                    textbox = {
                                        block "artist_character_experience_bar_text" {
                                            raw_text = "Undefined"
                                            default_format = "#r"
                                        }
                                        parentanchor = center
                                        autoresize = yes
                                        using = fontsize_large
                                    }
                                }

                                button = {
                                    # Invite Composer
                                    using = default_button_primary_big_action
                                    size = { 170 40 }
                                    using = fontsize_medium
                                    block "artist_character_interaction" {
                                        raw_text = "Undefined"
                                        default_format = "#r"
                                        onclick = "[ScriptedGui.Execute(GuiScope.SetRoot(Country.MakeScope).AddScope('chosen_composer', Scope.GetCharacter.MakeScope).End)]"
                                        enabled = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).AddScope('chosen_composer', Scope.GetCharacter.MakeScope).End)]"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    type mr_artist_cultural_tradition_button = button {
        block "button_context" {}
        size = { 200 300 }
        enabled = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).End)]"
        onclick = "[ScriptedGui.Execute(GuiScope.SetRoot(Country.MakeScope).End)]"

        # Glow when available
        widget = {
            visible = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).End)]"
            size = { 215 315 }
            parentanchor = center
            icon = {
                name = ui_event_glow_animation
                using = ui_event_glow
                using = frame_small_mask
                alpha = 0

                state = {
                    trigger_on_create = yes
                    name = 1
                    next = 2
                    alpha = 0.4
                    duration = 1
                    using = Animation_Curve_Default
                }
                state = {
                    name = 2
                    next = 1
                    alpha = 0.05
                    duration = 1
                    using = Animation_Curve_Default
                }
            }
        }

        mr_artist_cultural_tradition = {
            blockoverride "context" {
                block "button_context" {}
            }
        }

        state = {
            name = _mouse_enter
            on_start = "[PdxGuiWidget.FindChild('background').TriggerAnimation('enter')]"
        }

        state = {
            name = _mouse_leave
            on_start = "[PdxGuiWidget.FindChild('background').TriggerAnimation('leave')]"
        }

        icon = {
            name = background
            size = { 200 300 }
            visible = "[ScriptedGui.IsValid(GuiScope.SetRoot(Country.MakeScope).End)]"
            texture = "gfx/interface/buttons/glow_button_border.dds"
            spriteType = CorneredStretched
            framesize = { 150 150 }
            spriteborder = { 60 60 }
            frame = 3
            using = frame_small_mask
            alpha = 0
            state = {
                name = "enter"
                alpha = 1
            }
            state = {
                name = "leave"
                alpha = 0
            }
        }
    }

    type mr_artist_cultural_tradition = widget {
        size = { 200 300 }
        block "context" {}
        block "tradition_tooltip" {}
        background = {
            using = frame_small
        }

        widget = {
            size = { 100% 100% }

            background = {
                block "tradition_background" {
                    #texture = "gfx/interface/icons/objectives/sandbox.dds"
                }
                fittype = centercrop
                spriteType = Corneredstretched
                using = frame_small_mask
            }

            background = {
                visible = "[ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                texture = "gfx/frontend/interface/colors/black.dds"
                fittype = centercrop
                spriteType = Corneredstretched
                alpha = 0.8
                using = frame_small_mask
            }

            background = {
                using = frame_small
            }
        }

        widget = {
            visible = "[Not(ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"
            size = { 100% 100% }
            parentanchor = center
            block "tooltip_active" {}
        }

        widget = {
            visible = "[ScriptedGui.IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
            size = { 100% 100% }
            parentanchor = center
            block "tooltip_inactive" {}
        }

        default_header_clean = {
            parentanchor = top
            layoutpolicy_horizontal = expanding
            blockoverride "text" {
                block "tradition_header" {
                    raw_text = "tradition_header"
                    default_format = "#r"
                }
            }
            blockoverride "header_mask" {
                using = frame_small_mask_top
            }
            blockoverride "size" {
                size = { 100% 50 }
            }
        }
    }

    type mr_arts_nation = mr_shared_basic_box {
