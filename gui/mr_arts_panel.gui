@panel_button_width = 370
@panel_text_width = 300

types mr_main_arts_panel_types {

    type mr_arts_panel = fullscreen_block_window {
        name = "mr_arts_panel"
        datacontext = "[GetMetaPlayer.GetPlayedOrObservedCountry]"

        background = {
            using = illu_alpha
            fittype = center
            texture = "gfx/interface/illustrations/tech_tree/illustration_tech_society.dds"
            using = default_content_fade
        }

        visible = "[GetVariableSystem.HasValue('com_open_window', 'mr_sidebar_button_arts_sgui')]"

        blockoverride "animation_state_block" {
            state = {
                name = _show
                # Close open panel before showing this one
                on_start = "[InformationPanelBar.ClosePanel]"
                on_start = "[MapListPanelManager.CloseCurrentPanel]"
                # Fullscreen panels hide topbar
                on_finish = "[GetVariableSystem.Set('com_fullscreen', 'com_fullscreen')]"
                start_sound = {
                    soundeffect = "event:/SFX/UI/SideBar/markets"
                }
                start_sound = {
                    soundeffect = "snapshot:/Dynamic/mute_world_80"
                }
                start_sound = {
                    soundeffect = "snapshot:/Dynamic/mute_vfx_war_100"
                }
            }

            state = {
                name = _hide
                on_start = "[GetVariableSystem.Clear('com_fullscreen')]"
                on_finish = "[GetVariableSystem.Clear('mr_arts_tab')]"
                start_sound = {
                    soundeffect = "event:/SFX/UI/SideBar/markets_stop"
                }
            }
        }

        blockoverride "window_header_name" {
            text = ARTS_VIEW_NAME
            default_format = "#bold"
        }

        blockoverride "back_button_fullscreen" {
            back_button_large = {
                position = { 11 15 }
                parentanchor = top|left
                onclick = "[GetVariableSystem.Clear('com_open_window')]"
                onclick = "[GetVariableSystem.Clear('com_alert_action')]"
                onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
                input_action = "back"
            }
        }

        close_button_large = {
            name = "tutorial_highlight_close_button"
            parentanchor = top|right
            onclick = "[GetVariableSystem.Clear('com_open_window')]"
            onclick = "[GetVariableSystem.Clear('com_alert_action')]"
            onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
            shortcut = "close_window"
            position = { -56 115 }
        }

        blockoverride "close_button_position" {
            visible = no
        }

        blockoverride "fixed_top" {
            tab_buttons_fullscreen = {
                name = "mr_tutorial_highlight_arts_tab_bar"
                # General
                blockoverride "first_button" {
                    text = "mr_arts_tab_general"
                }
                blockoverride "first_button_background" {
                    background = {
                        margin = { 0 -2 }
                        using = fade_bottom_entry_fancy_header_colored
                        using = Color_Purple
                        alpha = 0.5
                    }
                }
                blockoverride "first_button_click" {
                    onclick = "[GetVariableSystem.Set('mr_arts_tab', 'main')]"
                }
                blockoverride "first_button_visibility" {
                    visible = "[Or(
									GetVariableSystem.HasValue('mr_arts_tab', 'main'),
									Not(GetVariableSystem.Exists('mr_arts_tab'))
								)]"
                }
                blockoverride "first_button_visibility_checked" {
                    visible = "[And(
									Not(GetVariableSystem.HasValue('mr_arts_tab', 'main')),
									GetVariableSystem.Exists('mr_arts_tab')
								)]"
                }
                blockoverride "first_button_selected" {
                    text = "mr_arts_tab_general"
                }
                blockoverride "first_button_background_selected" {
                    background = {
                        using = fade_bottom_entry_fancy_header_colored
                        using = Color_Purple
                        alpha = 0.5
                    }
                }

                # Artists
                blockoverride "second_button" {
                    name = "mr_tutorial_highlight_arts_tab_artists"
                    text = "mr_arts_tab_artists"
                }
                blockoverride "second_button_background" {
                    background = {
                        margin = { 0 -2 }
                        using = fade_bottom_entry_fancy_header_colored
                        using = Color_Purple
                        alpha = 0.5
                    }
                }
                blockoverride "second_button_click" {
                    onclick = "[GetVariableSystem.Set('mr_arts_tab', 'artists')]"
                }
                blockoverride "second_button_visibility" {
                    visible = "[GetVariableSystem.HasValue('mr_arts_tab', 'artists')]"
                }
                blockoverride "second_button_visibility_checked" {
                    visible = "[Not(GetVariableSystem.HasValue('mr_arts_tab', 'artists'))]"
                }
                blockoverride "second_button_selected" {
                    text = "mr_arts_tab_artists"
                }
                blockoverride "second_button_background_selected" {
                    background = {
                        using = fade_bottom_entry_fancy_header_colored
                        using = Color_Purple
                        alpha = 0.5
                    }
                }
            }
        }

        blockoverride "scrollarea_content" {
            vbox = {
                layoutpolicy_vertical = expanding
                layoutpolicy_horizontal = expanding

                mr_shared_tab_fullscreen = {
                    blockoverride "view_visibility" {
                        visible = "[Or(GetVariableSystem.HasValue('mr_arts_tab', 'main'), Not(GetVariableSystem.Exists('mr_arts_tab')))]"
                    }
                    blockoverride "view_content" {
                        hbox = {
                            layoutpolicy_horizontal = expanding
                            spacing = 10
                            mr_arts_nation = {}
                            expand = {}
                            mr_arts_promote = {}
                        }
                        mr_cultural_traditions = {}
                    }
                }

                mr_shared_tab_fullscreen = {
                    blockoverride "view_visibility" {
                        visible = "[GetVariableSystem.HasValue('mr_arts_tab', 'artists')]"
                    }
                    blockoverride "view_content" {
                        mr_artist_architect = {}
                        mr_artist_composer = {}
                        mr_artist_writer = {}
                        mr_artist_painter = {}
                    }
                }
            }
        }
    }

    type mr_artist_architect = mr_shared_occupation {
        layoutpolicy_horizontal = expanding
        blockoverride "occupation_character_context" {
            datacontext = "[Country.MakeScope.Var('gaudi_architect_var')]"
        }
        blockoverride "occupation_role_icon" {
            texture = "gfx/interface/icons/character_role_icons/gaudi_architect_role.dds"
        }
        blockoverride "occupation_role_tooltip" {
            tooltip = "[concept_gaudi_architect_desc]"
        }
        blockoverride "occupation_role_name" {
            text = "MR_ARCHITECT_HEADER_TEXT"
        }
        blockoverride "occupation_character_name" {
            text = "[Country.GetCustom('artists_has_architect_gui_type')]"
        }
        blockoverride "character_animation" {
            portrait_texture = "[Character.GetAnimatedPortrait('characters_portrait_environment', 'mr_camera_torso_architect', 'idle', GetPortraitRenderSize(PdxGuiWidget.Self))]"
        }
        blockoverride "occupation_achievement_tooltip" {
            tooltip = "MR_ARCHITECT_ACHIEVEMENTS_TT"
        }
        blockoverride "occupation_experience_value" {
            value = "[Scope.Var('gaudi_architect_experience').GetValue]"
        }
        blockoverride "occupation_experience_range" {
            min = 0
            max = 500
        }
        blockoverride "occupation_experience_tooltip" {
            tooltip = "[Country.GetCustom('GUI_gaudi_architect_experience_type')]"
        }
        blockoverride "occupation_experience_bar_text" {
            text = "[Country.GetCustom('GUI_gaudi_architect_experience_text_type')]"
        }
        blockoverride "occupation_ranking_visible" {
            visible = yes
        }
        blockoverride "occupation_ranking" {
            tooltipwidget = {
                MR_TooltipRankingType = {
                    blockoverride "ranking_on_finish" {
                        on_finish = "[GetScriptedGui('mr_architect_ranking_sgui').Execute( GuiScope.SetRoot( Country.MakeScope ).End )]" #Resets the Ranking
                        on_finish = "[GetVariableSystem.Set('mr_arts_architect_ranking', 'architectural_splendour')]"
                    }
                    blockoverride "buttons_visible" {
                        visible = yes
                    }
                    blockoverride "button_1_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_arts_architect_ranking', 'architectural_splendour') )]"
                        text = "MR_ARCHITECT_ARCHITECTURAL_SPLENDOUR"
                        tooltip = "MR_ARCHITECT_ARCHITECTURAL_SPLENDOUR_TT"

                        onclick = "[GetVariableSystem.Set('mr_arts_architect_ranking', 'architectural_splendour')]"
                    }
                    blockoverride "button_2_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_arts_architect_ranking', 'blueprints') )]"
                        text = "MR_ARCHITECT_BLUEPRINTS"
                        tooltip = "MR_ARCHITECT_BLUEPRINTS_TT"

                        onclick = "[GetVariableSystem.Set('mr_arts_architect_ranking', 'blueprints')]"
                    }
                    blockoverride "button_3_content" {
                        enabled = "[Not( GetVariableSystem.HasValue('mr_arts_architect_ranking', 'architect_ranking') )]"
                        text = "MR_ARCHITECT_RANKING_BUTTON"
                        tooltip = "MR_RANKING_BY_ARCHITECT"

                        onclick = "[GetVariableSystem.Set('mr_arts_architect_ranking', 'architect_ranking')]"
                    }
                    blockoverride "text_1" {
                        raw_text = "MR_ARCHITECT_ARCHITECTURAL_SPLENDOUR_RANKING_HEADER"
                        visible = "[GetVariableSystem.HasValue('mr_arts_architect_ranking', 'architectural_splendour')]"
                    }
                    blockoverride "ranking_1_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_arts_architect_ranking', 'architectural_splendour')]"
                    }
                    blockoverride "ranking_1_datamodel" {
                        datamodel = "[GetGlobalList('mr_architect_architectural_splendour_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_1" {
                        raw_text = "[Country.MakeScope.GetVariable('gaudi_architectural_splendour_var').GetValue|*V0]"
                    }
                    blockoverride "text_2" {
                        raw_text = "MR_ARCHITECT_BLUEPRINTS_RANKING_HEADER"
                    }
                    blockoverride "ranking_2_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_arts_architect_ranking', 'blueprints')]"
                    }
                    blockoverride "ranking_2_datamodel" {
                        datamodel = "[GetGlobalList('mr_architect_blueprints_ranking_global_list')]"
                    }
                    blockoverride "ranking_variable_used_2" {
                        raw_text = "[Country.MakeScope.GetVariable('gaudi_country_num_blueprints_var').GetValue|*V0]"
                    }
                    blockoverride "text_3" {
                        raw_text = "ARCHITECT_ARCHITECT_RANKING_HEADER"
                    }
                    blockoverride "ranking_3_visible" {
                        visible = "[GetVariableSystem.HasValue('mr_arts_architect_ranking', 'architect_ranking')]"
                    }
                    blockoverride "ranking_3_datamodel" {
                        datamodel = "[GetGlobalList('mr_architect_ranking_global_list')]"
                    }
                    blockoverride "ranking_3_datacontext"{
                        datacontext = "[Scope.GetCharacter]"
                    }
                    blockoverride "ranking_3_text_column_2"{
                        raw_text = "#tooltip:[GetRawTextTooltipTag('gaudi_architect_rating_tt_loc')] [Character.GetCustom('gaudi_architect_rating_icon_type')] #! [Character.GetFullName]"
                    }
                    blockoverride "ranking_variable_used_3" {
                        raw_text = "[Character.MakeScope.GetVariable('gaudi_architect_experience').GetValue|V0]"
                    }
                }
            }
        }
        blockoverride "occupation_data_size" {
            size = { @panel_text_width 440 }
        }
        blockoverride "occupation_data_header_text" {
            text = "mr_artist_architect_data_header"
        }
        blockoverride "occupation_data_content" {
            # Splendid Architecture Points
            mr_shared_data_text = {
                text = "GAUDI_ARCHITECTURAL_SPLENDOUR_VAR"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
            # Splendid Architecture Points
            mr_shared_data_text = {
                text = "ARCHITECTURAL_BLUEPRINTS_VAR"
                blockoverride "font_size" {
                    using = fontsize_xxl
                }
            }
        }
        blockoverride "visit_button" {
            text = "MR_ARCHITECT_VISIT_CAPITAL_BUTTON"
            datacontext = "[GetScriptedGui('mr_visit_capital_gui_button_sgui')]"
            onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
            enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
            tooltip = "MR_ARCHITECT_VISIT_CAPITAL_BUTTON_TT"
        }
        blockoverride "big_box_content" {
            mr_shared_interactions = {
                blockoverride "interaction_size" {
                    minimumsize = { @[ panel_button_width + 20 ] 50 }
                    maximumsize = { @[ panel_button_width + 20 ] -1 }
                }
                blockoverride "tabs" {
                    tab_buttons = {
                        maximumsize = { @[ panel_button_width + 20 ] 0 }
                        margin_bottom = -4
                        blockoverride "first_button" {
                            text = "MR_ARTISTS_ARCHITECT_GENERAL_TAB"
                        }
                        blockoverride "first_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_artist_architect_tab', 'general')]"
                        }
                        blockoverride "first_button_visibility" {
                            visible = "[Or(GetVariableSystem.HasValue('mr_artist_architect_tab', 'general'), Not(GetVariableSystem.Exists('mr_artist_architect_tab')))]"
                        }
                        blockoverride "first_button_visibility_checked" {
                            visible = "[And(Not(GetVariableSystem.HasValue('mr_artist_architect_tab', 'general')), GetVariableSystem.Exists('mr_artist_architect_tab'))]"
                        }
                        blockoverride "first_button_selected" {
                            text = "MR_ARTISTS_ARCHITECT_GENERAL_TAB"
                        }

                        blockoverride "second_button" {
                            text = "MR_ARTISTS_ARCHITECT_BLUEPRINTS_TAB"
                        }
                        blockoverride "second_button_click" {
                            onclick = "[GetVariableSystem.Set('mr_artist_architect_tab', 'blueprints')]"
                        }
                        blockoverride "second_button_visibility" {
                            visible = "[GetVariableSystem.HasValue('mr_artist_architect_tab', 'blueprints')]"
                        }
                        blockoverride "second_button_visibility_checked" {
                            visible = "[Not(GetVariableSystem.HasValue('mr_artist_architect_tab', 'blueprints'))]"
                        }
                        blockoverride "second_button_selected" {
                            text = "MR_ARTISTS_ARCHITECT_BLUEPRINTS_TAB"
                        }
                    }
                }
                blockoverride "tab_content" {
                    vbox = {
                        visible = "[Or(GetVariableSystem.HasValue('mr_artist_architect_tab', 'general'), Not(GetVariableSystem.Exists('mr_artist_architect_tab')))]"
                        layoutpolicy_vertical = expanding
                        spacing = 7
                        minimumsize = { @panel_button_width 0 }

                        # Public Construction
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_public_construction_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_PUBLIC_CONSTRUCTION_BUTTON"
                                tooltip = "MR_ARCHITECT_PUBLIC_CONSTRUCTION_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = "[GetScriptedGui('mr_architect_public_construction_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_public_construction_button.dds"
                            }
                        }

                        # Study Trip
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_study_trip_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_STUDY_TRIP_BUTTON"
                                tooltip = "MR_ARCHITECT_STUDY_TRIP_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = "[GetScriptedGui('mr_architect_study_trip_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_study_trip_button.dds"
                            }
                        }

                        # Architect Treatise
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_treatise_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_TREATISE_BUTTON"
                                tooltip = "MR_ARCHITECT_TREATISE_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = "[GetScriptedGui('mr_architect_treatise_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_architect_treatise_button.dds"
                            }
                        }

                        # Capital Expansion
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_capital_expansion_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_CAPITAL_EXPANSION_BUTTON"
                                tooltip = "MR_ARCHITECT_CAPITAL_EXPANSION_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = "[GetScriptedGui('mr_architect_capital_expansion_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_capital_expansion_button.dds"
                            }
                        }

                        # Urban Planning
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_urban_planning_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_URBAN_PLANNING_BUTTON"
                                tooltip = "MR_ARCHITECT_URBAN_PLANNING_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = "[GetScriptedGui('mr_architect_urban_planning_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_urban_planning_button.dds"
                            }
                        }

                        # Modern Splendour Button
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_modern_splendour_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_MODERN_SPLENDOUR_BUTTON"
                                tooltip = "MR_ARCHITECT_MODERN_SPLENDOUR_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = "[GetScriptedGui('mr_architect_modern_splendour_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_modern_splendour_button.dds"
                            }
                        }

                        # Custom Monument Blueprint
                        mr_shared_project_button = {
                            datacontext = "[GetScriptedGui('mr_architect_custom_monument_blueprint_button_sgui')]"
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_CUSTOM_MONUMENT_BLUEPRINT_BUTTON"
                                tooltip = "MR_ARCHITECT_CUSTOM_MONUMENT_BLUEPRINT_BUTTON_TT"
                            }
                            blockoverride "size" {
                                size = { @[ panel_button_width - 20 ] 45 }
                            }
                            blockoverride "button_highlight_visible" {
                                 visible = "[GetScriptedGui('mr_architect_custom_monument_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                        }

                        expand = {}
                    }
                    vbox = {
                        visible = "[GetVariableSystem.HasValue('mr_artist_architect_tab', 'blueprints')]"
                        layoutpolicy_vertical = expanding
                        spacing = 7
                        minimumsize = { @panel_button_width 0 }

                        # Create Monument Blueprints
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_blueprints_monument_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_BLUEPRINTS_MONUMENT_BUTTON"
                                tooltip = "MR_ARCHITECT_BLUEPRINTS_MONUMENT_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = no
                            #    visible = "[GetScriptedGui('mr_architect_blueprints_monument_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_blueprint_monument_button.dds"
                            }
                        }

                        # Create Square Blueprints
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_blueprints_square_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_BLUEPRINTS_SQUARE_BUTTON"
                                tooltip = "MR_ARCHITECT_BLUEPRINTS_SQUARE_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = no
                            #    visible = "[GetScriptedGui('mr_architect_blueprints_square_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_blueprint_square_button.dds"
                            }
                        }

                        # Create Service Buildings Blueprints
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_blueprints_service_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_BLUEPRINTS_SERVICE_BUTTON"
                                tooltip = "MR_ARCHITECT_BLUEPRINTS_SERVICE_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = no
                            #    visible = "[GetScriptedGui('mr_architect_blueprints_service_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_blueprint_service_button.dds"
                            }
                        }

                        # Create Health Buildings Blueprints
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_blueprints_health_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
                            blockoverride "button_size" {
                                size = { @[ panel_button_width - 40 ] 45 }
                            }
                            blockoverride "button_content" {
                                text = "MR_ARCHITECT_BLUEPRINTS_HEALTH_BUTTON"
                                tooltip = "MR_ARCHITECT_BLUEPRINTS_HEALTH_BUTTON_TT"
                            }
                            blockoverride "button_highlight_visible" {
                                visible = no
                            #    visible = "[GetScriptedGui('mr_architect_blueprints_health_button_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                            }
                            blockoverride "button_icon" {
                                texture = "gfx/interface/icons/GUI_icons/GUI_gaudi_blueprint_health_button.dds"
                            }
                        }

                        # Create Academy Blueprints
                        mr_shared_activity_button = {
                            datacontext = "[GetScriptedGui('mr_architect_blueprints_academy_button_sgui')]"
                            blockoverride "size" {
                                size = { @[ panel_button_width - 60 ] 45 }
                            }
