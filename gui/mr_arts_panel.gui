    type mr_arts_promote = mr_shared_basic_box {
        name = "mr_tutorial_highlight_arts_promote"
        blockoverride "general_header_text" {
            text = mr_artist_promote_header
        }
        blockoverride "content" {
            spacing = 20

            vbox = {
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding
                spacing = 30
                margin = { 15 0 }

                vbox = {
                    layoutpolicy_horizontal = expanding
                    margin = { 20 0 }
                    margin_bottom = 20
                    spacing = 20
                    background = {
                        using = simple_frame
                    }

                    default_header_clean_faded = {
                        layoutpolicy_horizontal = expanding
                        blockoverride "text" {
                            text = "PROGRESS_TO_NEXT_ARTIST"
                        }
                        blockoverride "text_size" {
                            using = fontsize_xxl
                        }
                        blockoverride "size" {
                            size = { 100% 50 }
                        }
                    }

                    vbox = {
                        spacing = 20
                        layoutpolicy_horizontal = expanding
                        layoutpolicy_vertical = expanding

                        textbox = {
                            layoutpolicy_horizontal = expanding
                            text = "CURRENT_ARTISTIC_PROGRESS"
                            autoresize = yes
                            multiline = yes
                            using = fontsize_xl
                            align = center
                        }

                        hbox = {
                            spacing = 20
                            layoutpolicy_horizontal = expanding

                            mr_shared_left_icon_button = {
                                blockoverride "datacontext" {
                                    datacontext = "[GetScriptedGui('mr_patron_of_the_arts_sgui')]"
                                }
                                blockoverride "button_content" {
                                    text = "MR_PATRON_OF_THE_ARTS_BUTTON"
                                    tooltip = "MR_PATRON_OF_THE_ARTS_BUTTON_TT"
                                }
                                blockoverride "icon_size" {
                                    size = { 50% 50% }
                                }
                                blockoverride "size" {
                                    size = { 200 45 }
                                }
                                blockoverride "icon" {
                                    texture = "gfx/interface/icons/generic_icons/coin_icon_13.dds"
                                }
                                blockoverride "icon_highlight_visible" {
                                    visible = "[GetScriptedGui('mr_artists_patron_of_the_arts_is_active_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                                }
                            }

                            green_progressbar_horizontal = {
                                layoutpolicy_horizontal = expanding
                                blockoverride "values" {
                                    min = 0
                                    max = 1000
                                    value = "[FixedPointToFloat(Country.MakeScope.Var('artists_artistic_progress_var').GetValue)]"
                                }
                                tooltip = "MR_ARTISTIC_PROGRESS_BAR_TT"
                                textbox = {
                                    max_update_rate = 100
                                    text = "MR_ARTISTIC_PROGRESS_VALUES"
                                    size = { 100% 100% }
                                    using = fontsize_xl
                                    align = center
                                }
                            }
                        }
                    }
                }

                hbox = {
                    layoutpolicy_horizontal = expanding
                    layoutpolicy_vertical = expanding
                    spacing = 20
                    # Promote Architect
                    mr_shared_left_icon_button = {
                            blockoverride "datacontext" {
                                datacontext = "[GetScriptedGui('mr_artists_promote_architect_sgui')]"
                            }
                        blockoverride "button_content" {
                            text = "MR_ARCHITECT_HEADER_TEXT"
                            tooltip = "MR_PROMOTE_ARCHITECT_TT"
                        }
                        blockoverride "icon_size" {
                            size = { 100% 100% }
                        }
                        blockoverride "size" {
                            size = { 250 45 }
                        }
                        blockoverride "icon" {
                            texture = "gfx/interface/icons/character_role_icons/gaudi_architect_role.dds"
                        }
                        blockoverride "icon_highlight_visible" {
                            visible = "[GetScriptedGui('mr_artists_architect_is_promoted_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                        }
                    }
                    # Promote Composer
                    mr_shared_left_icon_button = {
                            blockoverride "datacontext" {
                                datacontext = "[GetScriptedGui('mr_artists_promote_composer_sgui')]"
                            }
                        blockoverride "button_content" {
                            text = "COMPOSER_HEADER_TEXT"
                            tooltip = "MR_PROMOTE_COMPOSER_TT"
                        }
                        blockoverride "icon_size" {
                            size = { 100% 100% }
                        }
                        blockoverride "size" {
                            size = { 250 45 }
                        }
                        blockoverride "icon" {
                            texture = "gfx/interface/icons/character_role_icons/elgar_composer_role.dds"
                        }
                        blockoverride "icon_highlight_visible" {
                            visible = "[GetScriptedGui('mr_artists_composer_is_promoted_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                        }
                    }
                    # Promote Writer
                    mr_shared_left_icon_button = {
                            blockoverride "datacontext" {
                                datacontext = "[GetScriptedGui('mr_artists_promote_writer_sgui')]"
                            }
                        blockoverride "button_content" {
                            text = "WRITER_HEADER_TEXT"
                            tooltip = "MR_PROMOTE_WRITER_TT"
                        }
                        blockoverride "icon_size" {
                            size = { 100% 100% }
                        }
                        blockoverride "size" {
                            size = { 250 45 }
                        }
                        blockoverride "icon" {
                            texture = "gfx/interface/icons/character_role_icons/manzoni_writer_role.dds"
                        }
                        blockoverride "icon_highlight_visible" {
                            visible = "[GetScriptedGui('mr_artists_writer_is_promoted_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                        }
                    }
                    # Promote Painter
                    mr_shared_left_icon_button = {
                            blockoverride "datacontext" {
                                datacontext = "[GetScriptedGui('mr_artists_promote_painter_sgui')]"
                            }
                        blockoverride "button_content" {
                            text = "PAINTER_HEADER_TEXT"
                            tooltip = "MR_PROMOTE_PAINTER_TT"
                        }
                        blockoverride "icon_size" {
                            size = { 100% 100% }
                        }
                        blockoverride "size" {
                            size = { 250 45 }
                        }
                        blockoverride "icon" {
                            texture = "gfx/interface/icons/character_role_icons/klimt_painter_role.dds"
                        }
                        blockoverride "icon_highlight_visible" {
                            visible = "[GetScriptedGui('mr_artists_painter_is_promoted_sgui').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
                        }
                    }
                }
            }
        }
    }

