									text = "MR_PSYCHOTHERAPEUTIC_LEVEL"
									parentanchor = top|hcenter
									max_width = 250
									autoresize = yes
									elide = right
									using = fontsize_xl
								}

								green_progressbar_horizontal = {
									size = { 410 35 }
									blockoverride "values" {
										min = 0
										max = 1000
										value = "[FixedPointToFloat(Country.MakeScope.Var('panum_psycho_points_var').GetValue)]"
									}
									textbox = {
										text = "MR_PSYCHOTHERAPEUTIC_POINTS"
										position = { 10 4 }
										parentanchor = left
										autoresize = yes
										using = fontsize_large
									}
									tooltip = "MR_PSYCHOTHERAPEUTIC_POINTS_TT"
								}

								textbox = {
									text = "MR_BASIC_SUCCESS_CHANCE_PSYCHOLOGY"
									max_update_rate = 100 #We don't want the script value to reevaluate every frame
									parentanchor = top|hcenter
									max_width = 410
									autoresize = yes
									elide = right
									using = fontsize_large
								}
							}

							flowcontainer = {
								#	margin_top = 12
								direction = vertical
								ignoreinvisible = yes
								spacing = 4

								textbox = {
									text = "MR_PSYCHOLOGICAL_SCHOOLS"
									parentanchor = top|hcenter
									max_width = 420
									autoresize = yes
									elide = right
									using = fontsize_xl
								}

								textbox = {
									text = "MR_FUNCTIONALISM"
									parentanchor = top|left
