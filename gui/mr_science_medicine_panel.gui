types mr_main_science_panel_types {

	type mr_science_medicine_panel = fullscreen_block_window {
		name = "mr_main_medicine_panel"
		datacontext = "[GetMetaPlayer.GetPlayedOrObservedCountry]"

		visible = "[GetVariableSystem.HasValue('com_open_window', 'mr_academic_medicine')]"

		blockoverride "animation_state_block" {
			state = {
				name = _show
				# Close open panel before showing this one
				on_start = "[InformationPanelBar.ClosePanel]"
				on_start = "[MapListPanelManager.CloseCurrentPanel]"
				# Fullscreen panels hide topbar
				on_finish = "[GetVariableSystem.Set('com_fullscreen', 'com_fullscreen')]"
				start_sound = {
					soundeffect = "event:/SFX/UI/SideBar/markets"
				}
				start_sound = {
					soundeffect = "snapshot:/Dynamic/mute_world_80"
				}
				start_sound = {
					soundeffect = "snapshot:/Dynamic/mute_vfx_war_100"
				}
			}

			state = {
				name = _hide
				on_start = "[GetVariableSystem.Clear('com_fullscreen')]"
				start_sound = {
					soundeffect = "event:/SFX/UI/SideBar/markets_stop"
				}
			}
		}

		blockoverride "window_header_name" {
			text = MEDICINE_HEADER
			default_format = "#bold"
		}

		blockoverride "back_button_fullscreen" {
			back_button_large = {
				position = { 11 15 }
				parentanchor = top|left
				onclick = "[GetVariableSystem.Set('com_open_window', 'mr_sidebar_button_science_sgui')]"
				onclick = "[GetVariableSystem.Set('mr_science_tab', 'humanities')]"
				tooltip = "MR_RETURN_ACADEMY_OF_SCIENCE_TT"
				input_action = "back"
			}
		}

		close_button_large = {
			name = "tutorial_highlight_close_button"
			parentanchor = top|right
			onclick = "[GetVariableSystem.Clear('com_open_window')]"
			onclick = "[GetVariableSystem.Clear('com_alert_action')]"
			onclick = "[GetVariableSystem.Clear('com_fullscreen')]"
			shortcut = "close_window"
			position = { -56 115 }
		}

		blockoverride "close_button_position" {
			visible = no
		}

		blockoverride "fixed_top" {
			flowcontainer = {
				minimumsize = { 100% -1 }
				margin_top = 20

				button = {
					#Button to get back to the Academy of Science
					using = default_button_primary_big_action
					size = { 250 40 }
					raw_text = "MR_RETURN_ACADEMY_OF_SCIENCE"
					using = fontsize_medium
					onclick = "[GetVariableSystem.Set('com_open_window', 'mr_sidebar_button_science_sgui')]"
					onclick = "[GetVariableSystem.Set('mr_science_tab', 'humanities')]"
					tooltip = "MR_RETURN_ACADEMY_OF_SCIENCE_TT"
				}
			}
		}

		blockoverride "scrollarea_content" {
			flowcontainer = {
				minimumsize = { 100% -1 }
				margin = { 0 20 }
				margin_left = 20
				spacing = 10

				#Diseases Research
				widget = {
					size = { 910 720 }
					parentanchor = left

					background = {
						using = entry_bg_simple
					}

					default_header_clean = {
						size = { 910 50 }
						position = { 1 -3 }
						blockoverride "text" {
						}
						textbox = {
							text = "DISEASES_HEADER_TEXT"
							parentanchor = center
							position = { 0 0 }
							autoresize = yes
							max_width = 190
							elide = right
							using = fontsize_xxl
						}
					}

					widget = {
						size = { 570 660 }
						position = { 10 50 }
						background = {
							using = entry_bg_simple
						}
						#Cholera
						academics_medicine_diseases_catalogue_overview = {
							blockoverride "main_visibility" {
								visible = "[GetScriptedGui('mr_physician_cholera_catalogue_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
							}
							blockoverride "disease_name" {
								text = "MR_CHOLERA_CATALOGUE_BUTTON"
							}
							blockoverride "disease_description" {
								text = "MR_CHOLERA_DESCRIPTION_LOC"
							}
							blockoverride "disease_technology" {
								text = "MR_CHOLERA_REQUIRED_TECHNOLOGY_LOC"
							}
							blockoverride "disease_healthcare_level" {
								text = "MR_CHOLERA_REQUIRED_HEALTHCARE_LEVEL_LOC"
							}
							blockoverride "disease_type" {
								text = "MR_PANUM_TRANSREGIONAL_DISEASE_LOC"
							}
							blockoverride "first_description" {
								text = "MR_CHOLERA_FIRST_DESCRIPTION_LOC"
								visible = "[GetScriptedGui('mr_physician_cholera_first_description_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
							}
							blockoverride "first_treatment" {
								text = "MR_CHOLERA_FIRST_TREATMENT_LOC"
								visible = "[GetScriptedGui('mr_physician_cholera_first_treatment_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
							}
							blockoverride "pathogen_discovery" {
								text = "MR_CHOLERA_DISCOVERER_LOC"
								visible = "[GetScriptedGui('mr_physician_cholera_pathogen_discovered_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
							}
							blockoverride "vaccine_invention" {
								text = "MR_CHOLERA_INVENTOR_LOC"
								visible = "[GetScriptedGui('mr_physician_cholera_vaccine_invented_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
							}
							blockoverride "description_finished" {
								text = "MR_CHOLERA_DESCRIPTION_FINISHED_LOC"
