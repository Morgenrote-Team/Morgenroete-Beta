	type academics_medicine_diseases_catalogue_button =	hbox {
		block "visible" {}
		widget = {
			size = { 18 50 }

			icon = {
				block "datacontext_arrow" {
					datacontext = "[GetScriptedGui('mr_physician_yellow_fever_catalogue_active_sgui')]"
				}
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
				size = { 100% 100% }
				texture = "gfx/interface/icons/generic_icons/arrow_left.dds"
			}
		}
		button = {
			using = default_button_primary_big_action
			size = { 270 50 }
			block "text_button" {
				raw_text = "MR_YELLOW_FEVER_CATALOGUE_BUTTON"
			}
			using = fontsize_xxl

			block "datacontext_button" {
				datacontext = "[GetScriptedGui('mr_physician_yellow_fever_catalogue_button_sgui')]"
			}
			onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Country.MakeScope ).End )]"
			enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Country.MakeScope ).End )]"
			block "tooltip_button" {
				tooltip = "MR_YELLOW_FEVER_CATALOGUE_BUTTON_TT"
			}
		}
	}

}