	type academics_medicine_diseases_catalogue_overview = flowcontainer {
		block "main_visibility" {
			visible = "[GetScriptedGui('mr_physician_cholera_catalogue_active_sgui').IsShown( GuiScope.SetRoot( Country.MakeScope ).End )]"
